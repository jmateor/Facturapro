@using Facturapro.Data
@using Microsoft.EntityFrameworkCore
@inject ApplicationDbContext _context
@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
@{
    var csrfToken = Antiforgery.GetAndStoreTokens(Context).RequestToken;
    var warehouseCount = await _context.Almacenes.CountAsync();
}
<!DOCTYPE html>
<html lang="es" data-bs-theme="light" data-layout="vertical" data-layout-mode="fluid" data-topbar-color="light" data-menu-color="dark" data-sidenav-size="default" data-layout-position="fixed">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Facturapro</title>

    <!-- Escudo de Consola contra Extensiones -->
    <script>
        (function() {
            const originalError = console.error;
            const originalWarn = console.warn;
            const noiseFilters = [
                'tabs:outgoing',
                'message channel closed',
                'No Listener:',
                'chrome-extension',
                'moz-extension',
                'asynchronous response',
                'Permisos denegados'
            ];

            console.error = function() {
                const msg = Array.from(arguments).join(' ');
                if (noiseFilters.some(filter => msg.includes(filter))) return;
                originalError.apply(console, arguments);
            };

            console.warn = function() {
                const msg = Array.from(arguments).join(' ');
                if (noiseFilters.some(filter => msg.includes(filter))) return;
                originalWarn.apply(console, arguments);
            };

            // Capturar promesas no capturadas (Unhandled Rejections) de extensiones
            window.addEventListener('unhandledrejection', function(event) {
                const reason = event.reason ? (event.reason.message || event.reason.toString()) : '';
                if (noiseFilters.some(filter => reason.includes(filter))) {
                    event.preventDefault();
                    return;
                }
            });
        })();
    </script>

    <meta content="Sistema de facturación electrónica para República Dominicana" name="description" />
    <meta content="Facturapro" name="author" />
    <meta name="csrf-token" content="@csrfToken" />

    <!-- App favicon -->
    <link rel="shortcut icon" href="~/velonic/images/favicon.ico">

    <!-- Theme Config Js -->
    <script src="~/velonic/js/config.js"></script>

    <!-- App css -->
    <link href="~/velonic/css/app.min.css" rel="stylesheet" type="text/css" id="app-style" />

    <!-- Icons css -->
    <link href="~/velonic/css/icons.min.css" rel="stylesheet" type="text/css" />

    <!-- Custom css -->
    <link href="~/css/custom-velonic.css" rel="stylesheet" type="text/css" asp-append-version="true" />
    <link href="~/css/validacion.css" rel="stylesheet" type="text/css" asp-append-version="true" />
    <link href="~/css/skeleton.css" rel="stylesheet" type="text/css" asp-append-version="true" />
    <link href="~/css/toasts.css" rel="stylesheet" type="text/css" asp-append-version="true" />

    @await RenderSectionAsync("Styles", required: false)

    <style>
        /* ===== TRANSICIONES ELEGANTES DE PÁGINA ===== */

        /* Barra de progreso superior sutil */
        #page-loader-bar {
            position: fixed;
            top: 0;
            left: 0;
            height: 2px;
            width: 0%;
            background: #6658dd;
            z-index: 100000;
            transition: width 0.3s ease-out;
            border-radius: 0 2px 2px 0;
        }
        #page-loader-bar.loading { width: 60%; }
        #page-loader-bar.done { width: 100%; opacity: 0; transition: width 0.2s ease, opacity 0.3s ease 0.1s; }

        /* Contenido principal - transición sutil */
        .content-page {
            opacity: 1;
            transition: opacity 0.15s ease-out;
        }

        /* Efecto de salida al navegar - muy sutil */
        .page-exit {
            opacity: 0.7 !important;
        }

        /* Overlay sutil */
        #page-transition-overlay {
            position: fixed;
            inset: 0;
            background: rgba(102, 88, 221, 0.03);
            z-index: 99998;
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.15s ease-out;
        }
        #page-transition-overlay.active {
            opacity: 1;
            pointer-events: all;
        }

        [data-bs-theme='dark'] #page-transition-overlay {
            background: rgba(102, 88, 221, 0.05);
        }

        /* Sidebar - hover suave */
        .side-nav-link {
            transition: all 0.2s ease !important;
        }
        .side-nav-link:hover {
            padding-left: 18px !important;
            background-color: rgba(102, 88, 221, 0.1);
        }
    </style>
</head>
<body>
    <!-- Elementos de Transición Premium -->
    <div id="page-loader-bar"></div>
    <div id="page-transition-overlay"></div>

    <!-- Begin page -->
    <div class="wrapper">

