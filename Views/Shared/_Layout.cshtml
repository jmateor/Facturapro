                            <a href="@Url.Action("Dashboard", "Reportes")" class="side-nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Reportes" && ViewContext.RouteData.Values["Action"]?.ToString() == "Dashboard" ? "active" : "")">
                                <i class="ri-bar-chart-box-line"></i>
