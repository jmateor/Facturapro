                <div class="clearfix"></div>
            </div>
        </div>
        <!-- ========== Left Sidebar End ========== -->

        <!-- ============================================================== -->
        <!-- Start Page Content here -->
        <!-- ============================================================== -->

        <div class="content-page">
            <div class="content">

                <!-- Start Content-->
                <div class="container-fluid">

                    @RenderBody()

                </div>
                <!-- container -->

            </div>
            <!-- content -->

            <!-- Footer Start -->
            <footer class="footer">
                <div class="container-fluid">
                    <div class="row">
                        <div class="col-12 text-center">
                            <script>document.write(new Date().getFullYear())</script> © Facturapro - Sistema de Facturación Electrónica
                        </div>
                    </div>
                </div>
            </footer>
            <!-- end Footer -->

        </div>
        <!-- ============================================================== -->
        <!-- End Page content -->
        <!-- ============================================================== -->

    </div>
    <!-- END wrapper -->

    <!-- Buscador Global (Command Palette) -->
    <partial name="_GlobalSearch" />

    <!-- Notificaciones Toast -->
    <partial name="_Toasts" />

    <script>
        // Filtro para silenciar errores ruidosos de extensiones del navegador
        (function() {
            const originalError = console.error;
            console.error = function() {
                const msg = arguments[0] ? arguments[0].toString() : "";
                if (msg.includes("tabs:outgoing") || msg.includes("message channel closed") || msg.includes("No Listener")) {
                    // Silenciar ruido de extensiones
                    return;
                }
                originalError.apply(console, arguments);
            };
        })();
    </script>

    <!-- Vendor js -->
    <script src="~/velonic/js/vendor.min.js"></script>

    <!-- App js -->
    <script src="~/velonic/js/app.min.js"></script>

    <!-- Validación en Tiempo Real -->
    <script src="~/js/validacion.js" asp-append-version="true"></script>

    <!-- Buscador Global -->
    <script src="~/js/search.js" asp-append-version="true"></script>

    <!-- Skeleton Loaders -->
    <script src="~/js/skeleton.js" asp-append-version="true"></script>

    <!-- Toast Notifications -->
    <script src="~/js/toasts.js" asp-append-version="true"></script>

    <!-- UI Enhancements -->
    <script src="~/js/ui-enhancements.js" asp-append-version="true"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <!-- Form Guard (Prevent Data Loss) -->
    <script src="~/js/form-guard.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)


    <script>
    </script>
    <script>
        // Manejo Global de TempData con Toasts
        document.addEventListener('DOMContentLoaded', function() {
            @if (TempData["SuccessMessage"] != null)
            {
                <text>window.Toast.success("¡Éxito!", "@TempData["SuccessMessage"]");</text>
            }
            @if (TempData["ErrorMessage"] != null)
            {
                <text>window.Toast.error("Error", "@TempData["ErrorMessage"]");</text>
            }
            @if (TempData["InfoMessage"] != null)
            {
                <text>window.Toast.info("Información", "@TempData["InfoMessage"]");</text>
            }
        });
    </script>
</body>
</html>
