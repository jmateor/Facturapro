<!DOCTYPE html>
<html lang="es" data-bs-theme="light" data-layout="vertical" data-layout-mode="fluid" data-topbar-color="light" data-menu-color="dark" data-sidenav-size="default" data-layout-position="fixed">
@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
@{
    var csrfToken = Antiforgery.GetAndStoreTokens(Context).RequestToken;
}
<!DOCTYPE html>
<html lang="es" data-bs-theme="light" data-layout="vertical" data-layout-mode="fluid" data-topbar-color="light" data-menu-color="dark" data-sidenav-size="default" data-layout-position="fixed">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Facturapro</title>
    <meta content="Sistema de facturación electrónica para República Dominicana" name="description" />
    <meta content="Facturapro" name="author" />
    <meta name="csrf-token" content="@csrfToken" />

    <!-- App favicon -->
    <link rel="shortcut icon" href="~/velonic/images/favicon.ico">

    <!-- Theme Config Js -->
    <script src="~/velonic/js/config.js"></script>

    <!-- App css -->
    <link href="~/velonic/css/app.min.css" rel="stylesheet" type="text/css" id="app-style" />

    <!-- Icons css -->
    <link href="~/velonic/css/icons.min.css" rel="stylesheet" type="text/css" />

    <!-- Custom css -->
    <link href="~/css/custom-velonic.css" rel="stylesheet" type="text/css" asp-append-version="true" />

    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <!-- Begin page -->
    <div class="wrapper">

        <!-- ========== Topbar Start ========== -->
        <div class="navbar-custom">
            <div class="topbar container-fluid">
                <div class="d-flex align-items-center gap-1">

                    <!-- Topbar Brand Logo -->
                    <div class="logo-topbar">
                        <!-- Logo light -->
                        <a href="@Url.Action("Index", "Home")" class="logo-light">
                            <span class="logo-lg">
                                <span class="fw-bold fs-4" style="color: #fff;">📄 FACTURAPRO</span>
                            </span>
                            <span class="logo-sm">
                                <span class="fw-bold fs-4" style="color: #fff;">📄</span>
                            </span>
                        </a>

                        <!-- Logo Dark -->
                        <a href="@Url.Action("Index", "Home")" class="logo-dark">
                            <span class="logo-lg">
                                <span class="fw-bold fs-4">📄 FACTURAPRO</span>
                            </span>
                            <span class="logo-sm">
                                <span class="fw-bold fs-4">📄</span>
                            </span>
                        </a>
                    </div>

                    <!-- Sidebar Menu Toggle Button -->
                    <button class="button-toggle-menu">
                        <i class="ri-menu-line"></i>
                    </button>

                    <!-- Horizontal Menu Toggle Button -->
                    <button class="navbar-toggle" data-bs-toggle="collapse" data-bs-target="#topnav-menu-content">
                        <div class="lines">
                            <span></span>
                            <span></span>
                            <span></span>
                        </div>
                    </button>
                </div>

                <ul class="topbar-menu d-flex align-items-center gap-3">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <li class="dropdown">
                            <a class="nav-link dropdown-toggle arrow-none nav-user" data-bs-toggle="dropdown" href="#" role="button"
                               aria-haspopup="false" aria-expanded="false">
                                <span class="account-user-avatar">
                                    <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center" style="width: 32px; height: 32px;">
                                        @(User.Identity?.Name?[0].ToString().ToUpper() ?? "U")
                                    </div>
                                </span>
                                <span class="d-lg-block d-none">
                                    <h5 class="my-0 fw-normal">@(User.Identity?.Name?.Split('@')[0] ?? "Usuario") <i class="ri-arrow-down-s-line d-none d-sm-inline-block align-middle"></i></h5>
                                </span>
                            </a>
                            <div class="dropdown-menu dropdown-menu-end dropdown-menu-animated profile-dropdown">
                                <div class="dropdown-header noti-title">
                                    <h6 class="text-overflow m-0">Bienvenido!</h6>
                                </div>

                                <a href="@Url.Action("Profile", "Account")" class="dropdown-item">
                                    <i class="ri-account-circle-line fs-18 align-middle me-1"></i>
                                    <span>Mi Perfil</span>
                                </a>

                                <a href="@Url.Action("Index", "Configuracion")" class="dropdown-item">
                                    <i class="ri-settings-4-line fs-18 align-middle me-1"></i>
                                    <span>Configuración</span>
                                </a>

                                <div class="dropdown-divider"></div>

                                <form asp-action="Logout" asp-controller="Account" method="post" class="m-0">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="dropdown-item text-danger border-0 bg-transparent w-100 text-start">
                                        <i class="ri-logout-box-line fs-18 align-middle me-1"></i>
                                        <span>Cerrar Sesión</span>
                                    </button>
                                </form>
                            </div>
                        </li>
                    }
                    else
                    {
                        <li class="d-none d-sm-inline-block">
                            <a href="@Url.Action("Login", "Account")" class="btn btn-primary btn-sm">Iniciar Sesión</a>
                        </li>
                        <li class="d-none d-sm-inline-block">
                            <a href="@Url.Action("Register", "Account")" class="btn btn-outline-primary btn-sm">Registrarse</a>
                        </li>
                    }
                </ul>
            </div>
        </div>
        <!-- ========== Topbar End ========== -->

        <!-- ========== Left Sidebar Start ========== -->
        <div class="leftside-menu">

            <!-- Brand Logo Light -->
            <a href="@Url.Action("Index", "Home")" class="logo logo-light">
                <span class="logo-lg">
                    <span class="fw-bold fs-4 text-white">📄 FACTURAPRO</span>
                </span>
                <span class="logo-sm">
                    <span class="fw-bold fs-4 text-white">📄</span>
                </span>
            </a>

            <!-- Brand Logo Dark -->
            <a href="@Url.Action("Index", "Home")" class="logo logo-dark">
                <span class="logo-lg">
                    <span class="fw-bold fs-4">📄 FACTURAPRO</span>
                </span>
                <span class="logo-sm">
                    <span class="fw-bold fs-4">📄</span>
                </span>
            </a>

            <!-- Sidebar -left -->
            <div class="h-100" id="leftside-menu-container" data-simplebar>
                <!--- Sidemenu -->
                <ul class="side-nav">

                    <li class="side-nav-title">Principal</li>

                    <li class="side-nav-item">
                        <a href="@Url.Action("Index", "Home")" class="side-nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Home" && ViewContext.RouteData.Values["Action"]?.ToString() == "Index" ? "active" : "")">
                            <i class="ri-dashboard-3-line"></i>
                            <span> Dashboard </span>
                        </a>
                    </li>

                    <li class="side-nav-item">
                        <a href="@Url.Action("Index", "POS")" class="side-nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "POS" ? "active" : "")">
                            <i class="ri-shopping-cart-2-line"></i>
                            <span> Punto de Venta (POS) </span>
                        </a>
                    </li>

                    <li class="side-nav-item">
                        <a href="@Url.Action("Index", "Facturas")" class="side-nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Facturas" ? "active" : "")">
                            <i class="ri-file-list-3-line"></i>
                            <span> Facturas </span>
                        </a>
                    </li>

                    <li class="side-nav-item">
                        <a href="@Url.Action("Index", "Clientes")" class="side-nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Clientes" ? "active" : "")">
                            <i class="ri-user-3-line"></i>
                            <span> Clientes </span>
                        </a>
                    </li>

                    <li class="side-nav-title">Catálogo</li>

                    <li class="side-nav-item">
                        <a href="@Url.Action("Index", "Productos")" class="side-nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Productos" ? "active" : "")">
                            <i class="ri-box-3-line"></i>
                            <span> Productos </span>
                        </a>
                    </li>

                    <li class="side-nav-item">
                        <a href="@Url.Action("Index", "Categorias")" class="side-nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Categorias" ? "active" : "")">
                            <i class="ri-price-tag-3-line"></i>
                            <span> Categorías </span>
                        </a>
                    </li>

                    <li class="side-nav-title">Inventario</li>

                    <li class="side-nav-item">
                        <a href="@Url.Action("Index", "Kalder")" class="side-nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Kalder" && ViewContext.RouteData.Values["Action"]?.ToString() == "Index" ? "active" : "")">
                            <i class="ri-archive-line"></i>
                            <span> Kalder - Almacén </span>
                        </a>
                    </li>

                    <li class="side-nav-item">
                        <a href="@Url.Action("Index", "Proveedores")" class="side-nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Proveedores" ? "active" : "")">
                            <i class="ri-truck-line"></i>
                            <span> Proveedores </span>
                        </a>
                    </li>

                    <li class="side-nav-item">
                        <a href="@Url.Action("Index", "Compras")" class="side-nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Compras" ? "active" : "")">
                            <i class="ri-shopping-bag-line"></i>
                            <span> Compras </span>
                        </a>
                    </li>

                    <li class="side-nav-item">
                        <a href="@Url.Action("Historial", "Kalder")" class="side-nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "Historial" ? "active" : "")">
                            <i class="ri-history-line"></i>
                            <span> Historial </span>
                        </a>
                    </li>

                    <li class="side-nav-title">DGII - Facturación Electrónica</li>

                    <li class="side-nav-item">
                        <a href="@Url.Action("Index", "Rangos")" class="side-nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Rangos" ? "active" : "")">
                            <i class="ri-file-list-2-line"></i>
                            <span> Rangos de Numeración </span>
                        </a>
                    </li>

                    <li class="side-nav-item">
                        <a href="@Url.Action("Index", "Configuracion")" class="side-nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Configuracion" ? "active" : "")">
                            <i class="ri-settings-3-line"></i>
                            <span> Configuración </span>
                        </a>
                    </li>

                    <li class="side-nav-title">Reportes</li>

                    <li class="side-nav-item">
                        <a href="@Url.Action("Dashboard", "Reportes")" class="side-nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Reportes" && ViewContext.RouteData.Values["Action"]?.ToString() == "Dashboard" ? "active" : "")">
                            <i class="ri-bar-chart-box-line"></i>
                            <span> Dashboard Completo </span>
                        </a>
                    </li>

                    <li class="side-nav-item">
                        <a href="@Url.Action("Ventas", "Reportes")" class="side-nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "Ventas" ? "active" : "")">
                            <i class="ri-line-chart-line"></i>
                            <span> Reporte de Ventas </span>
                        </a>
                    </li>

                    <li class="side-nav-item">
                        <a href="@Url.Action("Inventario", "Reportes")" class="side-nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "Inventario" ? "active" : "")">
                            <i class="ri-pie-chart-line"></i>
                            <span> Reporte de Inventario </span>
                        </a>
                    </li>

                </ul>
                <!--- End Sidemenu -->

                <div class="clearfix"></div>
            </div>
        </div>
        <!-- ========== Left Sidebar End ========== -->

        <!-- ============================================================== -->
        <!-- Start Page Content here -->
        <!-- ============================================================== -->

        <div class="content-page">
            <div class="content">

                <!-- Start Content-->
                <div class="container-fluid">

                    @RenderBody()

                </div>
                <!-- container -->

            </div>
            <!-- content -->

            <!-- Footer Start -->
            <footer class="footer">
                <div class="container-fluid">
                    <div class="row">
                        <div class="col-12 text-center">
                            <script>document.write(new Date().getFullYear())</script> © Facturapro - Sistema de Facturación Electrónica
                        </div>
                    </div>
                </div>
            </footer>
            <!-- end Footer -->

        </div>
        <!-- ============================================================== -->
        <!-- End Page content -->
        <!-- ============================================================== -->

    </div>
    <!-- END wrapper -->

    <!-- Vendor js -->
    <script src="~/velonic/js/vendor.min.js"></script>

    <!-- App js -->
    <script src="~/velonic/js/app.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
