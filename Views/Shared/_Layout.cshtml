                                <i class="ri-article-line"></i>
                                <span> Reportes Fiscales (606/607) </span>
                            </a>
                        </li>

                        <li class="side-nav-item">
                            <a href="@Url.Action("Index", "Configuracion")" class="side-nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Configuracion" ? "active" : "")">
