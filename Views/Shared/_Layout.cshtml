                                <i class="ri-box-3-line"></i>
                                <span> Productos </span>
                            </a>
                        </li>

                        <li class="side-nav-item">
                            <a href="@Url.Action("Index", "Categorias")" class="side-nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Categorias" ? "active" : "")">
                                <i class="ri-price-tag-3-line"></i>
                                <span> Categorías </span>
                            </a>
                        </li>
                    }

                    @if (User.IsInRole("Admin") || User.IsInRole("Gerente"))
                    {
                        <li class="side-nav-title mt-2">Configuración</li>

                        <li class="side-nav-item">
                            <a href="@Url.Action("Index", "Kalder")" class="side-nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Kalder" && ViewContext.RouteData.Values["Action"]?.ToString() == "Index" ? "active" : "")">
                                <i class="ri-archive-line"></i>
                                <span> Kalder - Almacén </span>
                            </a>
                        </li>

                        <li class="side-nav-item">
                            <a href="@Url.Action("Index", "Proveedores")" class="side-nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Proveedores" ? "active" : "")">
