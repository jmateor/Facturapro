                            <a href="@Url.Action("Index", "Compras")" class="side-nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Compras" ? "active" : "")">
                                <i class="ri-shopping-bag-line"></i>
                                <span> Compras </span>
                            </a>
                        </li>

                        <li class="side-nav-item">
                            <a href="@Url.Action("Historial", "Kalder")" class="side-nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "Historial" ? "active" : "")">
