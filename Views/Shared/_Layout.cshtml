            </div>
        </div>
        <!-- ========== Topbar End ========== -->

        <!-- ========== Left Sidebar Start ========== -->
        <div class="leftside-menu">

            <!-- Brand Logo Light -->
            <a href="@Url.Action("Index", "Home")" class="logo logo-light">
                <span class="logo-lg">
                    <span class="fw-bold fs-4 text-white">📄 FACTURAPRO</span>
                </span>
                <span class="logo-sm">
                    <span class="fw-bold fs-4 text-white">📄</span>
                </span>
            </a>

            <!-- Brand Logo Dark -->
            <a href="@Url.Action("Index", "Home")" class="logo logo-dark">
                <span class="logo-lg">
                    <span class="fw-bold fs-4">📄 FACTURAPRO</span>
                </span>
