@model Facturapro.Controllers.ProfileViewModel
@{
    ViewData["Title"] = "Mi Perfil";
}

<!-- start page title -->
<div class="row">
    <div class="col-12">
        <div class="page-title-box">
            <h4 class="page-title">Mi Perfil</h4>
            <p class="text-muted mb-0">Información de su cuenta</p>
        </div>
    </div>
</div>
<!-- end page title -->

<div class="row">
    <div class="col-lg-6">
        <div class="card">
            <div class="card-header">
                <h5 class="header-title mb-0">Información Personal</h5>
            </div>
            <div class="card-body">
                <div class="d-flex align-items-center mb-4">
                    <div class="flex-shrink-0">
                        <div class="avatar-lg rounded-circle bg-primary text-white d-flex align-items-center justify-content-center" style="width: 80px; height: 80px; font-size: 2rem;">
                            @(Model.Nombre?[0].ToString().ToUpper() ?? "U")
                        </div>
                    </div>
                    <div class="flex-grow-1 ms-3">
                        <h5 class="mb-1">@Model.Nombre @Model.Apellido</h5>
                        <p class="text-muted mb-0">@Model.Email</p>
                        <span class="badge bg-primary">@Model.Rol</span>
                    </div>
                </div>

                <hr />

                <div class="row">
                    <div class="col-sm-6 mb-3">
                        <p class="text-muted mb-1">Fecha de registro</p>
                        <p class="fw-medium">@Model.FechaRegistro.ToString("dd/MM/yyyy HH:mm")</p>
                    </div>
                    <div class="col-sm-6 mb-3">
                        <p class="text-muted mb-1">Último acceso</p>
                        <p class="fw-medium">@(Model.UltimoAcceso?.ToString("dd/MM/yyyy HH:mm") ?? "N/A")</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-6">
        <div class="card">
            <div class="card-header">
                <h5 class="header-title mb-0">Cambiar Contraseña</h5>
            </div>
            <div class="card-body">
                <form asp-action="ChangePassword" method="post">
                    <div class="mb-3">
                        <label for="CurrentPassword" class="form-label">Contraseña actual</label>
                        <input type="password" name="CurrentPassword" class="form-control" required />
                    </div>

                    <div class="mb-3">
                        <label for="NewPassword" class="form-label">Nueva contraseña</label>
                        <input type="password" name="NewPassword" class="form-control" required minlength="8" />
                        <div class="form-text">Mínimo 8 caracteres, incluyendo mayúsculas, minúsculas y números</div>
                    </div>

                    <div class="mb-3">
                        <label for="ConfirmPassword" class="form-label">Confirmar nueva contraseña</label>
                        <input type="password" name="ConfirmPassword" class="form-control" required />
                    </div>

                    <button type="submit" class="btn btn-primary">
                        <i class="ri-lock-password-line me-1"></i>
                        Cambiar Contraseña
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
