@model Facturapro.Controllers.RegisterViewModel
@{
    ViewData["Title"] = "Registro";
    Layout = null;
}

<!DOCTYPE html>
<html lang="es" data-bs-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Facturapro</title>
    <meta content="Sistema de facturación electrónica" name="description" />

    <!-- Theme Config Js -->
    <script src="~/velonic/js/config.js"></script>

    <!-- App css -->
    <link href="~/velonic/css/app.min.css" rel="stylesheet" type="text/css" id="app-style" />

    <!-- Icons css -->
    <link href="~/velonic/css/icons.min.css" rel="stylesheet" type="text/css" />
</head>
<body class="authentication-bg position-relative">
    <div class="account-pages pt-2 pt-sm-5 pb-4 pb-sm-5 position-relative">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-xxl-8 col-lg-10">
                    <div class="card overflow-hidden">
                        <div class="row g-0">
                            <div class="col-lg-6 d-none d-lg-block p-2 bg-success-subtle">
                                <div class="h-100 d-flex flex-column justify-content-center align-items-center p-4">
                                    <div class="text-center">
                                        <div class="mb-4">
                                            <span class="display-1">📄</span>
                                        </div>
                                        <h2 class="fw-bold text-success">Facturapro</h2>
                                        <p class="text-muted mb-0">Sistema de Facturación Electrónica</p>
                                        <p class="text-muted small">Compatible con DGII República Dominicana</p>
                                    </div>
                                </div>
                            </div>
                            <div class="col-lg-6">
                                <div class="d-flex flex-column h-100">
                                    <div class="auth-brand p-4 text-center">
                                        <span class="fw-bold fs-3 text-success">📄 FACTURAPRO</span>
                                    </div>
                                    <div class="p-4 my-auto">
                                        <h4 class="fs-20">Crear Cuenta</h4>
                                        <p class="text-muted mb-3">Regístrese para acceder al sistema de facturación.</p>

                                        <form asp-action="Register" method="post">
                                            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                                            <div class="row">
                                                <div class="col-md-6 mb-3">
                                                    <label asp-for="Nombre" class="form-label">Nombre</label>
                                                    <input asp-for="Nombre" class="form-control" placeholder="Nombre" />
                                                    <span asp-validation-for="Nombre" class="text-danger small"></span>
                                                </div>

                                                <div class="col-md-6 mb-3">
                                                    <label asp-for="Apellido" class="form-label">Apellido</label>
                                                    <input asp-for="Apellido" class="form-control" placeholder="Apellido" />
                                                    <span asp-validation-for="Apellido" class="text-danger small"></span>
                                                </div>
                                            </div>

                                            <div class="mb-3">
                                                <label asp-for="Email" class="form-label">Correo electrónico</label>
                                                <input asp-for="Email" class="form-control" placeholder="correo@ejemplo.com" />
                                                <span asp-validation-for="Email" class="text-danger small"></span>
                                            </div>

                                            <div class="mb-3">
                                                <label asp-for="Rol" class="form-label">Rol</label>
                                                <select asp-for="Rol" class="form-select">
                                                    <option value="Vendedor">Vendedor</option>
                                                    <option value="Cajero">Cajero</option>
                                                    <option value="Gerente">Gerente</option>
                                                    <option value="Admin">Administrador</option>
                                                </select>
                                                <span asp-validation-for="Rol" class="text-danger small"></span>
                                            </div>

                                            <div class="row">
                                                <div class="col-md-6 mb-3">
                                                    <label asp-for="Password" class="form-label">Contraseña</label>
                                                    <input asp-for="Password" type="password" class="form-control" placeholder="Mínimo 8 caracteres" />
                                                    <span asp-validation-for="Password" class="text-danger small"></span>
                                                </div>

                                                <div class="col-md-6 mb-3">
                                                    <label asp-for="ConfirmPassword" class="form-label">Confirmar Contraseña</label>
                                                    <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="Confirmar contraseña" />
                                                    <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                                                </div>
                                            </div>

                                            <div class="mb-0 text-start">
                                                <button class="btn btn-success w-100" type="submit">
                                                    <i class="ri-user-add-line me-1"></i>
                                                    <span class="fw-bold">Crear Cuenta</span>
                                                </button>
                                            </div>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="row">
                <div class="col-12 text-center">
                    <p class="text-dark-emphasis">
                        ¿Ya tiene cuenta?
                        <a href="@Url.Action("Login", "Account")" class="text-dark fw-bold ms-1 link-offset-3 text-decoration-underline">
                            <b>Inicie sesión aquí</b>
                        </a>
                    </p>
                </div>
            </div>
        </div>
    </div>

    <footer class="footer footer-alt fw-medium">
        <span class="text-dark">
            <script>document.write(new Date().getFullYear())</script> © Facturapro - Sistema de Facturación Electrónica
        </span>
    </footer>

    <!-- Vendor js -->
    <script src="~/velonic/js/vendor.min.js"></script>

    <!-- App js -->
    <script src="~/velonic/js/app.min.js"></script>

    @await Html.PartialAsync("_ValidationScriptsPartial")
</body>
</html>
