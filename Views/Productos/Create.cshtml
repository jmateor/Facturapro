@model Facturapro.Models.Entities.Producto

@{
    ViewData["Title"] = "Nuevo Producto";
}

<!-- Page Header -->
<div class="page-header-title">
    <div class="d-flex align-items-center justify-content-between">
        <div>
            <h4 class="page-title mb-1">
                <i class="ri-box-3-line me-1"></i>
                Nuevo Producto
            </h4>
            <p class="text-muted mb-0">Añade un nuevo producto a tu catálogo</p>
        </div>
        <div class="d-flex gap-2">
            <a href="@Url.Action("Importar")" class="btn btn-soft-info">
                <i class="ri-upload-cloud-line me-1"></i> Importar CSV
            </a>
            <a href="@Url.Action("Index")" class="btn btn-soft-secondary">
                <i class="ri-arrow-left-line me-1"></i> Volver
            </a>
        </div>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="row">
        <div class="col-12">
            <div class="alert alert-success border-0 alert-dismissible fade show" role="alert">
                <i class="ri-checkbox-circle-line me-2"></i>
                @TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        </div>
    </div>
}

@if (ViewData.ModelState.ErrorCount > 0)
{
    <div class="row">
        <div class="col-12">
            <div class="alert alert-danger border-0 alert-dismissible fade show" role="alert">
                <i class="ri-error-warning-line me-2"></i>
                Por favor corrige los errores marcados en el formulario.
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        </div>
    </div>
}

<div class="row">
    <!-- Columna Izquierda - Formulario -->
    <div class="col-xl-8">
        <form asp-action="Create" method="post" id="productoForm" class="dirty-check">
            @Html.AntiForgeryToken()

            <!-- Sección 1: Información Básica -->
            <div class="card">
                <div class="card-body">
                    <div class="d-flex align-items-center mb-4">
                        <div class="avatar-sm bg-primary rounded-3 me-3">
                            <span class="avatar-title text-white fw-bold">1</span>
                        </div>
                        <div>
                            <h5 class="card-title mb-0">Información Básica</h5>
                            <p class="text-muted mb-0 small">Datos de identificación del producto</p>
                        </div>
                    </div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="Codigo" class="form-label">
                                Código <span class="text-danger">*</span>
                            </label>
                            <input asp-for="Codigo" class="form-control" placeholder="Ej: PROD-001" />
                            <span asp-validation-for="Codigo" class="text-danger small"></span>
                            <small class="text-muted d-block mt-1">Código interno único</small>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Nombre" class="form-label">
                                Nombre <span class="text-danger">*</span>
                            </label>
                            <input asp-for="Nombre" class="form-control" placeholder="Nombre del producto" />
                            <span asp-validation-for="Nombre" class="text-danger small"></span>
                            <small class="text-muted d-block mt-1">Nombre comercial del producto</small>
                        </div>

                        <div class="col-12">
                            <label asp-for="Icono" class="form-label">
                                <i class="ri-emotion-line me-1"></i> Ícono Personalizado
                            </label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="ri-remixicon-line"></i></span>
                                <input asp-for="Icono" class="form-control" placeholder="Ej: ri-car-line, ri-t-shirt-line, ri-cup-line" id="iconoInput" />
                                <button type="button" class="btn btn-outline-primary" onclick="abrirSelectorIconos()">
                                    <i class="ri-grid-line me-1"></i> Seleccionar
                                </button>
                            </div>
                            <span asp-validation-for="Icono" class="text-danger small"></span>
                            <small class="text-muted d-block mt-1">
                                Ícono de <a href="https://remixicon.com/" target="_blank">RemixIcon</a>. Deja vacío para usar el ícono predeterminado.
                            </small>
                            <div id="vistaPreviaIcono" class="mt-2" style="display: none;">
                                <div class="d-inline-flex align-items-center gap-2 px-3 py-2 bg-light rounded">
                                    <i id="iconoPreview" class="" style="font-size: 1.5rem;"></i>
                                    <span class="small text-muted" id="nombreIconoPreview"></span>
                                </div>
                            </div>
                        </div>

                        <div class="col-12">
                            <label asp-for="Descripcion" class="form-label">Descripción</label>
                            <textarea asp-for="Descripcion" class="form-control" rows="3" placeholder="Descripción detallada del producto, características, especificaciones..."></textarea>
                            <span asp-validation-for="Descripcion" class="text-danger small"></span>
                            <small class="text-muted d-block mt-1">Opcional pero recomendado para mejor identificación</small>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Sección 2: Tipo de Producto -->
            <div class="card">
                <div class="card-body">
                    <div class="d-flex align-items-center mb-4">
                        <div class="avatar-sm bg-warning rounded-3 me-3">
                            <span class="avatar-title text-white fw-bold">2</span>
                        </div>
                        <div>
                            <h5 class="card-title mb-0">Tipo de Producto</h5>
                            <p class="text-muted mb-0 small">Clasifica el producto según su naturaleza</p>
                        </div>
                    </div>

                    <div class="row g-3">
                        <div class="col-md-4">
                            <input type="radio" class="btn-check" name="TipoProducto" id="tipoArticulo" value="1" checked autocomplete="off">
                            <label class="card h-100 mb-0 border-2 shadow-sm" for="tipoArticulo" style="cursor: pointer; transition: all 0.2s;">
                                <div class="card-body text-center py-4">
                                    <div class="avatar-md bg-soft-primary rounded-circle d-flex align-items-center justify-content-center mx-auto mb-3">
                                        <i class="ri-box-3-line text-primary fs-3"></i>
                                    </div>
                                    <h6 class="mb-1">Artículo</h6>
                                    <small class="text-muted">Producto físico tangible</small>
                                </div>
                            </label>
                        </div>

                        <div class="col-md-4">
                            <input type="radio" class="btn-check" name="TipoProducto" id="tipoServicio" value="2" autocomplete="off">
                            <label class="card h-100 mb-0 border-2 shadow-sm" for="tipoServicio" style="cursor: pointer; transition: all 0.2s;">
                                <div class="card-body text-center py-4">
                                    <div class="avatar-md bg-soft-success rounded-circle d-flex align-items-center justify-content-center mx-auto mb-3">
                                        <i class="ri-customer-service-2-line text-success fs-3"></i>
                                    </div>
                                    <h6 class="mb-1">Servicio</h6>
                                    <small class="text-muted">Servicio intangible</small>
                                </div>
                            </label>
                        </div>

                        <div class="col-md-4">
                            <input type="radio" class="btn-check" name="TipoProducto" id="tipoLibra" value="3" autocomplete="off">
                            <label class="card h-100 mb-0 border-2 shadow-sm" for="tipoLibra" style="cursor: pointer; transition: all 0.2s;">
                                <div class="card-body text-center py-4">
                                    <div class="avatar-md bg-soft-info rounded-circle d-flex align-items-center justify-content-center mx-auto mb-3">
                                        <i class="ri-weight-line text-info fs-3"></i>
                                    </div>
                                    <h6 class="mb-1">Libra / Peso</h6>
                                    <small class="text-muted">Producto a granel</small>
                                </div>
                            </label>
                        </div>
                    </div>

                    <!-- Campos condicionales para Libra -->
                    <div id="camposLibra" style="display: none;" class="mt-3 pt-3 border-top">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label asp-for="PesoPorUnidad" class="form-label">Peso por Unidad (lb)</label>
                                <input asp-for="PesoPorUnidad" type="number" step="0.01" min="0" class="form-control" placeholder="0.00" />
                                <small class="text-muted d-block mt-1">Peso promedio por unidad individual</small>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="UnidadMedida" class="form-label">Unidad de Medida</label>
                                <select asp-for="UnidadMedida" class="form-select">
                                    <option value="Libra">Libra (lb)</option>
                                    <option value="Kilogramo">Kilogramo (kg)</option>
                                    <option value="Onza">Onza (oz)</option>
                                    <option value="Gramo">Gramo (g)</option>
                                </select>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Sección 3: Precios y Ganancia -->
            <div class="card">
                <div class="card-body">
                    <div class="d-flex align-items-center mb-4">
                        <div class="avatar-sm bg-success rounded-3 me-3">
                            <span class="avatar-title text-white fw-bold">3</span>
                        </div>
                        <div>
                            <h5 class="card-title mb-0">Precios y Ganancia</h5>
                            <p class="text-muted mb-0 small">Información comercial y rentabilidad</p>
                        </div>
                    </div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="PrecioCompra" class="form-label">
                                <i class="ri-shopping-cart-2-line me-1"></i> Precio de Compra
                            </label>
                            <div class="input-group">
                                <span class="input-group-text bg-soft-warning text-warning fw-bold">$</span>
                                <input asp-for="PrecioCompra" type="number" step="0.01" min="0" class="form-control" placeholder="0.00" id="precioCompra" />
                            </div>
                            <span asp-validation-for="PrecioCompra" class="text-danger small"></span>
                            <small class="text-muted d-block mt-1">Costo de adquisición del producto</small>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Precio" class="form-label">
                                <i class="ri-money-dollar-circle-line me-1"></i> Precio de Venta <span class="text-danger">*</span>
                            </label>
                            <div class="input-group">
                                <span class="input-group-text bg-soft-primary text-primary fw-bold">$</span>
                                <input asp-for="Precio" type="number" step="0.01" min="0" class="form-control" placeholder="0.00" id="precioVenta" />
                            </div>
                            <span asp-validation-for="Precio" class="text-danger small"></span>
                            <small class="text-muted d-block mt-1">Precio unitario antes de impuestos</small>
                        </div>

                        <!-- Resumen de Ganancia -->
                        <div class="col-12">
                            <div class="card bg-soft-success border-0">
                                <div class="card-body py-3">
                                    <div class="row align-items-center">
                                        <div class="col-md-4">
                                            <small class="text-muted d-block">Ganancia por Unidad</small>
                                            <span class="fs-4 fw-bold text-success" id="gananciaUnidad">$0.00</span>
                                        </div>
                                        <div class="col-md-4">
                                            <small class="text-muted d-block">Margen de Ganancia</small>
                                            <span class="fs-4 fw-bold text-success" id="margenGanancia">0%</span>
                                        </div>
                                        <div class="col-md-4 text-end">
                                            <span class="badge bg-success-soft text-success">
                                                <i class="ri-line-chart-line me-1"></i> Rentabilidad
                                            </span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Sección 4: Stock e Inventario -->
            <div class="card">
                <div class="card-body">
                    <div class="d-flex align-items-center mb-4">
                        <div class="avatar-sm bg-info rounded-3 me-3">
                            <span class="avatar-title text-white fw-bold">4</span>
                        </div>
                        <div>
                            <h5 class="card-title mb-0">Stock e Inventario</h5>
                            <p class="text-muted mb-0 small">Control de existencias y alertas</p>
                        </div>
                    </div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="Stock" class="form-label">
                                Stock Inicial
                            </label>
                            <div class="input-group">
                                <span class="input-group-text bg-soft-info text-info">
                                    <i class="ri-archive-line"></i>
                                </span>
                                <input asp-for="Stock" type="number" min="0" class="form-control" value="0" id="stockInicial" />
                            </div>
                            <span asp-validation-for="Stock" class="text-danger small"></span>
                            <small class="text-muted d-block mt-1">Cantidad disponible en almacén</small>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="StockMinimo" class="form-label">
                                Stock Mínimo de Alerta
                            </label>
                            <div class="input-group">
                                <span class="input-group-text bg-soft-warning text-warning">
                                    <i class="ri-alert-line"></i>
                                </span>
                                <input asp-for="StockMinimo" type="number" min="0" class="form-control" value="5" />
                            </div>
                            <span asp-validation-for="StockMinimo" class="text-danger small"></span>
                            <small class="text-muted d-block mt-1">Nivel para activar alerta de reorden</small>
                        </div>

                        <div class="col-md-6">
                            <div class="form-check form-switch form-switch-lg">
                                <input asp-for="ControlaStock" class="form-check-input" type="checkbox" checked id="controlaStock">
                                <label class="form-check-label" for="controlaStock">
                                    <strong>Controlar Stock</strong>
                                </label>
                            </div>
                            <small class="text-muted d-block mt-1">Desactivar para servicios o productos digitales</small>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Ubicacion" class="form-label">
                                <i class="ri-map-pin-2-line me-1"></i> Ubicación en Almacén
                            </label>
                            <input asp-for="Ubicacion" class="form-control" placeholder="Ej: Pasillo A, Estante 3" />
                            <span asp-validation-for="Ubicacion" class="text-danger small"></span>
                            <small class="text-muted d-block mt-1">Ubicación física para fácil localización</small>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Sección 5: Clasificación y Proveedor -->
            <div class="card">
                <div class="card-body">
                    <div class="d-flex align-items-center mb-4">
                        <div class="avatar-sm bg-purple rounded-3 me-3">
                            <span class="avatar-title text-white fw-bold">5</span>
                        </div>
                        <div>
                            <h5 class="card-title mb-0">Clasificación y Proveedor</h5>
                            <p class="text-muted mb-0 small">Categorización y proveedor principal</p>
                        </div>
                    </div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="CategoriaId" class="form-label">Categoría</label>
                            <select asp-for="CategoriaId" class="form-select" asp-items="ViewBag.CategoriaId">
                                <option value="">-- Sin categoría --</option>
                            </select>
                            <span asp-validation-for="CategoriaId" class="text-danger small"></span>
                            <small class="text-muted d-block mt-1">
                                <i class="ri-information-line me-1"></i>
                                <a href="@Url.Action("Index", "Categorias")" target="_blank" class="text-decoration-none">Ver categorías</a>
                            </small>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="ProveedorId" class="form-label">Proveedor Principal</label>
                            <select asp-for="ProveedorId" class="form-select" asp-items="ViewBag.ProveedorId">
                                <option value="">-- Sin proveedor --</option>
                            </select>
                            <span asp-validation-for="ProveedorId" class="text-danger small"></span>
                            <small class="text-muted d-block mt-1">
                                <i class="ri-information-line me-1"></i>
                                <a href="@Url.Action("Index", "Proveedores")" target="_blank" class="text-decoration-none">Ver proveedores</a>
                            </small>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Sección 6: Lote y Vencimiento -->
            <div class="card">
                <div class="card-body">
                    <div class="d-flex align-items-center mb-4">
                        <div class="avatar-sm bg-danger rounded-3 me-3">
                            <span class="avatar-title text-white fw-bold">6</span>
                        </div>
                        <div>
                            <h5 class="card-title mb-0">Lote y Vencimiento</h5>
                            <p class="text-muted mb-0 small">Control de caducidad y trazabilidad</p>
                        </div>
                    </div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="NumeroLote" class="form-label">Número de Lote</label>
                            <input asp-for="NumeroLote" class="form-control" placeholder="Ej: LOT-2026-001" />
                            <span asp-validation-for="NumeroLote" class="text-danger small"></span>
                            <small class="text-muted d-block mt-1">Útil para productos perecederos o con garantía</small>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="FechaVencimiento" class="form-label">Fecha de Vencimiento</label>
                            <input asp-for="FechaVencimiento" type="date" class="form-control" />
                            <span asp-validation-for="FechaVencimiento" class="text-danger small"></span>
                            <small class="text-muted d-block mt-1">El sistema alertará antes del vencimiento</small>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Sección 7: Código de Barras -->
            <div class="card">
                <div class="card-body">
                    <div class="d-flex align-items-center mb-4">
                        <div class="avatar-sm bg-dark rounded-3 me-3">
                            <span class="avatar-title text-white fw-bold">7</span>
                        </div>
                        <div>
                            <h5 class="card-title mb-0">Código de Barras</h5>
                            <p class="text-muted mb-0 small">Identificación universal del producto</p>
                        </div>
                    </div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="CodigoBarras" class="form-label">Código de Barras</label>
                            <input asp-for="CodigoBarras" class="form-control" placeholder="Escanear o ingresar código" />
                            <span asp-validation-for="CodigoBarras" class="text-danger small"></span>
                            <small class="text-muted d-block mt-1">
                                <i class="ri-barcode-line me-1"></i>
                                Se genera automáticamente si está vacío
                            </small>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Vista Previa</label>
                            <div class="border rounded p-3 bg-light text-center" id="barcodePreview">
                                <small class="text-muted">El código de barras se mostrará aquí</small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Botones de Acción -->
            <div class="d-flex gap-2 justify-content-end mt-4">
                <button type="button" class="btn btn-light" onclick="history.back()">
                    <i class="ri-arrow-left-line me-1"></i> Cancelar
                </button>
                <button type="submit" class="btn btn-primary">
                    <i class="ri-save-line me-1"></i> Guardar Producto
                </button>
            </div>
        </form>
    </div>

    <!-- Columna Derecha - Ayuda y Resumen -->
    <div class="col-xl-4">
        <!-- Campos Requeridos -->
        <div class="card">
            <div class="card-body">
                <h6 class="card-title mb-3">
                    <i class="ri-list-check me-1 text-primary"></i>
                    Campos Requeridos
                </h6>
                <ul class="list-group list-group-flush small">
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                        <span><i class="ri-barcode-box-line me-2"></i>Código</span>
                        <span class="badge bg-danger-soft text-danger">Obligatorio</span>
                    </li>
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                        <span><i class="ri-price-tag-line me-2"></i>Nombre</span>
                        <span class="badge bg-danger-soft text-danger">Obligatorio</span>
                    </li>
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                        <span><i class="ri-money-dollar-circle-line me-2"></i>Precio</span>
                        <span class="badge bg-danger-soft text-danger">Obligatorio</span>
                    </li>
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                        <span><i class="ri-archive-line me-2"></i>Stock</span>
                        <span class="badge bg-warning-soft text-warning">Opcional</span>
                    </li>
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                        <span><i class="ri-price-tag-3-line me-2"></i>Categoría</span>
                        <span class="badge bg-warning-soft text-warning">Opcional</span>
                    </li>
                </ul>
            </div>
        </div>

        <!-- Información Importante -->
        <div class="card bg-soft-primary border-0">
            <div class="card-body">
                <h6 class="card-title text-primary mb-2">
                    <i class="ri-information-line me-1"></i>
                    Información Importante
                </h6>
                <p class="small text-muted mb-2">
                    El código del producto debe ser único en todo el sistema. No se puede repetir.
                </p>
                <ul class="small text-muted mb-0" style="padding-left: 1.2rem;">
                    <li>Usa un patrón consistente (Ej: PROD-001)</li>
                    <li>El precio no incluye ITBIS automáticamente</li>
                    <li>El stock puede ser cero para servicios</li>
                </ul>
            </div>
        </div>

        <!-- Código de Barras -->
        <div class="card bg-soft-success border-0">
            <div class="card-body">
                <h6 class="card-title text-success mb-2">
                    <i class="ri-barcode-line me-1"></i>
                    Código de Barras
                </h6>
                <p class="small text-muted mb-2">
                    Al guardar el producto, se generará automáticamente un código de barras basado en el código interno.
                </p>
                <div class="alert alert-success-soft mb-0 small">
                    <i class="ri-checkbox-circle-line me-1"></i>
                    Generación automática al crear
                </div>
            </div>
        </div>

        <!-- Atajo de Importación -->
        <div class="card border-0">
            <div class="card-body text-center p-4">
                <div class="avatar-lg bg-info-soft rounded-circle mb-2 mx-auto d-flex align-items-center justify-content-center" style="width: 64px; height: 64px;">
                    <i class="ri-upload-cloud-2-line display-4 text-info"></i>
                </div>
                <h6 class="fw-semibold mb-1">Importar Múltiples</h6>
                <p class="small text-muted mb-2">
                    ¿Necesitas cargar muchos productos? Usa la importación CSV.
                </p>
                <a href="@Url.Action("Importar")" class="btn btn-info">
                    <i class="ri-file-text-line me-1"></i> Importar desde CSV
                </a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // ========================================
        // CÁLCULO DE GANANCIA EN TIEMPO REAL
        // ========================================
        function calcularGanancia() {
            const precioCompra = parseFloat(document.getElementById('precioCompra')?.value) || 0;
            const precioVenta = parseFloat(document.getElementById('precioVenta')?.value) || 0;

            const ganancia = precioVenta - precioCompra;
            const margen = precioVenta > 0 ? (ganancia / precioVenta) * 100 : 0;

            document.getElementById('gananciaUnidad').textContent = '$' + ganancia.toFixed(2);
            document.getElementById('margenGanancia').textContent = margen.toFixed(1) + '%';

            // Cambiar color según rentabilidad
            const gananciaElement = document.getElementById('gananciaUnidad');
            const margenElement = document.getElementById('margenGanancia');

            if (ganancia < 0) {
                gananciaElement.className = 'fs-4 fw-bold text-danger';
                margenElement.className = 'fs-4 fw-bold text-danger';
            } else if (ganancia === 0) {
                gananciaElement.className = 'fs-4 fw-bold text-warning';
                margenElement.className = 'fs-4 fw-bold text-warning';
            } else {
                gananciaElement.className = 'fs-4 fw-bold text-success';
                margenElement.className = 'fs-4 fw-bold text-success';
            }
        }

        document.getElementById('precioCompra')?.addEventListener('input', calcularGanancia);
        document.getElementById('precioVenta')?.addEventListener('input', calcularGanancia);

        // ========================================
        // MANEJO DE TIPO DE PRODUCTO
        // ========================================
        document.querySelectorAll('input[name="TipoProducto"]').forEach(radio => {
            radio.addEventListener('change', function() {
                const camposLibra = document.getElementById('camposLibra');
                const controlaStockCheckbox = document.getElementById('controlaStock');
                const stockInput = document.getElementById('stockInicial');

                if (this.value === '3') { // Libra / Peso
                    camposLibra.style.display = 'block';
                } else {
                    camposLibra.style.display = 'none';
                }

                if (this.value === '2') { // Servicio
                    controlaStockCheckbox.checked = false;
                    stockInput.value = '0';
                    stockInput.disabled = true;
                } else {
                    controlaStockCheckbox.checked = true;
                    stockInput.disabled = false;
                }
            });
        });

        // ========================================
        // VISTA PREVIA DE CÓDIGO DE BARRAS
        // ========================================
        document.querySelector('input[name="CodigoBarras"]')?.addEventListener('input', function(e) {
            const codigo = e.target.value.trim();
            const preview = document.getElementById('barcodePreview');

            if (codigo) {
                // Simular código de barras con caracteres
                const barras = codigo.split('').map(c => {
                    const width = (c.charCodeAt(0) % 3) + 1;
                    return '<div class="d-inline-block bg-dark" style="width: ' + width + 'px; height: 30px; margin-right: 1px;"></div>';
                }).join('');

                preview.innerHTML = `
                    <div class="d-flex justify-content-center align-items-end gap-1">
                        ${barras}
                    </div>
                    <small class="d-block mt-2 text-muted">${codigo}</small>
                `;
            } else {
                preview.innerHTML = '<small class="text-muted">El código de barras se mostrará aquí</small>';
            }
        });

        // ========================================
        // VALIDACIONES EXISTENTES
        // ========================================

        // Validación de Precio - Solo números con decimales
        document.querySelector('input[name="Precio"]').addEventListener('input', function(e) {
            let value = this.value.replace(/[^0-9.]/g, '');
            const parts = value.split('.');
            if (parts.length > 1 && parts[1].length > 2) {
                value = parts[0] + '.' + parts[1].substring(0, 2);
            }
            this.value = value;
        });

        // Validación de Stock - Solo números enteros
        document.querySelector('input[name="Stock"]').addEventListener('input', function(e) {
            this.value = this.value.replace(/[^0-9]/g, '');
            if (parseInt(this.value) < 0) {
                this.value = '0';
            }
        });

        // Validación de Código - Convertir a mayúsculas
        document.querySelector('input[name="Codigo"]').addEventListener('input', function(e) {
            this.value = this.value.toUpperCase().replace(/[^A-Z0-9\-_]/g, '');
        });

        // Auto-formateo de precio al perder foco
        document.querySelector('input[name="Precio"]').addEventListener('blur', function() {
            if (this.value) {
                const valor = parseFloat(this.value);
                if (!isNaN(valor)) {
                    this.value = valor.toFixed(2);
                }
            }
        });

        // ========================================
        // ESTILOS DINÁMICOS PARA TARJETAS DE TIPO
        // ========================================
        document.querySelectorAll('input[name="TipoProducto"]').forEach(radio => {
            radio.addEventListener('change', function() {
                document.querySelectorAll('.btn-check + .card').forEach(card => {
                    card.classList.remove('border-primary', 'border-success', 'border-info');
                    card.classList.add('border-2');
                });

                const card = this.nextElementSibling;
                if (this.value === '1') {
                    card.classList.add('border-primary');
                } else if (this.value === '2') {
                    card.classList.add('border-success');
                } else if (this.value === '3') {
                    card.classList.add('border-info');
                }
            });
        });

        // Trigger inicial para marcar la tarjeta seleccionada
        document.querySelector('input[name="TipoProducto"]:checked')?.dispatchEvent(new Event('change'));

        // ========================================
        // SELECTOR DE ÍCONOS
        // ========================================
        function abrirSelectorIconos() {
            const modal = new bootstrap.Modal(document.getElementById('modalSelectorIconos'));
            modal.show();
        }

        function seleccionarIcono(nombreIcono) {
            document.getElementById('iconoInput').value = nombreIcono;
            mostrarVistaPrevia(nombreIcono);
            bootstrap.Modal.getInstance(document.getElementById('modalSelectorIconos')).hide();
        }

        function mostrarVistaPrevia(nombreIcono) {
            const vistaPrevia = document.getElementById('vistaPreviaIcono');
            const iconoPreview = document.getElementById('iconoPreview');
            const nombreIconoPreview = document.getElementById('nombreIconoPreview');

            if (nombreIcono.trim()) {
                iconoPreview.className = nombreIcono;
                nombreIconoPreview.textContent = nombreIcono;
                vistaPrevia.style.display = 'inline-flex';
            } else {
                vistaPrevia.style.display = 'none';
            }
        }

        // Vista previa al escribir
        document.getElementById('iconoInput')?.addEventListener('input', function(e) {
            mostrarVistaPrevia(e.target.value);
        });

        // Búsqueda en tiempo real
        document.getElementById('buscadorIconos')?.addEventListener('input', function(e) {
            const termino = e.target.value.toLowerCase();
            document.querySelectorAll('.icono-item').forEach(item => {
                const nombre = item.dataset.icono.toLowerCase();
                const categoria = item.dataset.categoria.toLowerCase();
                item.style.display = (nombre.includes(termino) || categoria.includes(termino)) ? 'block' : 'none';
            });
        });
    </script>
}

