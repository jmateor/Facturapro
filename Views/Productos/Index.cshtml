@model IEnumerable<Facturapro.Models.Entities.Producto>

@{
    ViewData["Title"] = "Productos";
    var cultura = new System.Globalization.CultureInfo("es-DO");
    var categorias = ViewData["Categorias"] as List<Categoria> ?? new List<Categoria>();
}

<!-- Page Header -->
<div class="page-header-title">
    <div class="d-flex align-items-center justify-content-between">
        <div>
            <h4 class="page-title mb-1">
                <i class="ri-box-3-line me-1"></i>
                Productos
            </h4>
            <p class="text-muted mb-0">Gestiona tu catálogo de productos y servicios</p>
        </div>
        <div class="d-flex gap-2">
            <div class="btn-group" role="group">
                <a href="@Url.Action("Importar")" class="btn btn-soft-info" title="Importar desde CSV">
                    <i class="ri-upload-cloud-line"></i>
                </a>
                <a href="@Url.Action("Exportar")" class="btn btn-soft-info" title="Exportar a CSV">
                    <i class="ri-download-cloud-line"></i>
                </a>
            </div>
            <a href="@Url.Action("Create")" class="btn btn-primary">
                <i class="ri-add-line me-1"></i> Nuevo Producto
            </a>
        </div>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="row">
        <div class="col-12">
            <div class="alert alert-success border-0 alert-dismissible fade show" role="alert">
                <i class="ri-checkbox-circle-line me-2"></i>
                @TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        </div>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="row">
        <div class="col-12">
            <div class="alert alert-danger border-0 alert-dismissible fade show" role="alert">
                <i class="ri-error-warning-line me-2"></i>
                @TempData["ErrorMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        </div>
    </div>
}

<!-- Filtros y Búsqueda -->
<div class="card mb-3">
    <div class="card-body">
        <form method="get" class="row g-2 align-items-center">
            <div class="col-md-5">
                <div class="position-relative">
                    <input type="text" name="buscar" class="form-control" placeholder="Buscar por nombre, código o descripción..." value="@Context.Request.Query["buscar"]" />
                    <i class="ri-search-line position-absolute top-50 end-0 translate-middle-y me-3 text-muted"></i>
                </div>
            </div>
            <div class="col-md-4">
                <select name="categoriaId" class="form-select">
                    <option value="">Todas las categorías</option>
                    @foreach (var cat in categorias)
                    {
                        if (Context.Request.Query["categoriaId"] == cat.Id.ToString())
                        {
                            <option value="@cat.Id" selected>@cat.Nombre</option>
                        }
                        else
                        {
                            <option value="@cat.Id">@cat.Nombre</option>
                        }
                    }
                </select>
            </div>
            <div class="col-md-3">
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary flex-grow-1">
                        <i class="ri-filter-search-line me-1"></i> Filtrar
                    </button>
                    <a href="@Url.Action("Index")" class="btn btn-soft-secondary" title="Limpiar filtros">
                        <i class="ri-close-line"></i>
                    </a>
                </div>
            </div>
        </form>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <!-- Resumen de Productos -->
        <div class="row g-3 mb-3">
            <div class="col-md-3">
                <div class="p-3 bg-soft-primary rounded-3">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <p class="text-muted mb-0 small">Total Productos</p>
                            <h4 class="mb-0 fw-bold">@Model.Count()</h4>
                        </div>
                        <div class="avatar-md bg-primary text-white rounded-circle d-flex align-items-center justify-content-center">
                            <i class="ri-box-3-line fs-4"></i>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="p-3 bg-soft-success rounded-3">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <p class="text-muted mb-0 small">Activos</p>
                            <h4 class="mb-0 fw-bold">@Model.Count(p => p.Activo)</h4>
                        </div>
                        <div class="avatar-md bg-success text-white rounded-circle d-flex align-items-center justify-content-center">
                            <i class="ri-checkbox-circle-line fs-4"></i>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="p-3 bg-soft-danger rounded-3">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <p class="text-muted mb-0 small">Stock Bajo</p>
                            <h4 class="mb-0 fw-bold">@Model.Count(p => p.Stock <= 5 && p.Activo)</h4>
                        </div>
                        <div class="avatar-md bg-danger text-white rounded-circle d-flex align-items-center justify-content-center">
                            <i class="ri-alarm-warning-line fs-4"></i>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="p-3 bg-soft-warning rounded-3">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <p class="text-muted mb-0 small">Inactivos</p>
                            <h4 class="mb-0 fw-bold">@Model.Count(p => !p.Activo)</h4>
                        </div>
                        <div class="avatar-md bg-warning text-white rounded-circle d-flex align-items-center justify-content-center">
                            <i class="ri-stop-circle-line fs-4"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="table-responsive-sm">
            <table class="table table-hover table-centered mb-0" id="tablaProductos">
                <thead class="table-light">
                    <tr>
                        <th style="width: 15%;">Código</th>
                        <th style="width: 30%;">Producto</th>
                        <th style="width: 15%;">Categoría</th>
                        <th style="width: 12%;" class="text-end">Precio</th>
                        <th style="width: 10%;" class="text-center">Stock</th>
                        <th style="width: 8%;" class="text-center">Estado</th>
                        <th style="width: 10%;" class="text-end">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr class="producto-row" data-codigo="@item.Codigo.ToLower()" data-nombre="@item.Nombre.ToLower()" data-categoria="@item.Categoria?.Nombre.ToLower()">
                            <td>
                                <span class="badge bg-light text-dark fw-normal">@item.Codigo</span>
                            </td>
                            <td>
                                <div class="d-flex align-items-center">
                                    <div class="flex-shrink-0">
                                        <div class="avatar-sm rounded-circle bg-primary text-white d-flex align-items-center justify-content-center" style="width: 42px; height: 42px;">
                                            <i class="ri-box-3-line"></i>
                                        </div>
                                    </div>
                                    <div class="flex-grow-1 ms-3">
                                        <h6 class="mb-0 fw-semibold">@item.Nombre</h6>
                                        @if (!string.IsNullOrEmpty(item.Descripcion))
                                        {
                                            <small class="text-muted">@item.Descripcion.Substring(0, Math.Min(50, item.Descripcion.Length))...</small>
                                        }
                                    </div>
                                </div>
                            </td>
                            <td>
                                @if (item.Categoria != null)
                                {
                                    <span class="badge bg-info-subtle text-info-emphasis border border-info-subtle">@item.Categoria.Nombre</span>
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                            <td class="text-end">
                                <span class="fw-bold text-success">@item.Precio.ToString("C", cultura)</span>
                            </td>
                            <td class="text-center">
                                @if (item.Stock <= 5)
                                {
                                    <span class="badge bg-danger-subtle text-danger-emphasis border border-danger-subtle">
                                        @item.Stock <i class="ri-alarm-warning-line ms-1"></i>
                                    </span>
                                }
                                else if (item.Stock <= 15)
                                {
                                    <span class="badge bg-warning-subtle text-warning-emphasis border border-warning-subtle">
                                        @item.Stock
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-success-subtle text-success-emphasis border border-success-subtle">
                                        @item.Stock
                                    </span>
                                }
                            </td>
                            <td class="text-center">
                                @if (item.Activo)
                                {
                                    <span class="badge bg-success-soft text-success">
                                        <i class="ri-checkbox-circle-fill me-1"></i>Activo
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary-soft text-secondary">
                                        <i class="ri-stop-circle-fill me-1"></i>Inactivo
                                    </span>
                                }
                            </td>
                            <td class="text-end">
                                <div class="btn-group" role="group">
                                    <a href="@Url.Action("Details", new { id = item.Id })" class="btn btn-sm btn-soft-info" title="Ver detalles">
                                        <i class="ri-eye-line"></i>
                                    </a>
                                    <a href="@Url.Action("Edit", new { id = item.Id })" class="btn btn-sm btn-soft-primary" title="Editar">
                                        <i class="ri-edit-line"></i>
                                    </a>
                                    <a href="@Url.Action("Delete", new { id = item.Id })" class="btn btn-sm btn-soft-danger" title="Eliminar" onclick="return confirm('¿Está seguro de eliminar este producto?')">
                                        <i class="ri-delete-bin-line"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (!Model.Any())
        {
            <div class="text-center py-5">
                <div class="avatar-lg bg-soft-primary rounded-circle mb-3 mx-auto d-inline-flex" style="width: 100px; height: 100px;">
                    <i class="ri-box-3-line display-4 text-primary"></i>
                </div>
                <h5 class="fw-semibold">No hay productos registrados</h5>
                <p class="text-muted mb-3">Comienza agregando tu primer producto al catálogo</p>
                <div class="d-flex gap-2 justify-content-center">
                    <a href="@Url.Action("Create")" class="btn btn-primary">
                        <i class="ri-add-line me-1"></i> Crear primer producto
                    </a>
                    <a href="@Url.Action("Importar")" class="btn btn-soft-info">
                        <i class="ri-upload-cloud-line me-1"></i> Importar CSV
                    </a>
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        // Búsqueda en tiempo real
        document.querySelector('input[name="buscar"]').addEventListener('input', function() {
            const filtro = this.value.toLowerCase();
            const filas = document.querySelectorAll('.producto-row');

            filas.forEach(function(fila) {
                const codigo = fila.getAttribute('data-codigo');
                const nombre = fila.getAttribute('data-nombre');
                const categoria = fila.getAttribute('data-categoria');

                if (codigo?.includes(filtro) || nombre?.includes(filtro) || categoria?.includes(filtro)) {
                    fila.style.display = '';
                } else {
                    fila.style.display = 'none';
                }
            });
        });

        // Confirmar eliminación
        document.querySelectorAll('.btn-soft-danger').forEach(function(btn) {
            btn.addEventListener('click', function(e) {
                if (!confirm('¿Está seguro de eliminar este producto? Esta acción no se puede deshacer.')) {
                    e.preventDefault();
                }
            });
        });
    </script>
}
