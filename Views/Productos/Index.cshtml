@model IEnumerable<Facturapro.Models.Entities.Producto>

@{
    ViewData["Title"] = "Productos";
    var cultura = new System.Globalization.CultureInfo("es-DO");
    var categorias = ViewData["Categorias"] as List<Categoria> ?? new List<Categoria>();
}

<!-- Page Header -->
<div class="page-header-title">
    <div class="d-flex align-items-center justify-content-between">
        <div>
            <h4 class="page-title mb-1">
                <i class="ri-box-3-line me-1"></i>
                Productos
            </h4>
            <p class="text-muted mb-0">Gestiona tu catálogo de productos y servicios</p>
        </div>
        <div class="d-flex gap-2">
            <div class="btn-group" role="group">
                <a href="@Url.Action("Importar")" class="btn btn-soft-info" title="Importar desde Excel">
                    <i class="ri-upload-cloud-line"></i>
                </a>
                <a href="@Url.Action("Exportar")" class="btn btn-soft-info" title="Exportar a Excel">
                    <i class="ri-download-cloud-line"></i>
                </a>
            </div>
            <a href="@Url.Action("Create")" class="btn btn-primary">
                <i class="ri-add-line me-1"></i> Nuevo Producto
            </a>
        </div>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="row">
        <div class="col-12">
            <div class="alert alert-success border-0 alert-dismissible fade show" role="alert">
                <i class="ri-checkbox-circle-line me-2"></i>
                @TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        </div>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="row">
        <div class="col-12">
            <div class="alert alert-danger border-0 alert-dismissible fade show" role="alert">
                <i class="ri-error-warning-line me-2"></i>
                @TempData["ErrorMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        </div>
    </div>
}

<!-- Filtros y Búsqueda -->
<div class="card mb-3">
    <div class="card-body">
        <form method="get" class="row g-2 align-items-center">
            <div class="col-md-5">
                <div class="position-relative">
                    <input type="text" name="buscar" class="form-control" placeholder="Buscar por nombre, código o descripción..." value="@Context.Request.Query["buscar"]" />
                    <i class="ri-search-line position-absolute top-50 end-0 translate-middle-y me-3 text-muted"></i>
                </div>
            </div>
            <div class="col-md-4">
                <select name="categoriaId" class="form-select">
                    <option value="">Todas las categorías</option>
                    @foreach (var cat in categorias)
                    {
                        if (Context.Request.Query["categoriaId"] == cat.Id.ToString())
                        {
                            <option value="@cat.Id" selected>@cat.Nombre</option>
                        }
                        else
                        {
                            <option value="@cat.Id">@cat.Nombre</option>
                        }
                    }
                </select>
            </div>
            <div class="col-md-3">
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary flex-grow-1">
                        <i class="ri-filter-search-line me-1"></i> Filtrar
                    </button>
                    <a href="@Url.Action("Index")" class="btn btn-soft-secondary" title="Limpiar filtros">
                        <i class="ri-close-line"></i>
                    </a>
                </div>
            </div>
        </form>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <!-- Resumen de Productos -->
        <div class="row g-3 mb-3">
            <div class="col-md-3">
                <div class="p-3 bg-soft-primary rounded-3">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <p class="text-muted mb-0 small">Total Productos</p>
                            <h4 class="mb-0 fw-bold">@Model.Count()</h4>
                        </div>
                        <div class="avatar-md bg-primary text-white rounded-circle d-flex align-items-center justify-content-center">
                            <i class="ri-box-3-line fs-4"></i>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="p-3 bg-soft-success rounded-3">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <p class="text-muted mb-0 small">Activos</p>
                            <h4 class="mb-0 fw-bold">@Model.Count(p => p.Activo)</h4>
                        </div>
                        <div class="avatar-md bg-success text-white rounded-circle d-flex align-items-center justify-content-center">
                            <i class="ri-checkbox-circle-line fs-4"></i>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="p-3 bg-soft-danger rounded-3">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <p class="text-muted mb-0 small">Stock Bajo</p>
                            <h4 class="mb-0 fw-bold">@Model.Count(p => p.Stock <= 5 && p.Activo)</h4>
                        </div>
                        <div class="avatar-md bg-danger text-white rounded-circle d-flex align-items-center justify-content-center">
                            <i class="ri-alarm-warning-line fs-4"></i>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="p-3 bg-soft-warning rounded-3">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <p class="text-muted mb-0 small">Inactivos</p>
                            <h4 class="mb-0 fw-bold">@Model.Count(p => !p.Activo)</h4>
                        </div>
                        <div class="avatar-md bg-warning text-white rounded-circle d-flex align-items-center justify-content-center">
                            <i class="ri-stop-circle-line fs-4"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="table-responsive-sm">
            <table class="table table-hover table-centered mb-0" id="tablaProductos">
                <thead class="table-light">
                    <tr>
                        <th style="width: 15%;">Código</th>
                        <th style="width: 30%;">Producto</th>
                        <th style="width: 15%;">Categoría</th>
                        <th style="width: 12%;" class="text-end">Precio</th>
                        <th style="width: 10%;" class="text-center">Stock</th>
                        <th style="width: 8%;" class="text-center">Estado</th>
                        <th style="width: 10%;" class="text-end">Acciones</th>
                    </tr>
                </thead>
                <tbody id="tablaProductosBody">
                    <!-- Dinámico vía AJAX -->
                </tbody>
            </table>
        </div>

        <div id="noResults" style="display: none;">
            <div class="text-center py-5">
                <i class="ri-search-line display-4 text-muted"></i>
                <h5 class="fw-semibold mt-3">No se encontraron productos</h5>
                <p class="text-muted">Prueba con otros filtros o términos de búsqueda</p>
            </div>
        </div>

        <!-- Pagination Controls -->
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-center mt-3 gap-3">
            <div class="text-muted small">
                Mostrando <span id="spanStart">0</span> a <span id="spanEnd">0</span> de <span id="spanTotal">0</span> productos
            </div>
            <nav aria-label="Navegación de productos">
                <ul class="pagination pagination-rounded mb-0" id="paginationContainer">
                    <!-- Dinámico -->
                </ul>
            </nav>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let currentPage = 1;
        const pageSize = 10;
        const cultura = 'es-DO';

        document.addEventListener('DOMContentLoaded', function() {
            cargarProductos();
        });

        // Búsqueda en tiempo real (con debounce)
        let searchTimeout;
        document.querySelector('input[name="buscar"]').addEventListener('input', function() {
            clearTimeout(searchTimeout);
            searchTimeout = setTimeout(() => {
                currentPage = 1;
                cargarProductos();
            }, 300);
        });

        // Cambio de categoría
        document.querySelector('select[name="categoriaId"]').addEventListener('change', function() {
            currentPage = 1;
            cargarProductos();
        });

        // Prevenir el submit normal del form
        document.querySelector('form').addEventListener('submit', function(e) {
            e.preventDefault();
            currentPage = 1;
            cargarProductos();
        });

        function cargarProductos(page = 1) {
            currentPage = page;
            const buscar = document.querySelector('input[name="buscar"]').value;
            const categoriaId = document.querySelector('select[name="categoriaId"]').value;
            const body = document.getElementById('tablaProductosBody');
            const noResults = document.getElementById('noResults');

            window.Skeleton.show('#tablaProductosBody', 'tableRow', 8);

            fetch(`/Productos/GetProductosJson?categoriaId=${categoriaId}&buscar=${buscar}&page=${currentPage}&pageSize=${pageSize}`)
                .then(r => r.json())
                .then(data => {
                    const productos = data.items;
                    if (productos.length === 0) {
                        body.innerHTML = '';
                        noResults.style.display = 'block';
                        updatePaginationInfo(0, 0, 0);
                        renderPagination(0);
                        return;
                    }

                    noResults.style.display = 'none';
                    const html = productos.map(item => {
                        const stockBadgeClass = getStockBadgeClass(item.stock);
                        const statusBadgeClass = item.activo ? 'bg-success-soft text-success' : 'bg-secondary-soft text-secondary';
                        const statusText = item.activo ? 'Activo' : 'Inactivo';
                        const statusIcon = item.activo ? 'ri-checkbox-circle-fill' : 'ri-stop-circle-fill';

                        return `
                            <tr>
                                <td><span class="badge bg-light text-dark fw-normal">${item.codigo}</span></td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="flex-shrink-0">
                                            <div class="avatar-sm rounded-circle bg-primary text-white d-flex align-items-center justify-content-center" style="width: 42px; height: 42px;">
                                                <i class="ri-box-3-line"></i>
                                            </div>
                                        </div>
                                        <div class="flex-grow-1 ms-3">
                                            <h6 class="mb-0 fw-semibold">${item.nombre}</h6>
                                            <small class="text-muted">${item.descripcion ? (item.descripcion.length > 50 ? item.descripcion.substring(0, 50) + '...' : item.descripcion) : ''}</small>
                                        </div>
                                    </div>
                                </td>
                                <td><span class="badge bg-info-subtle text-info-emphasis border border-info-subtle">${item.categoriaNombre}</span></td>
                                <td class="text-end"><span class="fw-bold text-success">${new Intl.NumberFormat(cultura, { style: 'currency', currency: 'DOP' }).format(item.precio)}</span></td>
                                <td class="text-center"><span class="badge ${stockBadgeClass}">${item.stock}</span></td>
                                <td class="text-center">
                                    <span class="badge ${statusBadgeClass}">
                                        <i class="${statusIcon} me-1"></i>${statusText}
                                    </span>
                                </td>
                                <td class="text-end">
                                    <div class="btn-group" role="group">
                                        <a href="/Productos/Details/${item.id}" class="btn btn-sm btn-soft-info" title="Ver detalles"><i class="ri-eye-line"></i></a>
                                        <a href="/Productos/Edit/${item.id}" class="btn btn-sm btn-soft-primary" title="Editar"><i class="ri-edit-line"></i></a>
                                        <a href="/Productos/Delete/${item.id}" class="btn btn-sm btn-soft-danger" title="Eliminar"><i class="ri-delete-bin-line"></i></a>
                                    </div>
                                </td>
                            </tr>
                        `;
                    }).join('');

                    window.Skeleton.hide('#tablaProductosBody', html);
                    
                    const start = ((currentPage - 1) * pageSize) + 1;
                    const end = Math.min(currentPage * pageSize, data.totalItems);
                    updatePaginationInfo(start, end, data.totalItems);
                    renderPagination(data.totalPages);
                });
        }

        function getStockBadgeClass(stock) {
            if (stock <= 5) return 'bg-danger-subtle text-danger-emphasis border border-danger-subtle';
            if (stock <= 15) return 'bg-warning-subtle text-warning-emphasis border border-warning-subtle';
            return 'bg-success-subtle text-success-emphasis border border-success-subtle';
        }

        function updatePaginationInfo(start, end, total) {
            document.getElementById('spanStart').textContent = start;
            document.getElementById('spanEnd').textContent = end;
            document.getElementById('spanTotal').textContent = total;
        }

        function renderPagination(totalPages) {
            const container = document.getElementById('paginationContainer');
            container.innerHTML = '';

            if (totalPages <= 1) return;

            container.innerHTML += `
                <li class="page-item ${currentPage === 1 ? 'disabled' : ''}">
                    <a class="page-link" href="javascript:void(0)" onclick="cargarProductos(${currentPage - 1})">
                        <i class="ri-arrow-left-s-line"></i>
                    </a>
                </li>
            `;

            for (let i = 1; i <= totalPages; i++) {
                if (i === 1 || i === totalPages || (i >= currentPage - 2 && i <= currentPage + 2)) {
                    container.innerHTML += `
                        <li class="page-item ${i === currentPage ? 'active' : ''}">
                            <a class="page-link" href="javascript:void(0)" onclick="cargarProductos(${i})">${i}</a>
                        </li>
                    `;
                } else if (i === currentPage - 3 || i === currentPage + 3) {
                    container.innerHTML += `<li class="page-item disabled"><span class="page-link">...</span></li>`;
                }
            }

            container.innerHTML += `
                <li class="page-item ${currentPage === totalPages ? 'disabled' : ''}">
                    <a class="page-link" href="javascript:void(0)" onclick="cargarProductos(${currentPage + 1})">
                        <i class="ri-arrow-right-s-line"></i>
                    </a>
                </li>
            `;
        }
    </script>
}
