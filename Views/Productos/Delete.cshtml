@model Facturapro.Models.Entities.Producto

@{
    ViewData["Title"] = "Eliminar Producto";
    var estaEnFacturas = ViewData["EstaEnFacturas"] as bool? ?? false;
}

<div class="page-header">
    <div class="page-title">
        <h1>Eliminar Producto</h1>
        <p>¿Estás seguro de que deseas eliminar este producto?</p>
    </div>
    <div class="page-actions">
        <a href="@Url.Action("Index")" class="btn btn-secondary">Volver a la lista</a>
    </div>
</div>

@if (estaEnFacturas)
{
    <div class="alert alert-warning">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z" />
        </svg>
        <strong>Advertencia:</strong> Este producto aparece en facturas existentes. Eliminarlo no afectará las facturas ya emitidas, pero ya no estará disponible para nuevas facturas.
    </div>
}

<div class="card">
    <div class="card-body">
        <div class="row" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: var(--space-lg); margin-bottom: var(--space-lg);">
            <div>
                <dl class="details-list">
                    <dt>Código</dt>
                    <dd><span class="badge badge-secondary">@Model.Codigo</span></dd>

                    <dt>Nombre</dt>
                    <dd>@Model.Nombre</dd>

                    <dt>Descripción</dt>
                    <dd>@(Model.Descripcion ?? "-")</dd>

                    <dt>Categoría</dt>
                    <dd>@(Model.Categoria?.Nombre ?? "Sin categoría")</dd>
                </dl>
            </div>

            <div>
                <dl class="details-list">
                    <dt>Precio</dt>
                    <dd style="font-size: 1.25rem; font-weight: 600;">@Model.Precio.ToString("C", new System.Globalization.CultureInfo("es-ES"))</dd>

                    <dt>Stock</dt>
                    <dd>@Model.Stock unidades</dd>

                    <dt>Estado</dt>
                    <dd>
                        @if (Model.Activo)
                        {
                            <span class="badge badge-success">Activo</span>
                        }
                        else
                        {
                            <span class="badge badge-secondary">Inactivo</span>
                        }
                    </dd>

                    <dt>Fecha de Creación</dt>
                    <dd>@Model.FechaCreacion.ToString("dd/MM/yyyy HH:mm")</dd>
                </dl>
            </div>
        </div>

        <form asp-action="Delete" method="post" style="border-top: 1px solid var(--color-gray-200); padding-top: var(--space-lg);">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />

            <div class="d-flex gap-1">
                <button type="submit" class="btn btn-danger btn-lg">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12.562c.34-.06.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
                    </svg>
                    Sí, Eliminar Producto
                </button>
                <a href="@Url.Action("Index")" class="btn btn-secondary btn-lg">Cancelar</a>
            </div>
        </form>
    </div>
</div>
