@model Facturapro.Models.Entities.Proveedor

@{
    ViewData["Title"] = "Nuevo Proveedor";
}

<!-- Page Header -->
<div class="page-header-title">
    <div class="d-flex align-items-center justify-content-between">
        <div>
            <h4 class="page-title mb-1">
                <i class="ri-truck-line me-1"></i>
                Nuevo Proveedor
            </h4>
            <p class="text-muted mb-0">Añade un nuevo proveedor a tu sistema</p>
        </div>
        <div>
            <a href="@Url.Action("Index")" class="btn btn-soft-secondary">
                <i class="ri-arrow-left-line me-1"></i> Volver
            </a>
        </div>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="row">
        <div class="col-12">
            <div class="alert alert-success border-0 alert-dismissible fade show" role="alert">
                <i class="ri-checkbox-circle-line me-2"></i>
                @TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        </div>
    </div>
}

@if (ViewData.ModelState.ErrorCount > 0)
{
    <div class="row">
        <div class="col-12">
            <div class="alert alert-danger border-0 alert-dismissible fade show" role="alert">
                <i class="ri-error-warning-line me-2"></i>
                Por favor corrige los errores marcados en el formulario.
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        </div>
    </div>
}

<div class="row">
    <!-- Columna Izquierda - Formulario -->
    <div class="col-xl-8">
        <form asp-action="Create" method="post" id="proveedorForm">
            @Html.AntiForgeryToken()

            <!-- Sección 1: Información Básica -->
            <div class="card">
                <div class="card-body">
                    <div class="d-flex align-items-center mb-4">
                        <div class="avatar-sm bg-primary rounded-3 me-3">
                            <span class="avatar-title text-white fw-bold">1</span>
                        </div>
                        <div>
                            <h5 class="card-title mb-0">Información Básica</h5>
                            <p class="text-muted mb-0 small">Datos principales del proveedor</p>
                        </div>
                    </div>

                    <div class="row g-3">
                        <div class="col-12">
                            <label asp-for="Nombre" class="form-label">
                                Nombre / Razón Social <span class="text-danger">*</span>
                            </label>
                            <input asp-for="Nombre" class="form-control" placeholder="Ej: Distribuidora S.R.L., Juan Pérez" />
                            <span asp-validation-for="Nombre" class="text-danger small"></span>
                            <small class="text-muted d-block mt-1">Nombre completo o razón social de la empresa</small>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Documento" class="form-label">
                                RNC / Cédula <span class="text-danger">*</span>
                            </label>
                            <div class="input-group">
                                <input asp-for="Documento" class="form-control" placeholder="Ej: 131703836" maxlength="20" inputmode="numeric" id="rncInput" />
                                <button class="btn btn-outline-primary" type="button" id="btnValidarRNC" title="Validar en DGII">
                                    <span id="spinnerRnc" class="spinner-border spinner-border-sm d-none" role="status"></span>
                                    <i id="iconRnc" class="ri-search-eye-line"></i>
                                </button>
                            </div>
                            <span asp-validation-for="Documento" class="text-danger small"></span>
                            <small class="text-muted d-block mt-1">9 dígitos (persona) u 11 (empresa)</small>
                            <div id="rncFeedback" class="small mt-1 d-none"></div>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="PersonaContacto" class="form-label">Persona de Contacto</label>
                            <input asp-for="PersonaContacto" class="form-control" placeholder="Nombre del contacto" />
                            <span asp-validation-for="PersonaContacto" class="text-danger small"></span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Sección 2: Información de Contacto -->
            <div class="card">
                <div class="card-body">
                    <div class="d-flex align-items-center mb-4">
                        <div class="avatar-sm bg-success rounded-3 me-3">
                            <span class="avatar-title text-white fw-bold">2</span>
                        </div>
                        <div>
                            <h5 class="card-title mb-0">Información de Contacto</h5>
                            <p class="text-muted mb-0 small">Teléfono y correo electrónico</p>
                        </div>
                    </div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="Telefono" class="form-label">Teléfono</label>
                            <input asp-for="Telefono" class="form-control" placeholder="Ej: 809-555-0000" maxlength="20" />
                            <span asp-validation-for="Telefono" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Email" class="form-label">
                                Email <span class="text-danger">*</span>
                            </label>
                            <input asp-for="Email" type="email" class="form-control" placeholder="contacto@proveedor.com" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Sección 3: Dirección y Estado -->
            <div class="card">
                <div class="card-body">
                    <div class="d-flex align-items-center mb-4">
                        <div class="avatar-sm bg-info rounded-3 me-3">
                            <span class="avatar-title text-white fw-bold">3</span>
                        </div>
                        <div>
                            <h5 class="card-title mb-0">Dirección y Estado</h5>
                            <p class="text-muted mb-0 small">Ubicación y estado del proveedor</p>
                        </div>
                    </div>

                    <div class="row g-3">
                        <div class="col-12">
                            <label asp-for="Direccion" class="form-label">Dirección</label>
                            <textarea asp-for="Direccion" class="form-control" rows="3" placeholder="Dirección completa del proveedor..."></textarea>
                            <span asp-validation-for="Direccion" class="text-danger small"></span>
                        </div>

                        <div class="col-12">
                            <div class="form-check form-switch form-switch-lg">
                                <input asp-for="Activo" class="form-check-input" id="activoToggle" checked />
                                <label class="form-check-label fw-semibold" for="activoToggle">
                                    <i class="ri-toggle-line me-1"></i>
                                    <span id="activoLabel">Proveedor Activo</span>
                                </label>
                            </div>
                            <small class="text-muted d-block mt-1">
                                <i class="ri-information-line me-1"></i>
                                <span id="activoDescripcion">Los proveedores activos aparecen en listados y pueden usarse en compras</span>
                            </small>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Botones de Acción -->
            <div class="d-flex gap-2 justify-content-end mt-4">
                <button type="button" class="btn btn-light" onclick="history.back()">
                    <i class="ri-arrow-left-line me-1"></i> Cancelar
                </button>
                <button type="submit" class="btn btn-primary">
                    <i class="ri-save-line me-1"></i> Guardar Proveedor
                </button>
            </div>
        </form>
    </div>

    <!-- Columna Derecha - Ayuda y Resumen -->
    <div class="col-xl-4">
        <!-- Campos Requeridos -->
        <div class="card">
            <div class="card-body">
                <h6 class="card-title mb-3">
                    <i class="ri-list-check me-1 text-primary"></i>
                    Campos Requeridos
                </h6>
                <ul class="list-group list-group-flush small">
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                        <span><i class="ri-store-2-line me-2"></i>Nombre / Razón Social</span>
                        <span class="badge bg-danger-soft text-danger">Obligatorio</span>
                    </li>
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                        <span><i class="ri-id-card-line me-2"></i>RNC / Cédula</span>
                        <span class="badge bg-danger-soft text-danger">Obligatorio</span>
                    </li>
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                        <span><i class="ri-mail-line me-2"></i>Email</span>
                        <span class="badge bg-danger-soft text-danger">Obligatorio</span>
                    </li>
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                        <span><i class="ri-phone-line me-2"></i>Teléfono</span>
                        <span class="badge bg-warning-soft text-warning">Opcional</span>
                    </li>
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                        <span><i class="ri-map-pin-line me-2"></i>Dirección</span>
                        <span class="badge bg-warning-soft text-warning">Opcional</span>
                    </li>
                </ul>
            </div>
        </div>

        <!-- Información Importante -->
        <div class="card bg-soft-primary border-0">
            <div class="card-body">
                <h6 class="card-title text-primary mb-2">
                    <i class="ri-information-line me-1"></i>
                    Información Importante
                </h6>
                <p class="small text-muted mb-2">
                    El RNC es el identificador fiscal que requiere la DGII para todas las compras registradas.
                </p>
                <ul class="small text-muted mb-0" style="padding-left: 1.2rem;">
                    <li>Personas físicas: 9 dígitos</li>
                    <li>Empresas: 11 dígitos</li>
                    <li>Sin puntos ni guiones</li>
                </ul>
            </div>
        </div>

        <!-- Tipos de Proveedores -->
        <div class="card bg-soft-success border-0">
            <div class="card-body">
                <h6 class="card-title text-success mb-2">
                    <i class="ri-truck-line me-1"></i>
                    Tipos de Proveedores
                </h6>
                <p class="small text-muted mb-2">
                    Puedes registrar diferentes tipos de proveedores:
                </p>
                <div class="d-flex flex-wrap gap-2">
                    <span class="badge bg-success-soft text-success-emphasis border border-success-subtle">Distribuidor</span>
                    <span class="badge bg-success-soft text-success-emphasis border border-success-subtle">Mayorista</span>
                    <span class="badge bg-success-soft text-success-emphasis border border-success-subtle">Fabricante</span>
                    <span class="badge bg-success-soft text-success-emphasis border border-success-subtle">Importador</span>
                    <span class="badge bg-success-soft text-success-emphasis border border-success-subtle">Servicios</span>
                </div>
            </div>
        </div>

        <!-- Soporte -->
        <div class="card border-0">
            <div class="card-body text-center p-4">
                <div class="avatar-lg bg-info-soft rounded-circle mb-2 mx-auto d-flex align-items-center justify-content-center" style="width: 64px; height: 64px;">
                    <i class="ri-customer-service-2-line display-4 text-info"></i>
                </div>
                <h6 class="fw-semibold mb-1">¿Necesitas Ayuda?</h6>
                <p class="small text-muted mb-0">
                    Contacta con soporte si tienes dudas
                </p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Actualizar etiqueta del toggle de estado
        document.getElementById('activoToggle').addEventListener('change', function() {
            const label = document.getElementById('activoLabel');
            const descripcion = document.getElementById('activoDescripcion');

            if (this.checked) {
                label.textContent = 'Proveedor Activo';
                descripcion.textContent = 'Los proveedores activos aparecen en listados y pueden usarse en compras';
            } else {
                label.textContent = 'Proveedor Inactivo';
                descripcion.textContent = 'Los proveedores inactivos no aparecen en listados ni compras';
            }
        });

        // Validación Automática de RNC (DGII)
        const rncInput = document.getElementById('rncInput');
        const btnValidarRNC = document.getElementById('btnValidarRNC');
        const spinnerRnc = document.getElementById('spinnerRnc');
        const iconRnc = document.getElementById('iconRnc');
        const rncFeedback = document.getElementById('rncFeedback');
        const nombreInput = document.querySelector('input[name="Nombre"]');

        async function validarRNC() {
            const rnc = rncInput.value.trim();
            if (rnc.length !== 9 && rnc.length !== 11) return;

            // Mostrar cargando
            spinnerRnc.classList.remove('d-none');
            iconRnc.classList.add('d-none');
            rncFeedback.classList.remove('d-none');
            rncFeedback.className = 'small mt-1 text-muted';
            rncFeedback.innerHTML = '<i class="ri-loader-4-line ri-spin me-1"></i> Consultando DGII...';

            try {
                const response = await fetch(`/api/validation/rnc/${rnc}`);
                const data = await response.json();

                if (data.esValido) {
                    rncInput.classList.add('is-valid');
                    rncInput.classList.remove('is-invalid');
                    
                    let feedbackMsg = `<i class="ri-checkbox-circle-line me-1"></i> ${data.mensaje}`;
                    if (data.estado) feedbackMsg += ` | Estado: <strong>${data.estado}</strong>`;
                    if (data.regimen) feedbackMsg += ` | Régimen: <strong>${data.regimen}</strong>`;
                    
                    rncFeedback.className = data.estado === 'SUSPENDIDO' ? 'small mt-1 text-danger fw-bold' : 'small mt-1 text-success fw-semibold';
                    rncFeedback.innerHTML = feedbackMsg;
                    
                    if (data.nombre) {
                        nombreInput.value = data.nombre;
                        nombreInput.classList.add('is-valid');
                        
                        // Efecto de brillo para indicar que se actualizó
                        nombreInput.style.backgroundColor = '#e8f5e9';
                        setTimeout(() => nombreInput.style.backgroundColor = '', 1000);
                    }
                } else {
                    rncInput.classList.add('is-invalid');
                    rncInput.classList.remove('is-valid');
                    rncFeedback.className = 'small mt-1 text-danger';
                    rncFeedback.innerHTML = `<i class="ri-error-warning-line me-1"></i> ${data.mensaje}`;
                }
            } catch (error) {
                console.error('Error validando RNC:', error);
                rncFeedback.className = 'small mt-1 text-warning';
                rncFeedback.innerHTML = '<i class="ri-alert-line me-1"></i> No se pudo conectar con el servicio de validación.';
            } finally {
                spinnerRnc.classList.add('d-none');
                iconRnc.classList.remove('d-none');
            }
        }

        rncInput.addEventListener('blur', validarRNC);
        btnValidarRNC.addEventListener('click', validarRNC);

        // Validación de Documento/RNC - Solo números
        rncInput.addEventListener('input', function(e) {
            this.value = this.value.replace(/[^0-9]/g, '');
            this.classList.remove('is-valid', 'is-invalid');
            rncFeedback.classList.add('d-none');
        });

        // Validación de Teléfono - Formato dominicano
        document.querySelector('input[name="Telefono"]').addEventListener('input', function(e) {
            let value = this.value.replace(/[^0-9]/g, '');
            if (value.length > 3 && value.length <= 6) {
                value = value.slice(0, 3) + '-' + value.slice(3);
            } else if (value.length > 6) {
                value = value.slice(0, 3) + '-' + value.slice(3, 6) + '-' + value.slice(6, 10);
            }
            this.value = value;
        });

        // Validación de Email - Convertir a minúsculas
        document.querySelector('input[name="Email"]').addEventListener('input', function(e) {
            this.value = this.value.toLowerCase();
        });

        // Validación del formulario antes de enviar
        document.getElementById('proveedorForm').addEventListener('submit', function(e) {
            let isValid = true;
            const camposObligatorios = ['Nombre', 'Documento', 'Email'];

            camposObligatorios.forEach(function(campo) {
                const elemento = document.querySelector('input[name="' + campo + '"]');
                if (elemento && !elemento.value.trim()) {
                    isValid = false;
                    elemento.classList.add('is-invalid');
                    elemento.classList.add('border-danger');
                } else if (elemento) {
                    elemento.classList.remove('is-invalid');
                    elemento.classList.remove('border-danger');
                }
            });

            // Validar formato de Documento/RNC (9 o 11 dígitos)
            const documentoInput = document.querySelector('input[name="Documento"]');
            if (documentoInput && documentoInput.value.trim()) {
                const documentoValor = documentoInput.value.trim();
                if (documentoValor.length !== 9 && documentoValor.length !== 11) {
                    isValid = false;
                    documentoInput.classList.add('is-invalid');
                    documentoInput.classList.add('border-danger');
                }
            }

            if (!isValid) {
                e.preventDefault();

                // Mostrar alerta de error
                const alerta = document.createElement('div');
                alerta.className = 'alert alert-danger border-0 alert-dismissible fade show';
                alerta.setAttribute('role', 'alert');
                alerta.innerHTML = `
                    <i class="ri-error-warning-line me-2"></i>
                    Por favor completa los campos requeridos y verifica el formato del RNC.
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                `;

                const formContainer = document.querySelector('.page-header-title');
                const alertaExistente = formContainer.parentElement.querySelector('.alert-danger');
                if (alertaExistente) {
                    alertaExistente.remove();
                }
                formContainer.after(alerta);

                // Scroll al primer error
                document.querySelector('.is-invalid')?.scrollIntoView({ behavior: 'smooth', block: 'center' });
            }
        });

        // Remover clase de error al escribir
        document.querySelectorAll('.form-control, textarea').forEach(function(input) {
            input.addEventListener('input', function() {
                this.classList.remove('is-invalid');
                this.classList.remove('border-danger');
            });
        });
    </script>
}
