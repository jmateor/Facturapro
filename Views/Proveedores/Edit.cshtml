@model Facturapro.Models.Entities.Proveedor

@{
    ViewData["Title"] = "Editar Proveedor";
}

<!-- Page Header -->
<div class="page-header-title">
    <div class="d-flex align-items-center justify-content-between">
        <div>
            <h4 class="page-title mb-1">
                <i class="ri-edit-2-line me-1"></i>
                Editar Proveedor
            </h4>
            <p class="text-muted mb-0">Modifica la información de @Model.Nombre</p>
        </div>
        <div class="d-flex gap-2">
            <a href="@Url.Action("Details", new { id = Model.Id })" class="btn btn-soft-info">
                <i class="ri-eye-line me-1"></i> Ver Detalles
            </a>
            <a href="@Url.Action("Index")" class="btn btn-soft-secondary">
                <i class="ri-arrow-left-line me-1"></i> Volver
            </a>
        </div>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="row">
        <div class="col-12">
            <div class="alert alert-success border-0 alert-dismissible fade show" role="alert">
                <i class="ri-checkbox-circle-line me-2"></i>
                @TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        </div>
    </div>
}

@if (ViewData.ModelState.ErrorCount > 0)
{
    <div class="row">
        <div class="col-12">
            <div class="alert alert-danger border-0 alert-dismissible fade show" role="alert">
                <i class="ri-error-warning-line me-2"></i>
                Por favor corrige los errores marcados en el formulario.
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        </div>
    </div>
}

<div class="row">
    <!-- Columna Izquierda - Formulario -->
    <div class="col-xl-8">
        <form asp-action="Edit" method="post" id="proveedorForm">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="FechaCreacion" />

            <!-- Sección 1: Información Básica -->
            <div class="card">
                <div class="card-body">
                    <div class="d-flex align-items-center mb-4">
                        <div class="avatar-sm bg-primary rounded-3 me-3">
                            <span class="avatar-title text-white fw-bold">1</span>
                        </div>
                        <div>
                            <h5 class="card-title mb-0">Información Básica</h5>
                            <p class="text-muted mb-0 small">Datos principales del proveedor</p>
                        </div>
                    </div>

                    <div class="row g-3">
                        <div class="col-12">
                            <label asp-for="Nombre" class="form-label">
                                Nombre / Razón Social <span class="text-danger">*</span>
                            </label>
                            <input asp-for="Nombre" class="form-control" placeholder="Ej: Distribuidora S.R.L." />
                            <span asp-validation-for="Nombre" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Documento" class="form-label">
                                RNC / Cédula <span class="text-danger">*</span>
                            </label>
                            <input asp-for="Documento" class="form-control" placeholder="Ej: 131703836" maxlength="20" inputmode="numeric" />
                            <span asp-validation-for="Documento" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="PersonaContacto" class="form-label">Persona de Contacto</label>
                            <input asp-for="PersonaContacto" class="form-control" placeholder="Nombre del contacto" />
                            <span asp-validation-for="PersonaContacto" class="text-danger small"></span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Sección 2: Información de Contacto -->
            <div class="card">
                <div class="card-body">
                    <div class="d-flex align-items-center mb-4">
                        <div class="avatar-sm bg-success rounded-3 me-3">
                            <span class="avatar-title text-white fw-bold">2</span>
                        </div>
                        <div>
                            <h5 class="card-title mb-0">Información de Contacto</h5>
                            <p class="text-muted mb-0 small">Teléfono y correo electrónico</p>
                        </div>
                    </div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="Telefono" class="form-label">Teléfono</label>
                            <input asp-for="Telefono" class="form-control" placeholder="Ej: 809-555-0000" maxlength="20" />
                            <span asp-validation-for="Telefono" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Email" class="form-label">
                                Email <span class="text-danger">*</span>
                            </label>
                            <input asp-for="Email" type="email" class="form-control" placeholder="contacto@proveedor.com" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Sección 3: Dirección y Estado -->
            <div class="card">
                <div class="card-body">
                    <div class="d-flex align-items-center mb-4">
                        <div class="avatar-sm bg-info rounded-3 me-3">
                            <span class="avatar-title text-white fw-bold">3</span>
                        </div>
                        <div>
                            <h5 class="card-title mb-0">Dirección y Estado</h5>
                            <p class="text-muted mb-0 small">Ubicación y estado del proveedor</p>
                        </div>
                    </div>

                    <div class="row g-3">
                        <div class="col-12">
                            <label asp-for="Direccion" class="form-label">Dirección</label>
                            <textarea asp-for="Direccion" class="form-control" rows="3" placeholder="Dirección completa del proveedor..."></textarea>
                            <span asp-validation-for="Direccion" class="text-danger small"></span>
                        </div>

                        <div class="col-12">
                            <div class="form-check form-switch form-switch-lg">
                                <input asp-for="Activo" class="form-check-input" id="activoToggle" />
                                <label class="form-check-label fw-semibold" for="activoToggle">
                                    <i class="ri-toggle-line me-1"></i>
                                    <span id="activoLabel">@(Model.Activo ? "Proveedor Activo" : "Proveedor Inactivo")</span>
                                </label>
                            </div>
                            <small class="text-muted d-block mt-1">
                                <i class="ri-information-line me-1"></i>
                                <span id="activoDescripcion">@(Model.Activo ? "Los proveedores activos aparecen en listados y pueden usarse en compras" : "Los proveedores inactivos no aparecen en listados ni compras")</span>
                            </small>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Botones de Acción -->
            <div class="d-flex gap-2 justify-content-end mt-4">
                <button type="button" class="btn btn-light" onclick="history.back()">
                    <i class="ri-arrow-left-line me-1"></i> Cancelar
                </button>
                <a href="@Url.Action("Delete", new { id = Model.Id })" class="btn btn-danger"
                   onclick="return confirm('¿Está seguro de eliminar este proveedor? Esta acción no se puede deshacer.')">
                    <i class="ri-delete-bin-line me-1"></i> Eliminar
                </a>
                <button type="submit" class="btn btn-primary">
                    <i class="ri-save-line me-1"></i> Guardar Cambios
                </button>
            </div>
        </form>
    </div>

    <!-- Columna Derecha - Resumen e Información -->
    <div class="col-xl-4">
        <!-- Tarjeta de Proveedor -->
        <div class="card bg-primary text-white">
            <div class="card-body text-center">
                <div class="avatar-lg bg-white text-primary rounded-circle mb-3 mx-auto d-flex align-items-center justify-content-center" style="width: 100px; height: 100px;">
                    <i class="ri-truck-line display-4"></i>
                </div>
                <h5 class="mb-1">@Model.Nombre</h5>
                <p class="text-white-50 small mb-2">
                    @(Model.Documento ?? "Sin documento")
                </p>
                <span class="badge bg-white text-primary">
                    @(Model.Activo ? "Activo" : "Inactivo")
                </span>
            </div>
        </div>

        <!-- Información Rápida -->
        <div class="card">
            <div class="card-body">
                <h6 class="card-title mb-3">
                    <i class="ri-file-info-line me-1 text-primary"></i>
                    Información Rápida
                </h6>

                <div class="d-flex justify-content-between mb-3 pb-3 border-bottom">
                    <div>
                        <p class="text-muted mb-0 small">Compras</p>
                        <h4 class="mb-0 fw-bold">@Model.Compras?.Count ?? 0</h4>
                    </div>
                    <div class="text-end">
                        <p class="text-muted mb-0 small">Estado</p>
                        <h4 class="mb-0 fw-bold @(Model.Activo ? "text-success" : "text-secondary")">
                            @(Model.Activo ? "Activo" : "Inactivo")
                        </h4>
                    </div>
                </div>

                <div class="small">
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted"><i class="ri-mail-line me-2"></i>Email:</span>
                        <span class="fw-medium">@Model.Email</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted"><i class="ri-phone-line me-2"></i>Teléfono:</span>
                        <span class="fw-medium">@Model.Telefono</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted"><i class="ri-user-line me-2"></i>Contacto:</span>
                        <span class="fw-medium">@Model.PersonaContacto</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted"><i class="ri-calendar-line me-2"></i>Creado:</span>
                        <span class="fw-medium">@Model.FechaCreacion.ToString("dd/MM/yyyy")</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Compras Asociadas -->
        @if (Model.Compras != null && Model.Compras.Any())
        {
            <div class="card bg-soft-success border-0">
                <div class="card-body">
                    <h6 class="card-title text-success mb-2">
                        <i class="ri-shopping-bag-line me-1"></i>
                        Compras Registradas
                    </h6>
                    <p class="small text-muted mb-2">
                        Este proveedor tiene <strong>@Model.Compras.Count compra(s)</strong> registrada(s).
                    </p>
                    <div class="alert alert-warning-soft mb-0 small">
                        <i class="ri-alert-line me-1"></i>
                        No se puede eliminar un proveedor con compras asociadas
                    </div>
                </div>
            </div>
        }

        <!-- Zona de Peligro -->
        <div class="card border-danger border-1">
            <div class="card-body">
                <h6 class="card-title text-danger mb-2">
                    <i class="ri-delete-bin-2-line me-1"></i>
                    Zona de Peligro
                </h6>
                @if (Model.Compras != null && Model.Compras.Any())
                {
                    <div class="alert alert-danger-soft mb-2">
                        <i class="ri-error-warning-line me-1"></i>
                        <strong>No se puede eliminar:</strong> Este proveedor tiene @(Model.Compras.Count) compra(s) asociada(s).
                    </div>
                }
                else
                {
                    <p class="small text-muted mb-3">
                        Este proveedor no tiene compras asociadas. Puedes eliminarlo de forma segura.
                    </p>
                    <a href="@Url.Action("Delete", new { id = Model.Id })" class="btn btn-outline-danger w-100"
                       onclick="return confirm('¿Está completamente seguro? Esta acción es irreversible.')">
                        <i class="ri-delete-bin-line me-1"></i> Eliminar Proveedor
                    </a>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Actualizar etiqueta del toggle de estado
        document.getElementById('activoToggle').addEventListener('change', function() {
            const label = document.getElementById('activoLabel');
            const descripcion = document.getElementById('activoDescripcion');

            if (this.checked) {
                label.textContent = 'Proveedor Activo';
                descripcion.textContent = 'Los proveedores activos aparecen en listados y pueden usarse en compras';
            } else {
                label.textContent = 'Proveedor Inactivo';
                descripcion.textContent = 'Los proveedores inactivos no aparecen en listados ni compras';
            }
        });
    </script>
}
