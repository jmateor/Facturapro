@model IEnumerable<Facturapro.Models.Entities.Sucursal>
@{
    ViewData["Title"] = "Gestionar Sucursales";
}

<div class="row">
    <div class="col-12">
        <div class="page-title-box d-flex align-items-center justify-content-between">
            <h4 class="page-title">Configuración de Sucursales</h4>
            <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#modalNuevaSucursal">
                <i class="ri-add-line me-1"></i> Nueva Sucursal
            </button>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover table-centered mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Nombre</th>
                                <th>Dirección</th>
                                <th>Teléfono</th>
                                <th>Almacenes</th>
                                <th>Estado</th>
                                <th>Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var sucursal in Model)
                            {
                                <tr>
                                    <td class="fw-bold">
                                        @sucursal.Nombre
                                        @if (sucursal.EsPrincipal)
                                        {
                                            <span class="badge bg-soft-primary text-primary ms-1">Principal</span>
                                        }
                                    </td>
                                    <td>@sucursal.Direccion</td>
                                    <td>@sucursal.Telefono</td>
                                    <td>
                                        <span class="badge bg-soft-info text-info">@sucursal.Almacenes.Count()</span>
                                    </td>
                                    <td>
                                        <div class="form-check form-switch">
                                            <input class="form-check-input" type="checkbox" @(sucursal.Activo ? "checked" : "")>
                                        </div>
                                    </td>
                                    <td>
                                        <div class="btn-group">
                                            <button class="btn btn-sm btn-soft-primary"><i class="ri-edit-line"></i></button>
                                            <button class="btn btn-sm btn-soft-danger" @(sucursal.EsPrincipal ? "disabled" : "")><i class="ri-delete-bin-line"></i></button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal Nueva Sucursal -->
<div class="modal fade" id="modalNuevaSucursal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Nueva Sucursal</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="CrearSucursal" method="post">
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Nombre de la Sucursal</label>
                        <input type="text" name="Nombre" class="form-control" required placeholder="Ej: Sucursal Zona Oriental">
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Dirección</label>
                        <input type="text" name="Direccion" class="form-control" placeholder="Calle, Número, Sector">
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Teléfono</label>
                        <input type="text" name="Telefono" class="form-control" placeholder="809-000-0000">
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-primary">Guardar Sucursal</button>
                </div>
            </form>
        </div>
    </div>
</div>
