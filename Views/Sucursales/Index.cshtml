@model IEnumerable<Facturapro.Models.Entities.Sucursal>
@{
    ViewData["Title"] = "Sucursales y Almacenes";
}

<div class="row">
    <div class="col-12">
        <div class="page-title-box">
            <h4 class="page-title"><i class="ri-store-2-line me-2"></i>Estado de Sucursales</h4>
            <p class="text-muted">Vista general de inventario por ubicación</p>
        </div>
    </div>
</div>

<div class="row">
    @foreach (var sucursal in Model)
    {
        <div class="col-xl-6">
            <div class="card">
                <div class="card-header bg-soft-primary d-flex justify-content-between align-items-center">
                    <h5 class="card-title mb-0">
                        <i class="ri-map-pin-line me-1"></i> @sucursal.Nombre
                        @if (sucursal.EsPrincipal)
                        {
                            <span class="badge bg-primary ms-2">Principal</span>
                        }
                    </h5>
                    <span class="badge @(sucursal.Activo ? "bg-success" : "bg-danger")">
                        @(sucursal.Activo ? "Activa" : "Inactiva")
                    </span>
                </div>
                <div class="card-body">
                    <p class="text-muted mb-3"><i class="ri-map-pin-2-line me-1"></i> @sucursal.Direccion</p>
                    
                    <h6>Almacenes:</h6>
                    <div class="table-responsive">
                        <table class="table table-sm table-centered mb-0">
                            <thead>
                                <tr>
                                    <th>Nombre</th>
                                    <th>Items</th>
                                    <th>Capacidad</th>
                                    <th>Acción</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var almacen in sucursal.Almacenes)
                                {
                                    <tr>
                                        <td>@almacen.Nombre</td>
                                        <td>@almacen.Stocks.Count() productos</td>
                                        <td>
                                            <div class="progress progress-sm" style="height: 5px;">
                                                <div class="progress-bar bg-success" role="progressbar" style="width: 45%" aria-valuenow="45" aria-valuemin="0" aria-valuemax="100"></div>
                                            </div>
                                        </td>
                                        <td>
                                            <button class="btn btn-sm btn-soft-info"><i class="ri-eye-line"></i></button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<div class="row mt-3">
    <div class="col-12 text-center">
        <a href="@Url.Action("Gestionar", "Sucursales")" class="btn btn-primary">
            <i class="ri-settings-line me-1"></i> Configurar Sucursales y Almacenes
        </a>
    </div>
</div>
