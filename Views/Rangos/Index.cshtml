@model Facturapro.Services.DGII.EstadisticasRangos

@{
    ViewData["Title"] = "Rangos de Numeración e-CF";
}

<!-- start page title -->
<div class="row">
    <div class="col-12">
        <div class="page-title-box">
            <div class="page-title-right">
                <a href="@Url.Action("Create")" class="btn btn-primary">
                    <i class="ri-add-circle-line me-1"></i>
                    Nuevo Rango
                </a>
            </div>
            <h4 class="page-title">
                <i class="ri-file-list-2-line me-2"></i>
                Rangos de Numeración
            </h4>
            <p class="text-muted mb-0">Gestione los rangos autorizados por la DGII para emitir e-CF</p>
        </div>
    </div>
</div>
<!-- end page title -->

<!-- Resumen Estadístico -->
<div class="row mb-3">
    <div class="col-md-3">
        <div class="card widget-flat text-bg-primary">
            <div class="card-body">
                <div class="float-end">
                    <i class="ri-file-list-3-line widget-icon"></i>
                </div>
                <h6 class="text-uppercase mt-0">Total Rangos</h6>
                <h2 class="my-2">@Model.TotalRangos</h2>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card widget-flat text-bg-success">
            <div class="card-body">
                <div class="float-end">
                    <i class="ri-checkbox-circle-line widget-icon"></i>
                </div>
                <h6 class="text-uppercase mt-0">Rangos Activos</h6>
                <h2 class="my-2">@Model.RangosActivos</h2>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card widget-flat text-bg-warning">
            <div class="card-body">
                <div class="float-end">
                    <i class="ri-alarm-warning-line widget-icon"></i>
                </div>
                <h6 class="text-uppercase mt-0">Por Agotarse</h6>
                <h2 class="my-2">@Model.RangosConAlerta</h2>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card widget-flat text-bg-danger">
            <div class="card-body">
                <div class="float-end">
                    <i class="ri-indeterminate-circle-line widget-icon"></i>
                </div>
                <h6 class="text-uppercase mt-0">Agotados</h6>
                <h2 class="my-2">@Model.RangosAgotados</h2>
            </div>
        </div>
    </div>
</div>

<!-- Disponibilidad por Tipo -->
<div class="card mb-3">
    <div class="card-header">
        <h5 class="header-title mb-0">
            <i class="ri-pie-chart-line me-1"></i>
            Disponibilidad por Tipo de Comprobante
        </h5>
    </div>
    <div class="card-body">
        <div class="table-responsive-sm">
            <table class="table table-centered mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Tipo e-CF</th>
                        <th>Descripción</th>
                        <th>Total Rangos</th>
                        <th>Disponibles</th>
                        <th>Estado</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var tipo in Model.DetallePorTipo)
                    {
                        var estadoClass = tipo.Disponibles > 100 ? "bg-success" : (tipo.Disponibles > 0 ? "bg-warning" : "bg-danger");
                        <tr>
                            <td><span class="badge bg-info">E@tipo.TipoECF</span></td>
                            <td>@tipo.TipoECFNombre</td>
                            <td>@tipo.Total</td>
                            <td>@tipo.Disponibles</td>
                            <td><span class="badge @estadoClass">@(tipo.Disponibles > 0 ? "Disponible" : "Agotado")</span></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Lista de Rangos -->
<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="header-title mb-0">
            <i class="ri-folders-line me-1"></i>
            Rangos Configurados
        </h5>
    </div>
    <div class="card-body">
        <div class="table-responsive-sm">
            <table class="table table-centered mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Tipo</th>
                        <th>Rango</th>
                        <th>Usados</th>
                        <th>Disponibles</th>
                        <th>Vencimiento</th>
                        <th>Estado</th>
                        <th>Progreso</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td colspan="8" class="text-center py-5">
                            <i class="ri-file-list-3-line text-muted" style="font-size: 3rem;"></i>
                            <p class="text-muted mt-2 mb-0">Los rangos se mostrarán aquí una vez configurados</p>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>
