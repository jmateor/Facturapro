@model Facturapro.Models.Entities.ConfiguracionIntegracion
@{
    ViewData["Title"] = "Integraciones y Moneda";
}

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-12">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="@Url.Action("Index", "Configuracion")">Configuración</a></li>
                    <li class="breadcrumb-item active">Integraciones</li>
                </ol>
            </nav>
            <h2 class="h3 mb-0 text-gray-800"><i class="ri-pulse-line me-2 text-primary"></i>Integraciones y Moneda</h2>
            <p class="text-muted">Gestiona la tasa del dólar y las conexiones con servicios externos.</p>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="ri-checkbox-circle-line me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <form asp-action="Integraciones" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />

        <div class="row">
            <!-- Moneda y Tasa de Cambio -->
            <div class="col-lg-4 mb-4">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-header bg-white py-3">
                        <h5 class="mb-0 text-primary"><i class="ri-money-dollar-circle-line me-2"></i>Configuración de Moneda</h5>
                    </div>
                    <div class="card-body">
                        <div class="alert alert-soft-info mb-4">
                            <small><i class="ri-information-line me-1"></i> Esta tasa se utilizará en el POS para convertir transacciones de USD a DOP para fines fiscales (DGII).</small>
                        </div>
                        
                        <div class="mb-3">
                            <label asp-for="TasaUSD" class="form-label fw-bold"></label>
                            <div class="input-group input-group-lg">
                                <span class="input-group-text bg-light">RD$</span>
                                <input asp-for="TasaUSD" class="form-control" type="number" step="0.01" />
                            </div>
                            <span asp-validation-for="TasaUSD" class="text-danger small"></span>
                        </div>

                        <div class="d-flex align-items-center p-3 bg-soft-warning rounded-3 border border-warning border-opacity-25 mt-4">
                            <i class="ri-time-line ri-2x text-warning me-3"></i>
                            <div>
                                <h6 class="mb-1 fw-bold">Actualización Diaria</h6>
                                <p class="mb-0 small text-muted">Se recomienda actualizar la tasa cada mañana según el Banco Central.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Email (SMTP) -->
            <div class="col-lg-8">
                <div class="row">
                    <div class="col-12 mb-4">
                        <div class="card border-0 shadow-sm">
                            <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
                                <h5 class="mb-0 text-primary"><i class="ri-mail-send-line me-2"></i>Correo Electrónico (SMTP)</h5>
                                <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox" asp-for="EmailHabilitado">
                                    <label class="form-check-label" asp-for="EmailHabilitado">Habilitado</label>
                                </div>
                            </div>
                            <div class="card-body">
                                <div class="row g-3">
                                    <div class="col-md-8">
                                        <label asp-for="SmtpServer" class="form-label">Servidor SMTP</label>
                                        <input asp-for="SmtpServer" class="form-control" placeholder="smtp.gmail.com" />
                                    </div>
                                    <div class="col-md-4">
                                        <label asp-for="SmtpPort" class="form-label">Puerto</label>
                                        <input asp-for="SmtpPort" class="form-control" type="number" />
                                    </div>
                                    <div class="col-md-6">
                                        <label asp-for="SmtpUser" class="form-label">Usuario / Email</label>
                                        <input asp-for="SmtpUser" class="form-control" />
                                    </div>
                                    <div class="col-md-6">
                                        <label asp-for="SmtpPassword" class="form-label">Contraseña</label>
                                        <input asp-for="SmtpPassword" class="form-control" type="password" />
                                    </div>
                                    <div class="col-12">
                                        <div class="form-check">
                                            <input class="form-check-input" type="checkbox" asp-for="SmtpUseSSL">
                                            <label class="form-check-label" asp-for="SmtpUseSSL">Usar SSL / TLS</label>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- WhatsApp y Otros -->
                    <div class="col-md-6 mb-4">
                        <div class="card border-0 shadow-sm h-100">
                            <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
                                <h5 class="mb-0 text-success"><i class="ri-whatsapp-line me-2"></i>WhatsApp Business</h5>
                                <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox" asp-for="WhatsAppHabilitado">
                                    <label class="form-check-label" asp-for="WhatsAppHabilitado">Habilitado</label>
                                </div>
                            </div>
                            <div class="card-body">
                                <div class="mb-3">
                                    <label asp-for="WhatsAppApiKey" class="form-label">API Key (Meta)</label>
                                    <input asp-for="WhatsAppApiKey" class="form-control" type="password" />
                                </div>
                                <div class="mb-3">
                                    <label asp-for="WhatsAppPhoneId" class="form-label">Phone ID</label>
                                    <input asp-for="WhatsAppPhoneId" class="form-control" />
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-6 mb-4">
                        <div class="card border-0 shadow-sm h-100">
                            <div class="card-header bg-white py-3">
                                <h5 class="mb-0 text-info"><i class="ri-shield-check-line me-2"></i>Validaciones DGII</h5>
                            </div>
                            <div class="card-body">
                                <div class="form-check form-switch mb-3">
                                    <input class="form-check-input" type="checkbox" asp-for="DgiiValidacionHabilitada">
                                    <label class="form-check-label" asp-for="DgiiValidacionHabilitada">Validar RNC en tiempo real</label>
                                </div>
                                <p class="text-muted small">Al activar esta opción, el sistema consultará el padrón de la DGII al crear clientes nuevos.</p>
                                
                                <hr>
                                
                                <div class="d-flex align-items-center text-muted">
                                    <i class="ri-google-fill me-2"></i>
                                    <span class="small">Google Drive Backup (Próximamente)</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-12 text-end">
                <hr>
                <button type="submit" class="btn btn-primary btn-lg px-5">
                    <i class="ri-save-line me-2"></i> Guardar Cambios
                </button>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
