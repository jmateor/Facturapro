@{
    ViewData["Title"] = "Configuración";
}

<!-- start page title -->
<div class="row">
    <div class="col-12">
        <div class="page-title-box">
            <h4 class="page-title">
                <i class="ri-settings-3-line me-2"></i>
                Configuración
            </h4>
            <p class="text-muted mb-0">Administre la información y ajustes de su negocio</p>
        </div>
    </div>
</div>
<!-- end page title -->

<div class="row">
    <!-- Negocio / Empresa -->
    <div class="col-xl-4 col-md-6">
        <div class="card h-100">
            <div class="card-body">
                <div class="d-flex align-items-center mb-3">
                    <div class="flex-shrink-0">
                        <div class="avatar-lg rounded-circle bg-primary text-white d-flex align-items-center justify-content-center" style="width: 60px; height: 60px;">
                            <i class="ri-store-2-line fs-2"></i>
                        </div>
                    </div>
                    <div class="flex-grow-1 ms-3">
                        <h5 class="mb-1">Negocio</h5>
                        <p class="text-muted mb-0 small">Información de su empresa</p>
                    </div>
                </div>
                <div class="list-group list-group-flush">
                    <a href="@Url.Action("Empresa", "Configuracion")" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center px-0">
                        <span><i class="ri-building-line me-2"></i>Mi negocio</span>
                        <i class="ri-arrow-right-s-line text-muted"></i>
                    </a>
                    <a href="@Url.Action("DGII", "Configuracion")" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center px-0">
                        <span><i class="ri-government-line me-2"></i>Configuración DGII</span>
                        <i class="ri-arrow-right-s-line text-muted"></i>
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Sucursal y Caja -->
    <div class="col-xl-4 col-md-6">
        <div class="card h-100">
            <div class="card-body">
                <div class="d-flex align-items-center mb-3">
                    <div class="flex-shrink-0">
                        <div class="avatar-lg rounded-circle bg-success text-white d-flex align-items-center justify-content-center" style="width: 60px; height: 60px;">
                            <i class="ri-map-pin-2-line fs-2"></i>
                        </div>
                    </div>
                    <div class="flex-grow-1 ms-3">
                        <h5 class="mb-1">Sucursal</h5>
                        <p class="text-muted mb-0 small">Puntos de atención</p>
                    </div>
                </div>
                <div class="list-group list-group-flush">
                    <a href="@Url.Action("Index", "Sucursales")" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center px-0">
                        <span><i class="ri-store-line me-2"></i>Sucursal actual</span>
                        <i class="ri-arrow-right-s-line text-muted"></i>
                    </a>
                    <a href="@Url.Action("Gestionar", "Sucursales")" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center px-0">
                        <span><i class="ri-building-4-line me-2"></i>Gestionar sucursales</span>
                        <i class="ri-arrow-right-s-line text-muted"></i>
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Detalles en ventas -->
    <div class="col-xl-4 col-md-6">
        <div class="card h-100">
            <div class="card-body">
                <div class="d-flex align-items-center mb-3">
                    <div class="flex-shrink-0">
                        <div class="avatar-lg rounded-circle bg-info text-white d-flex align-items-center justify-content-center" style="width: 60px; height: 60px;">
                            <i class="ri-shopping-cart-2-line fs-2"></i>
                        </div>
                    </div>
                    <div class="flex-grow-1 ms-3">
                        <h5 class="mb-1">Detalles en ventas</h5>
                        <p class="text-muted mb-0 small">Configuración de ventas</p>
                    </div>
                </div>
                <div class="list-group list-group-flush">
                    <a href="@Url.Action("Ventas", "Configuracion")" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center px-0">
                        <span><i class="ri-sliders-line me-2"></i>Preferencias de venta</span>
                        <i class="ri-arrow-right-s-line text-muted"></i>
                    </a>
                    <a href="@Url.Action("MetodosPago", "Configuracion")" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center px-0">
                        <span><i class="ri-bank-card-line me-2"></i>Métodos de pago</span>
                        <i class="ri-arrow-right-s-line text-muted"></i>
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Facturas -->
    <div class="col-xl-4 col-md-6">
        <div class="card h-100">
            <div class="card-body">
                <div class="d-flex align-items-center mb-3">
                    <div class="flex-shrink-0">
                        <div class="avatar-lg rounded-circle bg-warning text-white d-flex align-items-center justify-content-center" style="width: 60px; height: 60px;">
                            <i class="ri-file-list-3-line fs-2"></i>
                        </div>
                    </div>
                    <div class="flex-grow-1 ms-3">
                        <h5 class="mb-1">Facturas</h5>
                        <p class="text-muted mb-0 small">Documentos de venta</p>
                    </div>
                </div>
                <div class="list-group list-group-flush">
                    <a href="@Url.Action("Impresion", "Configuracion")" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center px-0">
                        <span><i class="ri-printer-line me-2"></i>Plantilla de impresión</span>
                        <i class="ri-arrow-right-s-line text-muted"></i>
                    </a>
                    <a href="@Url.Action("DGII", "Configuracion")" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center px-0">
                        <span><i class="ri-percent-line me-2"></i>Impuestos y NCF</span>
                        <i class="ri-arrow-right-s-line text-muted"></i>
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Administración -->
    <div class="col-xl-4 col-md-6">
        <div class="card h-100">
            <div class="card-body">
                <div class="d-flex align-items-center mb-3">
                    <div class="flex-shrink-0">
                        <div class="avatar-lg rounded-circle bg-purple text-white d-flex align-items-center justify-content-center" style="width: 60px; height: 60px;">
                            <i class="ri-shield-user-line fs-2"></i>
                        </div>
                    </div>
                    <div class="flex-grow-1 ms-3">
                        <h5 class="mb-1">Administración</h5>
                        <p class="text-muted mb-0 small">Seguridad y usuarios</p>
                    </div>
                </div>
                <div class="list-group list-group-flush">
                    <a href="@Url.Action("Usuarios", "Configuracion")" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center px-0">
                        <span><i class="ri-user-settings-line me-2"></i>Usuarios y permisos</span>
                        <i class="ri-arrow-right-s-line text-muted"></i>
                    </a>
                    <a href="@Url.Action("Alertas", "Configuracion")" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center px-0">
                        <span><i class="ri-notification-3-line me-2"></i>Alertas y avisos</span>
                        <i class="ri-arrow-right-s-line text-muted"></i>
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Dispositivos -->
    <div class="col-xl-4 col-md-6">
        <div class="card h-100">
            <div class="card-body">
                <div class="d-flex align-items-center mb-3">
                    <div class="flex-shrink-0">
                        <div class="avatar-lg rounded-circle bg-pink text-white d-flex align-items-center justify-content-center" style="width: 60px; height: 60px;">
                            <i class="ri-printer-cloud-line fs-2"></i>
                        </div>
                    </div>
                    <div class="flex-grow-1 ms-3">
                        <h5 class="mb-1">Dispositivos</h5>
                        <p class="text-muted mb-0 small">Hardware del punto de venta</p>
                    </div>
                </div>
                <div class="list-group list-group-flush">
                    <a href="@Url.Action("Index", "Dispositivos")" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center px-0">
                        <span><i class="ri-printer-line me-2"></i>Impresoras térmicas</span>
                        <span class="badge bg-success">Habilitado</span>
                    </a>
                    <a href="@Url.Action("Index", "Dispositivos")" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center px-0">
                        <span><i class="ri-barcode-box-line me-2"></i>Lectores de código</span>
                        <span class="badge bg-success">Habilitado</span>
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Más configuraciones -->
    <div class="col-xl-4 col-md-6">
        <div class="card h-100">
            <div class="card-body">
                <div class="d-flex align-items-center mb-3">
                    <div class="flex-shrink-0">
                        <div class="avatar-lg rounded-circle bg-dark text-white d-flex align-items-center justify-content-center" style="width: 60px; height: 60px;">
                            <i class="ri-more-line fs-2"></i>
                        </div>
                    </div>
                    <div class="flex-grow-1 ms-3">
                        <h5 class="mb-1">Más configuraciones</h5>
                        <p class="text-muted mb-0 small">Otras funcionalidades</p>
                    </div>
                </div>
                <div class="list-group list-group-flush">
                    <a href="@Url.Action("Backup", "Configuracion")" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center px-0">
                        <span><i class="ri-database-2-line me-2"></i>Respaldo de datos</span>
                        <i class="ri-arrow-right-s-line text-muted"></i>
                    </a>
                    <a href="@Url.Action("Integraciones", "Configuracion")" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center px-0">
                        <span><i class="ri-plug-line me-2"></i>Integraciones y Moneda</span>
                        <i class="ri-arrow-right-s-line text-muted"></i>
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
