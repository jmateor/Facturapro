@{
    ViewData["Title"] = "Plantilla de Impresión";
    ViewData["PageDescription"] = "Configura cómo se verán tus facturas al imprimir";
}

<!-- Page Header -->
<div class="page-header-title">
    <h4 class="page-title">
        <i class="ri-printer-line me-1"></i>
        Plantilla de Impresión
    </h4>
    <p class="text-muted">Personaliza el diseño y contenido de tus comprobantes fiscales</p>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="row">
        <div class="col-12">
            <div class="alert alert-success border-0 alert-dismissible fade show" role="alert">
                <i class="ri-checkbox-circle-line me-2"></i>
                @TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        </div>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="row">
        <div class="col-12">
            <div class="alert alert-danger border-0 alert-dismissible fade show" role="alert">
                <i class="ri-error-warning-line me-2"></i>
                @TempData["ErrorMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        </div>
    </div>
}

<div class="row">
    <!-- Columna Izquierda - Configuración -->
    <div class="col-xl-8">
        <form asp-action="Impresion" method="post" id="configForm">
            @Html.AntiForgeryToken()

            <!-- 1. Tipo de Ticket -->
            <div class="card">
                <div class="card-body">
                    <div class="d-flex align-items-center mb-4">
                        <div class="avatar-sm bg-primary rounded-3 me-3">
                            <span class="avatar-title text-white fw-bold">1</span>
                        </div>
                        <div>
                            <h5 class="card-title mb-0">Tipo de Comprobante</h5>
                            <p class="text-muted mb-0 small">Selecciona el formato de impresión de tus facturas</p>
                        </div>
                    </div>

                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="radio-card selected" onclick="selectTicketType('thermal', this)">
                                <input type="radio" name="TipoTicket" value="thermal" checked hidden />
                                <div class="card h-100 border-2 border-light hover-border-primary transition-all">
                                    <div class="card-body text-center p-4">
                                        <i class="ri-printer-2-line display-4 text-primary mb-3"></i>
                                        <h6 class="fw-semibold mb-1">Térmica</h6>
                                        <p class="text-muted small mb-0">58mm - 80mm</p>
                                    </div>
                                </div>
                            </label>
                        </div>

                        <div class="col-md-4">
                            <label class="radio-card" onclick="selectTicketType('half', this)">
                                <input type="radio" name="TipoTicket" value="half" hidden />
                                <div class="card h-100 border-2 border-light hover-border-primary transition-all">
                                    <div class="card-body text-center p-4">
                                        <i class="ri-file-text-line display-4 text-muted mb-3"></i>
                                        <h6 class="fw-semibold mb-1">Media Carta</h6>
                                        <p class="text-muted small mb-0">140mm × 216mm</p>
                                    </div>
                                </div>
                            </label>
                        </div>

                        <div class="col-md-4">
                            <label class="radio-card" onclick="selectTicketType('letter', this)">
                                <input type="radio" name="TipoTicket" value="letter" hidden />
                                <div class="card h-100 border-2 border-light hover-border-primary transition-all">
                                    <div class="card-body text-center p-4">
                                        <i class="ri-file-list-3-line display-4 text-muted mb-3"></i>
                                        <h6 class="fw-semibold mb-1">Carta</h6>
                                        <p class="text-muted small mb-0">216mm × 279mm</p>
                                    </div>
                                </div>
                            </label>
                        </div>
                    </div>
                </div>
            </div>

            <!-- 2. Elementos del Comprobante -->
            <div class="card">
                <div class="card-body">
                    <div class="d-flex align-items-center mb-4">
                        <div class="avatar-sm bg-info rounded-3 me-3">
                            <span class="avatar-title text-white fw-bold">2</span>
                        </div>
                        <div>
                            <h5 class="card-title mb-0">Elementos Visibles</h5>
                            <p class="text-muted mb-0 small">Elige qué información mostrar en tus comprobantes</p>
                        </div>
                    </div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <div class="card border-0 bg-soft-light">
                                <div class="card-body p-3">
                                    <div class="d-flex align-items-center justify-content-between">
                                        <div class="d-flex align-items-center gap-3">
                                            <div class="avatar-sm bg-soft-primary text-primary rounded-2 d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                                                <i class="ri-image-line"></i>
                                            </div>
                                            <div>
                                                <h6 class="mb-0 fs-6 fw-semibold">Mostrar Logotipo</h6>
                                                <p class="mb-0 text-muted small">Logo en el encabezado</p>
                                            </div>
                                        </div>
                                        <div class="form-check form-switch form-switch-lg mb-0">
                                            <input type="checkbox" class="form-check-input" id="MostrarLogo" name="MostrarLogo" value="true" checked onchange="updatePreview()" />
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="card border-0 bg-soft-light">
                                <div class="card-body p-3">
                                    <div class="d-flex align-items-center justify-content-between">
                                        <div class="d-flex align-items-center gap-3">
                                            <div class="avatar-sm bg-soft-success text-success rounded-2 d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                                                <i class="ri-file-text-line"></i>
                                            </div>
                                            <div>
                                                <h6 class="mb-0 fs-6 fw-semibold">Descripción Productos</h6>
                                                <p class="mb-0 text-muted small">Detalle de cada ítem</p>
                                            </div>
                                        </div>
                                        <div class="form-check form-switch form-switch-lg mb-0">
                                            <input type="checkbox" class="form-check-input" id="MostrarDescripcion" name="MostrarDescripcion" value="true" checked onchange="updatePreview()" />
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="card border-0 bg-soft-light">
                                <div class="card-body p-3">
                                    <div class="d-flex align-items-center justify-content-between">
                                        <div class="d-flex align-items-center gap-3">
                                            <div class="avatar-sm bg-soft-warning text-warning rounded-2 d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                                                <i class="ri-barcode-line"></i>
                                            </div>
                                            <div>
                                                <h6 class="mb-0 fs-6 fw-semibold">Código de Barras</h6>
                                                <p class="mb-0 text-muted small">Al pie del comprobante</p>
                                            </div>
                                        </div>
                                        <div class="form-check form-switch form-switch-lg mb-0">
                                            <input type="checkbox" class="form-check-input" id="MostrarCodigoBarras" name="MostrarCodigoBarras" value="true" checked onchange="updatePreview()" />
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="card border-0 bg-soft-light">
                                <div class="card-body p-3">
                                    <div class="d-flex align-items-center justify-content-between">
                                        <div class="d-flex align-items-center gap-3">
                                            <div class="avatar-sm bg-soft-danger text-danger rounded-2 d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                                                <i class="ri-file-code-line"></i>
                                            </div>
                                            <div>
                                                <h6 class="mb-0 fs-6 fw-semibold">NCF y Tipo</h6>
                                                <p class="mb-0 text-muted small">Número de comprobante fiscal</p>
                                            </div>
                                        </div>
                                        <div class="form-check form-switch form-switch-lg mb-0">
                                            <input type="checkbox" class="form-check-input" id="MostrarNCF" name="MostrarNCF" value="false" onchange="updatePreview()" />
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="card border-0 bg-soft-light">
                                <div class="card-body p-3">
                                    <div class="d-flex align-items-center justify-content-between">
                                        <div class="d-flex align-items-center gap-3">
                                            <div class="avatar-sm bg-soft-info text-info rounded-2 d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                                                <i class="ri-percent-line"></i>
                                            </div>
                                            <div>
                                                <h6 class="mb-0 fs-6 fw-semibold">Desglose Impuestos</h6>
                                                <p class="mb-0 text-muted small">ITBIS y otros impuestos</p>
                                            </div>
                                        </div>
                                        <div class="form-check form-switch form-switch-lg mb-0">
                                            <input type="checkbox" class="form-check-input" id="MostrarImpuestos" name="MostrarImpuestos" value="true" checked onchange="updatePreview()" />
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- 3. Pie de Página -->
            <div class="card">
                <div class="card-body">
                    <div class="d-flex align-items-center mb-4">
                        <div class="avatar-sm bg-warning rounded-3 me-3">
                            <span class="avatar-title text-white fw-bold">3</span>
                        </div>
                        <div>
                            <h5 class="card-title mb-0">Pie de Página</h5>
                            <p class="text-muted mb-0 small">Mensaje final al pie de tus comprobantes</p>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label for="PiePagina" class="form-label fw-semibold">Mensaje Personalizado</label>
                        <textarea class="form-control" id="PiePagina" name="PiePagina" rows="3" maxlength="200" placeholder="Ej: ¡Gracias por su compra!" oninput="updateCharCounter(this); updatePreview();">¡Gracias por su compra!</textarea>
                        <div class="d-flex justify-content-end mt-2">
                            <span class="badge bg-soft-secondary text-secondary" id="charCounter">0 / 200 caracteres</span>
                        </div>
                    </div>

                    <div>
                        <label class="form-label fw-semibold d-block mb-3">Tamaño de Fuente del Pie</label>
                        <div class="btn-group" role="group">
                            <button type="button" class="btn btn-outline-secondary btn-sm" onclick="selectFontSize('small', this)">
                                <i class="ri-text-small me-1"></i> Pequeño
                            </button>
                            <button type="button" class="btn btn-outline-secondary btn-sm active" onclick="selectFontSize('medium', this)">
                                <i class="ri-text me-1"></i> Mediano
                            </button>
                            <button type="button" class="btn btn-outline-secondary btn-sm" onclick="selectFontSize('large', this)">
                                <i class="ri-text-big me-1"></i> Grande
                            </button>
                        </div>
                        <input type="hidden" name="TamanoFuentePie" value="medium" />
                    </div>
                </div>
            </div>

            <!-- Botones de Acción -->
            <div class="d-flex gap-2 justify-content-end mt-4">
                <button type="button" class="btn btn-light" onclick="history.back()">
                    <i class="ri-arrow-left-line me-1"></i> Cancelar
                </button>
                <button type="submit" class="btn btn-primary">
                    <i class="ri-save-line me-1"></i> Guardar Configuración
                </button>
            </div>
        </form>
    </div>

    <!-- Columna Derecha - Vista Previa -->
    <div class="col-xl-4">
        <!-- Vista Previa del Ticket -->
        <div class="card sticky-top" style="top: 1rem; z-index: 100;">
            <div class="card-header bg-soft-primary border-0">
                <div class="d-flex align-items-center justify-content-between">
                    <h6 class="card-title mb-0 text-primary">
                        <i class="ri-eye-line me-1"></i>
                        Vista Previa
                    </h6>
                    <span class="badge bg-primary-subtle text-primary" id="ticketTypeLabel">Térmica</span>
                </div>
            </div>
            <div class="card-body p-0">
                <div class="p-4 bg-secondary-subtle">
                    <div class="ticket-preview thermal mx-auto" id="ticketPreview">
                        <!-- Logo -->
                        <div class="ticket-logo" id="previewLogo">
                            <i class="ri-store-2-line fs-4"></i>
                        </div>

                        <!-- Empresa -->
                        <div class="ticket-company" id="previewCompany">AutoServer</div>
                        <div class="ticket-info">
                            RNC: 131-70383-6<br />
                            Santo Domingo, República Dominicana<br />
                            Tel: 809-555-1234
                        </div>

                        <!-- Separador -->
                        <div class="ticket-divider"></div>

                        <!-- Tipo de Factura -->
                        <div style="text-align: center; margin-bottom: 8px;">
                            <strong>FACTURA DE CONTADO</strong><br />
                            <span style="font-size: 0.7rem;">25/04/2026 14:30</span>
                        </div>

                        <!-- Separador -->
                        <div class="ticket-divider"></div>

                        <!-- Cliente -->
                        <div style="margin-bottom: 8px;">
                            <strong>Cliente:</strong> Víctor Delgado<br />
                            <span style="font-size: 0.7rem;">RNC: 402-3056188-9</span>
                        </div>

                        <!-- Separador -->
                        <div class="ticket-divider"></div>

                        <!-- Items -->
                        <div id="previewDescription">
                            <div class="ticket-row">
                                <span>Servicio de mantenimiento</span>
                                <span>1</span>
                            </div>
                            <div class="ticket-row">
                                <span class="text-muted">RD$5,500.00</span>
                            </div>
                            <div class="ticket-divider"></div>
                        </div>

                        <div class="ticket-row">
                            <span>Repuesto frenos</span>
                            <span>2</span>
                        </div>
                        <div class="ticket-row">
                            <span class="text-muted">RD$3,200.00 c/u</span>
                        </div>

                        <!-- Separador -->
                        <div class="ticket-divider"></div>

                        <!-- Totales e Impuestos -->
                        <div id="previewTaxes">
                            <div class="ticket-row">
                                <span class="text-muted">Subtotal:</span>
                                <span>RD$8,700.00</span>
                            </div>
                            <div class="ticket-row">
                                <span class="text-muted">ITBIS (18%):</span>
                                <span>RD$1,566.00</span>
                            </div>
                        </div>

                        <!-- Total -->
                        <div class="ticket-row total">
                            <span>TOTAL:</span>
                            <span>RD$10,266.00</span>
                        </div>

                        <!-- Código de Barras -->
                        <div id="previewBarcode" class="ticket-barcode"></div>

                        <!-- Pie de Página -->
                        <div class="ticket-footer" id="previewFooter">
                            <strong>¡Gracias por su compra!</strong><br />
                            <span style="font-size: 0.65rem;">www.autoserver.com.do</span>
                        </div>

                        <!-- NCF -->
                        <div id="previewNCF" style="display: none; margin-top: 8px; padding-top: 8px; border-top: 1px dashed #ccc; font-size: 0.65rem;">
                            NCF: E310000000001<br />
                            Tipo: 01 - Crédito Fiscal
                        </div>
                    </div>
                </div>
            </div>
            <div class="card-footer bg-soft-light border-0">
                <div class="d-flex align-items-center gap-2">
                    <i class="ri-information-line text-info"></i>
                    <small class="text-muted">La vista previa es una aproximación. El resultado final puede variar según la impresora.</small>
                </div>
            </div>
        </div>

        <!-- Resumen de Configuración -->
        <div class="card mt-3">
            <div class="card-body">
                <h6 class="card-title mb-3">
                    <i class="ri-check-double-line me-1 text-success"></i>
                    Estado de Configuración
                </h6>
                <ul class="list-group list-group-flush small">
                    <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                        <span><i class="ri-ticket-line me-2 text-primary"></i>Tipo de Ticket</span>
                        <span class="badge bg-primary-subtle text-primary" id="summaryTicketType">Térmica</span>
                    </li>
                    <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                        <span><i class="ri-image-line me-2 text-primary"></i>Logotipo</span>
                        <span class="badge bg-success-subtle text-success" id="summaryLogo">Activado</span>
                    </li>
                    <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                        <span><i class="ri-file-text-line me-2 text-success"></i>Descripción</span>
                        <span class="badge bg-success-subtle text-success" id="summaryDescription">Activado</span>
                    </li>
                    <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                        <span><i class="ri-barcode-line me-2 text-warning"></i>Código Barras</span>
                        <span class="badge bg-success-subtle text-success" id="summaryBarcode">Activado</span>
                    </li>
                    <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                        <span><i class="ri-percent-line me-2 text-info"></i>Impuestos</span>
                        <span class="badge bg-success-subtle text-success" id="summaryTaxes">Activado</span>
                    </li>
                </ul>
            </div>
        </div>
    </div>
</div>

<style>
    /* Radio Cards */
    .radio-card {
        cursor: pointer;
        display: block;
    }

    .radio-card .card {
        transition: all 0.2s ease;
    }

    .radio-card:hover .card {
        border-color: var(--bs-primary) !important;
        box-shadow: 0 0 0 3px rgba(var(--bs-primary-rgb), 0.1);
    }

    .radio-card.selected .card {
        border-color: var(--bs-primary) !important;
        background-color: rgba(var(--bs-primary-rgb), 0.05);
    }

    .radio-card.selected .card .display-4 {
        color: var(--bs-primary) !important;
    }

    /* Form Switch Large */
    .form-switch-lg .form-check-input {
        width: 3em;
        height: 1.5em;
        cursor: pointer;
    }

    /* Ticket Preview */
    .ticket-preview {
        background: #fff;
        border: 1px solid #e0e0e0;
        border-radius: 8px;
        padding: 16px;
        font-family: 'Courier New', monospace;
        font-size: 12px;
        line-height: 1.5;
        color: #000;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
        transition: all 0.3s ease;
    }

    .ticket-preview.thermal {
        max-width: 280px;
        font-size: 11px;
    }

    .ticket-preview.half {
        max-width: 350px;
        font-family: var(--bs-font-sans-serif);
        font-size: 13px;
    }

    .ticket-preview.letter {
        max-width: 400px;
        font-family: var(--bs-font-sans-serif);
        font-size: 14px;
    }

    .ticket-logo {
        width: 50px;
        height: 50px;
        background: #f5f5f5;
        border-radius: 6px;
        margin: 0 auto 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #999;
    }

    .ticket-company {
        font-weight: 700;
        font-size: 14px;
        text-align: center;
        margin-bottom: 4px;
    }

    .ticket-info {
        color: #666;
        font-size: 10px;
        text-align: center;
        margin-bottom: 12px;
    }

    .ticket-divider {
        border-top: 1px dashed #ccc;
        margin: 8px 0;
    }

    .ticket-row {
        display: flex;
        justify-content: space-between;
        margin-bottom: 4px;
    }

    .ticket-row.total {
        font-weight: 700;
        font-size: 14px;
        border-top: 1px solid #000;
        padding-top: 8px;
        margin-top: 8px;
    }

    .ticket-footer {
        text-align: center;
        margin-top: 12px;
        padding-top: 12px;
        border-top: 1px dashed #ccc;
        font-size: 11px;
    }

    .ticket-barcode {
        height: 35px;
        background: repeating-linear-gradient(
            90deg,
            #000 0px,
            #000 3px,
            #fff 3px,
            #fff 6px
        );
        margin: 8px 0;
        opacity: 0.8;
    }

    /* Badge Soft */
    .badge-soft-secondary {
        background-color: rgba(var(--bs-secondary-rgb), 0.1);
        color: var(--bs-secondary);
    }

    /* Transitions */
    .transition-all {
        transition: all 0.2s ease;
    }

    .hover-border-primary:hover {
        border-color: var(--bs-primary) !important;
    }
</style>

@section Scripts {
    <script>
        // Seleccionar tipo de ticket
        function selectTicketType(type, element) {
            // Remover selección de todas las cards
            document.querySelectorAll('.radio-card').forEach(card => {
                card.classList.remove('selected');
            });

            // Seleccionar la card clickeada
            element.classList.add('selected');
            element.querySelector('input').checked = true;

            // Actualizar clase del preview
            const preview = document.getElementById('ticketPreview');
            preview.className = 'ticket-preview ' + type;

            // Actualizar label
            const labels = {
                'thermal': 'Térmica',
                'half': 'Media Carta',
                'letter': 'Carta'
            };
            document.getElementById('ticketTypeLabel').textContent = labels[type];
            document.getElementById('summaryTicketType').textContent = labels[type];
        }

        // Actualizar vista previa
        function updatePreview() {
            // Logo
            const showLogo = document.getElementById('MostrarLogo').checked;
            document.getElementById('previewLogo').style.display = showLogo ? 'flex' : 'none';
            document.getElementById('summaryLogo').textContent = showLogo ? 'Activado' : 'Desactivado';
            document.getElementById('summaryLogo').className = showLogo ? 'badge bg-success-subtle text-success' : 'badge bg-secondary-subtle text-secondary';

            // Descripción
            const showDescription = document.getElementById('MostrarDescripcion').checked;
            document.getElementById('previewDescription').style.display = showDescription ? 'block' : 'none';
            document.getElementById('summaryDescription').textContent = showDescription ? 'Activado' : 'Desactivado';
            document.getElementById('summaryDescription').className = showDescription ? 'badge bg-success-subtle text-success' : 'badge bg-secondary-subtle text-secondary';

            // Código de barras
            const showBarcode = document.getElementById('MostrarCodigoBarras').checked;
            document.getElementById('previewBarcode').style.display = showBarcode ? 'block' : 'none';
            document.getElementById('summaryBarcode').textContent = showBarcode ? 'Activado' : 'Desactivado';
            document.getElementById('summaryBarcode').className = showBarcode ? 'badge bg-success-subtle text-success' : 'badge bg-secondary-subtle text-secondary';

            // Impuestos
            const showTaxes = document.getElementById('MostrarImpuestos').checked;
            document.getElementById('previewTaxes').style.display = showTaxes ? 'block' : 'none';
            document.getElementById('summaryTaxes').textContent = showTaxes ? 'Activado' : 'Desactivado';
            document.getElementById('summaryTaxes').className = showTaxes ? 'badge bg-success-subtle text-success' : 'badge bg-secondary-subtle text-secondary';

            // NCF
            const showNCF = document.getElementById('MostrarNCF').checked;
            document.getElementById('previewNCF').style.display = showNCF ? 'block' : 'none';
        }

        // Contador de caracteres
        function updateCharCounter(textarea) {
            const counter = document.getElementById('charCounter');
            const length = textarea.value.length;
            const max = textarea.getAttribute('maxlength');
            counter.textContent = length + ' / ' + max + ' caracteres';

            if (length > max * 0.9) {
                counter.classList.remove('bg-soft-secondary', 'text-secondary');
                counter.classList.add('bg-warning', 'text-dark');
            } else {
                counter.classList.remove('bg-warning', 'text-dark');
                counter.classList.add('bg-soft-secondary', 'text-secondary');
            }

            // Actualizar preview del pie
            document.getElementById('previewFooter').innerHTML = '<strong>' + (textarea.value || '¡Gracias por su compra!') + '</strong><br><span style="font-size: 0.65rem;">www.autoserver.com.do</span>';
        }

        // Seleccionar tamaño de fuente
        function selectFontSize(size, button) {
            document.querySelectorAll('.btn-group .btn').forEach(btn => {
                btn.classList.remove('active');
            });
            button.classList.add('active');
            document.querySelector('input[name="TamanoFuentePie"]').value = size;

            // Actualizar tamaño del preview
            const footer = document.getElementById('previewFooter');
            footer.style.fontSize = size === 'small' ? '0.65rem' : size === 'large' ? '0.8rem' : '0.7rem';
        }

        // Inicializar al cargar
        document.addEventListener('DOMContentLoaded', function() {
            const textarea = document.getElementById('PiePagina');
            if (textarea) {
                updateCharCounter(textarea);
            }
            updatePreview();
        });
    </script>
}
