@model Facturapro.Models.Entities.ConfiguracionEmpresa

@{
    ViewData["Title"] = "Configuración DGII";
    ViewData["PageDescription"] = "Facturación Electrónica - Configura tu empresa para emitir e-CF";
}

<!-- Page Header -->
<div class="page-header-title">
    <h4 class="page-title">
        <i class="ri-bank-card-line me-1"></i>
        Configuración DGII - Facturación Electrónica
    </h4>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="row">
        <div class="col-12">
            <div class="alert alert-success border-0 alert-dismissible fade show" role="alert">
                <i class="ri-checkbox-circle-line me-2"></i>
                @TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        </div>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="row">
        <div class="col-12">
            <div class="alert alert-danger border-0 alert-dismissible fade show" role="alert">
                <i class="ri-error-warning-line me-2"></i>
                @TempData["ErrorMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        </div>
    </div>
}

<!-- Status Cards Row -->
<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-body">
                <div class="row g-3">
                    <!-- Ambiente -->
                    <div class="col-md-3 col-sm-6">
                        <div class="card bg-soft-primary border-0 mb-0">
                            <div class="card-body text-center p-3">
                                <i class="ri-flask-line display-4 text-primary mb-2"></i>
                                <h6 class="text-muted mb-1">Ambiente</h6>
                                <h5 class="mb-0 fw-semibold">@(Model.ModoPruebas ? "Pruebas" : "Producción")</h5>
                            </div>
                        </div>
                    </div>

                    <!-- RNC -->
                    <div class="col-md-3 col-sm-6">
                        <div class="card bg-soft-info border-0 mb-0">
                            <div class="card-body text-center p-3">
                                <i class="ri-building-2-line display-4 text-info mb-2"></i>
                                <h6 class="text-muted mb-1">RNC Emisor</h6>
                                <h5 class="mb-0 fw-semibold">@(string.IsNullOrEmpty(Model.RNCEmisor) ? "Sin configurar" : Model.RNCEmisor)</h5>
                            </div>
                        </div>
                    </div>

                    <!-- Certificado -->
                    <div class="col-md-3 col-sm-6">
                        <div class="card bg-soft-success border-0 mb-0">
                            <div class="card-body text-center p-3">
                                <i class="ri-shield-check-line display-4 text-success mb-2"></i>
                                <h6 class="text-muted mb-1">Certificado</h6>
                                <h5 class="mb-0 fw-semibold">
                                    @if (!string.IsNullOrEmpty(Model.HuellaCertificado))
                                    {
                                        <span class="text-success">✓ Activo</span>
                                    }
                                    else
                                    {
                                        <span class="text-danger">✗ Pendiente</span>
                                    }
                                </h5>
                            </div>
                        </div>
                    </div>

                    <!-- Servicios DGII -->
                    <div class="col-md-3 col-sm-6">
                        <div class="card bg-soft-warning border-0 mb-0">
                            <div class="card-body text-center p-3">
                                <i class="ri-server-line display-4 text-warning mb-2"></i>
                                <h6 class="text-muted mb-1">Servicios DGII</h6>
                                <h5 class="mb-0 fw-semibold">
                                    <span id="servicio-status" class="badge badge-soft-warning">
                                        <i class="ri-loader-4-line ri-spin me-1"></i> Verificando...
                                    </span>
                                </h5>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <!-- Columna Izquierda - Formularios -->
    <div class="col-xl-6">

        <!-- 1. Datos del Emisor -->
        <div class="card">
            <div class="card-body">
                <div class="d-flex align-items-center mb-4">
                    <div class="avatar-sm bg-primary rounded-3 me-3">
                        <span class="avatar-title text-white fw-bold">1</span>
                    </div>
                    <div>
                        <h5 class="card-title mb-0">Datos del Emisor</h5>
                        <p class="text-muted mb-0 small">Información fiscal de tu empresa</p>
                    </div>
                </div>

                <form asp-action="GuardarConfiguracion" method="post">
                    @Html.AntiForgeryToken()

                    <div class="row g-3">
                        <div class="col-12">
                            <label asp-for="RNCEmisor" class="form-label">RNC/DGII Emisor <span class="text-danger">*</span></label>
                            <input asp-for="RNCEmisor" class="form-control" placeholder="Ej: 131703836" maxlength="11" />
                            <span asp-validation-for="RNCEmisor" class="text-danger small"></span>
                            <small class="text-muted">11 dígitos sin guiones ni espacios</small>
                        </div>

                        <div class="col-12">
                            <label asp-for="RazonSocialEmisor" class="form-label">Razón Social <span class="text-danger">*</span></label>
                            <input asp-for="RazonSocialEmisor" class="form-control" placeholder="Nombre o razón social" />
                            <span asp-validation-for="RazonSocialEmisor" class="text-danger small"></span>
                        </div>

                        <div class="col-12">
                            <label asp-for="NombreComercial" class="form-label">Nombre Comercial</label>
                            <input asp-for="NombreComercial" class="form-control" placeholder="Nombre que aparece en la factura" />
                        </div>

                        <div class="col-12">
                            <label asp-for="DireccionEmisor" class="form-label">Dirección <span class="text-danger">*</span></label>
                            <input asp-for="DireccionEmisor" class="form-control" placeholder="Calle, número, sector..." />
                            <span asp-validation-for="DireccionEmisor" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Municipio" class="form-label">Municipio</label>
                            <input asp-for="Municipio" class="form-control" />
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Provincia" class="form-label">Provincia</label>
                            <input asp-for="Provincia" class="form-control" />
                        </div>

                        <div class="col-md-6">
                            <label asp-for="TelefonoEmisor" class="form-label">Teléfono</label>
                            <input asp-for="TelefonoEmisor" class="form-control" placeholder="809-555-0000" />
                        </div>

                        <div class="col-md-6">
                            <label asp-for="CorreoEmisor" class="form-label">Correo Electrónico</label>
                            <input asp-for="CorreoEmisor" type="email" class="form-control" placeholder="contacto@empresa.com" />
                        </div>
                    </div>

                    <div class="mt-4">
                        <button type="submit" class="btn btn-primary w-100">
                            <i class="ri-save-line me-1"></i> Guardar Datos de Empresa
                        </button>
                    </div>
                </form>
            </div>
        </div>

        <!-- 3. Modo de Operación -->
        <div class="card">
            <div class="card-body">
                <div class="d-flex align-items-center mb-4">
                    <div class="avatar-sm bg-warning rounded-3 me-3">
                        <span class="avatar-title text-white fw-bold">3</span>
                    </div>
                    <div>
                        <h5 class="card-title mb-0">Modo de Operación</h5>
                        <p class="text-muted mb-0 small">Selecciona el ambiente de trabajo</p>
                    </div>
                </div>

                <form asp-action="CambiarModo" method="post">
                    @Html.AntiForgeryToken()

                    <div class="form-check form-switch form-switch-lg mb-3">
                        <input type="checkbox" class="form-check-input" id="modoPruebas" name="modoPruebas"
                               value="true" @(Model.ModoPruebas ? "checked" : "") onchange="this.form.submit()" />
                        <label class="form-check-label fw-semibold" for="modoPruebas">
                            @(Model.ModoPruebas ? "🧪 Modo Pruebas (Sandbox)" : "🚀 Modo Producción")
                        </label>
                    </div>

                    <div class="alert @(Model.ModoPruebas ? "alert-warning" : "alert-success") mb-0">
                        <i class="ri-information-line me-2"></i>
                        @if (Model.ModoPruebas)
                        {
                            <span><strong>Ambiente de Pruebas:</strong> Los comprobantes se envían al ambiente de certificación de la DGII. No tienen validez fiscal.</span>
                        }
                        else
                        {
                            <span><strong>Ambiente de Producción:</strong> Los comprobantes son reales y tienen validez fiscal ante la DGII.</span>
                        }
                    </div>
                </form>
            </div>
        </div>

        <!-- 5. Configuración de Impuestos -->
        <div class="card">
            <div class="card-body">
                <div class="d-flex align-items-center mb-4">
                    <div class="avatar-sm bg-info rounded-3 me-3">
                        <span class="avatar-title text-white fw-bold">5</span>
                    </div>
                    <div>
                        <h5 class="card-title mb-0">Configuración de Impuestos</h5>
                        <p class="text-muted mb-0 small">Parámetros fiscales por defecto</p>
                    </div>
                </div>

                <form asp-action="GuardarImpuestos" method="post">
                    @Html.AntiForgeryToken()

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="ITBISPorDefecto" class="form-label">ITBIS por Defecto (%)</label>
                            <input asp-for="ITBISPorDefecto" type="number" step="0.01" class="form-control" />
                            <small class="text-muted">General: 18%</small>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="TipoIngresosPorDefecto" class="form-label">Tipo de Ingresos</label>
                            <select asp-for="TipoIngresosPorDefecto" class="form-select">
                                <option value="01">01 - Operaciones</option>
                                <option value="02">02 - Financieros</option>
                                <option value="03">03 - Extraordinarios</option>
                                <option value="04">04 - Arrendamientos</option>
                                <option value="05">05 - Venta de Activo</option>
                                <option value="06">06 - Otros</option>
                            </select>
                        </div>
                    </div>

                    <div class="mt-4">
                        <button type="submit" class="btn btn-primary w-100">
                            <i class="ri-percent-line me-1"></i> Guardar Impuestos
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Columna Derecha - Certificado y Estado -->
    <div class="col-xl-6">

        <!-- 2. Certificado Digital -->
        <div class="card">
            <div class="card-body">
                <div class="d-flex align-items-center mb-4">
                    <div class="avatar-sm bg-success rounded-3 me-3">
                        <span class="avatar-title text-white fw-bold">2</span>
                    </div>
                    <div>
                        <h5 class="card-title mb-0">Certificado Digital</h5>
                        <p class="text-muted mb-0 small">Certificado para firma electrónica</p>
                    </div>
                </div>

                <div class="alert alert-info border-0 mb-4">
                    <div class="d-flex">
                        <i class="ri-information-fill fs-3 me-3"></i>
                        <div>
                            <strong>Requisitos del Certificado:</strong>
                            <ul class="mb-0 mt-2 small">
                                <li>Formato .PFX o .P12</li>
                                <li>Emitido por entidad autorizada por INDOTEL</li>
                                <li>Debe contener clave privada</li>
                            </ul>
                        </div>
                    </div>
                </div>

                <form asp-action="SubirCertificado" method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label class="form-label">Archivo de Certificado <span class="text-danger">*</span></label>
                        <input type="file" name="certificado" class="form-control" accept=".pfx,.p12" required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Contraseña del Certificado <span class="text-danger">*</span></label>
                        <input type="password" name="passwordCertificado" class="form-control" required />
                    </div>

                    @if (!string.IsNullOrEmpty(Model.HuellaCertificado))
                    {
                        <div class="card bg-soft-success border-0 mb-3">
                            <div class="card-body">
                                <h6 class="card-title text-success mb-2">
                                    <i class="ri-shield-check-line me-1"></i> Certificado Actual
                                </h6>
                                <div class="small">
                                    <div class="mb-2">
                                        <strong>Huella:</strong>
                                        <code class="ms-2 bg-white px-2 py-1 rounded">@Model.HuellaCertificado</code>
                                    </div>
                                    @if (Model.FechaVencimientoCertificado.HasValue)
                                    {
                                        <div>
                                            <strong>Vencimiento:</strong> @Model.FechaVencimientoCertificado.Value.ToString("dd/MM/yyyy")
                                            @if (Model.FechaVencimientoCertificado.Value < DateTime.Now)
                                            {
                                                <span class="badge bg-danger ms-2">Expirado</span>
                                            }
                                            else if (Model.FechaVencimientoCertificado.Value < DateTime.Now.AddDays(30))
                                            {
                                                <span class="badge bg-warning ms-2">
                                                    Por vencer (@((Model.FechaVencimientoCertificado.Value - DateTime.Now).Days) días)
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-success ms-2">Vigente</span>
                                            }
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    }

                    <div class="d-grid">
                        <button type="submit" class="btn btn-success">
                            <i class="ri-upload-cloud-line me-1"></i>
                            @(string.IsNullOrEmpty(Model.HuellaCertificado) ? "Subir Certificado" : "Actualizar Certificado")
                        </button>
                    </div>
                </form>
            </div>
        </div>

        <!-- 4. Estado de Conexión API -->
        <div class="card">
            <div class="card-body">
                <div class="d-flex align-items-center mb-4">
                    <div class="avatar-sm bg-dark rounded-3 me-3">
                        <span class="avatar-title text-white fw-bold">4</span>
                    </div>
                    <div>
                        <h5 class="card-title mb-0">Estado API DGII</h5>
                        <p class="text-muted mb-0 small">Verifica la conectividad con la DGII</p>
                    </div>
                </div>

                <div class="card bg-soft-light border-0 mb-3">
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-sm table-borderless mb-0">
                                <tbody>
                                    <tr>
                                        <td class="text-muted">Ambiente:</td>
                                        <td class="fw-semibold text-end">@(Model.ModoPruebas ? "TesteCF (Pruebas)" : "eCF (Producción)")</td>
                                    </tr>
                                    <tr>
                                        <td class="text-muted">RNC Configurado:</td>
                                        <td class="fw-semibold text-end">@Model.RNCEmisor</td>
                                    </tr>
                                    <tr>
                                        <td class="text-muted">Certificado:</td>
                                        <td class="text-end">
                                            @if (!string.IsNullOrEmpty(Model.HuellaCertificado))
                                            {
                                                <span class="badge bg-success">Configurado</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-danger">No Configurado</span>
                                            }
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <button type="button" class="btn btn-secondary w-100 mb-3" onclick="verificarServicios()">
                    <i class="ri-refresh-line me-1"></i> Verificar Conexión
                </button>

                <div class="card bg-soft-primary border-0">
                    <div class="card-body p-3">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <h6 class="card-title text-primary mb-0">
                                <i class="ri-link me-1"></i> Endpoints API DGII
                            </h6>
                            <form asp-action="CambiarModo" method="post" class="m-0">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="modoPruebas" value="@(Model.ModoPruebas ? "false" : "true")" />
                                <button type="submit" class="btn btn-sm @(Model.ModoPruebas ? "btn-outline-danger" : "btn-outline-warning") py-0" style="font-size: 11px;">
                                    <i class="ri-refresh-line me-1"></i> Cambiar a @(Model.ModoPruebas ? "Producción" : "Pruebas")
                                </button>
                            </form>
                        </div>
                        <ul class="list-unstyled mb-0 small">
                            <li class="mb-1">
                                <i class="ri-flask-line text-warning me-1"></i>
                                <strong>Test:</strong> https://ecf.dgii.gov.do/testecf/
                            </li>
                            <li class="mb-1">
                                <i class="ri-shield-keyhole-line text-info me-1"></i>
                                <strong>Certificación:</strong> https://ecf.dgii.gov.do/certecf/
                            </li>
                            <li>
                                <i class="ri-bank-line text-success me-1"></i>
                                <strong>Producción:</strong> https://ecf.dgii.gov.do/ecf/
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        async function verificarServicios() {
            const statusSpan = document.getElementById('servicio-status');
            statusSpan.innerHTML = '<i class="ri-loader-4-line ri-spin me-1"></i> Verificando...';
            statusSpan.className = 'badge badge-soft-warning';

            try {
                const response = await fetch('/Configuracion/VerificarServiciosDGII');
                const data = await response.json();

                if (data.disponible) {
                    statusSpan.innerHTML = '<i class="ri-checkbox-circle-line me-1"></i> Disponible';
                    statusSpan.className = 'badge badge-soft-success';
                } else {
                    statusSpan.innerHTML = '<i class="ri-error-warning-line me-1"></i> No Disponible';
                    statusSpan.className = 'badge badge-soft-danger';
                }
            } catch (error) {
                statusSpan.innerHTML = '<i class="ri-error-warning-line me-1"></i> Error';
                statusSpan.className = 'badge badge-soft-danger';
            }
        }

        // Verificar al cargar la página
        document.addEventListener('DOMContentLoaded', verificarServicios);
    </script>
}
