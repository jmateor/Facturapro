@{
    ViewData["Title"] = "Respaldo de Datos";
}

<!-- Page Header -->
<div class="page-header-title">
    <h4 class="page-title">
        <i class="ri-database-2-line me-1"></i>
        Respaldo de Datos
    </h4>
    <p class="text-muted">Exporte, proteja y restaure la información de su negocio</p>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="row">
        <div class="col-12">
            <div class="alert alert-success border-0 alert-dismissible fade show" role="alert">
                <i class="ri-checkbox-circle-line me-2"></i>
                @TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        </div>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="row">
        <div class="col-12">
            <div class="alert alert-danger border-0 alert-dismissible fade show" role="alert">
                <i class="ri-error-warning-line me-2"></i>
                @TempData["ErrorMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        </div>
    </div>
}

<div class="row">
    <!-- Columna Izquierda - Opciones de Respaldo -->
    <div class="col-xl-8">

        <!-- 1. Crear Respaldo -->
        <div class="card">
            <div class="card-body">
                <div class="d-flex align-items-center mb-4">
                    <div class="avatar-sm bg-primary rounded-3 me-3">
                        <span class="avatar-title text-white fw-bold">1</span>
                    </div>
                    <div>
                        <h5 class="card-title mb-0">Crear Respaldo</h5>
                        <p class="text-muted mb-0 small">Exporte una copia de seguridad de su base de datos</p>
                    </div>
                </div>

                <div class="row g-3">
                    <div class="col-md-6">
                        <div class="card border border-primary bg-soft-primary mb-0 h-100" style="cursor: pointer; transition: all 0.2s;" onmouseover="this.style.transform='translateY(-2px)'; this.style.boxShadow='0 0.5rem 1rem rgba(0,0,0,0.1)'" onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='none'">
                            <div class="card-body text-center p-4">
                                <div class="mb-3">
                                    <i class="ri-database-export-line display-4 text-primary"></i>
                                </div>
                                <h6 class="fw-semibold mb-2">Respaldo Completo</h6>
                                <p class="small text-muted mb-3">
                                    Exporte toda la base de datos incluyendo productos, clientes, facturas y configuración.
                                </p>
                                <button type="button" class="btn btn-primary btn-sm" onclick="crearRespaldoCompleto()">
                                    <i class="ri-download-line me-1"></i> Descargar
                                </button>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="card border border-info bg-soft-info mb-0 h-100" style="cursor: pointer; transition: all 0.2s;" onmouseover="this.style.transform='translateY(-2px)'; this.style.boxShadow='0 0.5rem 1rem rgba(0,0,0,0.1)'" onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='none'">
                            <div class="card-body text-center p-4">
                                <div class="mb-3">
                                    <i class="ri-excel-line display-4 text-info"></i>
                                </div>
                                <h6 class="fw-semibold mb-2">Solo Productos</h6>
                                <p class="small text-muted mb-3">
                                    Exporte únicamente el catálogo de productos en formato Excel.
                                </p>
                                <button type="button" class="btn btn-info btn-sm" onclick="exportarProductos()">
                                    <i class="ri-download-line me-1"></i> Exportar
                                </button>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="alert alert-info border-0 mt-4 mb-0">
                    <i class="ri-information-line me-2"></i>
                    <span>Los respaldos completos se generan en formato <strong>.bak</strong> compatible con SQL Server. Guarde el archivo en un lugar seguro.</span>
                </div>
            </div>
        </div>

        <!-- 2. Restaurar Datos -->
        <div class="card">
            <div class="card-body">
                <div class="d-flex align-items-center mb-4">
                    <div class="avatar-sm bg-warning rounded-3 me-3">
                        <span class="avatar-title text-white fw-bold">2</span>
                    </div>
                    <div>
                        <h5 class="card-title mb-0">Restaurar Datos</h5>
                        <p class="text-muted mb-0 small">Recupere su base de datos desde un respaldo anterior</p>
                    </div>
                </div>

                <div class="alert alert-warning border-0 mb-4">
                    <div class="d-flex align-items-start">
                        <i class="ri-alert-fill fs-4 me-2 text-warning"></i>
                        <div>
                            <strong>Advertencia Importante:</strong>
                            <p class="mb-0 small mt-1">
                                Esta acción reemplazará <strong>todos los datos actuales</strong> de la base de datos.
                                El proceso es irreversible. Se recomienda crear un respaldo antes de continuar.
                            </p>
                        </div>
                    </div>
                </div>

                <form id="formRestaurar" enctype="multipart/form-data">
                    <div class="mb-4">
                        <label class="form-label fw-semibold">
                            <i class="ri-file-upload-line me-1"></i>
                            Archivo de Respaldo (.bak)
                        </label>
                        <input type="file"
                               class="form-control form-control-lg"
                               id="archivoRespaldo"
                               name="archivoRespaldo"
                               accept=".bak"
                               onchange="validarArchivo(this)" />
                        <small class="text-muted">Seleccione el archivo de respaldo generado previamente</small>
                        <div id="archivoInfo" class="mt-2" style="display: none;">
                            <div class="alert alert-success border-0 py-2">
                                <i class="ri-file-check-line me-1"></i>
                                <span id="archivoNombre"></span>
                            </div>
                        </div>
                    </div>

                    <div class="form-check mb-4">
                        <input class="form-check-input" type="checkbox" id="confirmarRestauracion" />
                        <label class="form-check-label" for="confirmarRestauracion">
                            Confirmo que he creado un respaldo de los datos actuales y deseo continuar con la restauración.
                        </label>
                    </div>

                    <button type="button"
                            class="btn btn-warning"
                            id="btnRestaurar"
                            disabled
                            onclick="confirmarRestauracion()">
                        <i class="ri-upload-cloud-line me-1"></i>
                        Restaurar Base de Datos
                    </button>
                </form>
            </div>
        </div>

        <!-- 3. Respaldos Automáticos -->
        <div class="card">
            <div class="card-body">
                <div class="d-flex align-items-center mb-4">
                    <div class="avatar-sm bg-success rounded-3 me-3">
                        <span class="avatar-title text-white fw-bold">3</span>
                    </div>
                    <div>
                        <h5 class="card-title mb-0">Respaldos Automáticos</h5>
                        <p class="text-muted mb-0 small">Configure la frecuencia de respaldos automáticos</p>
                    </div>
                </div>

                <div class="form-check form-switch form-switch-lg mb-3">
                    <input type="checkbox" class="form-check-input" id="respaldosAutomaticos" onchange="toggleFrecuencia()" />
                    <label class="form-check-label fw-semibold" for="respaldosAutomaticos">
                        <i class="ri-calendar-check-line me-1"></i> Activar respaldos automáticos
                    </label>
                </div>

                <div id="frecuenciaOptions" style="display: none;">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Frecuencia</label>
                            <select class="form-select" id="frecuenciaSelect">
                                <option value="diario">Diario</option>
                                <option value="semanal" selected>Semanal</option>
                                <option value="mensual">Mensual</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Hora</label>
                            <input type="time" class="form-control" value="02:00" />
                        </div>
                    </div>
                    <div class="alert alert-success border-0 mt-3 mb-0">
                        <i class="ri-time-line me-2"></i>
                        <span>Los respaldos se crearán automáticamente en la carpeta <strong>~/App_Data/Backups/</strong></span>
                    </div>
                </div>
            </div>
        </div>

    </div>

    <!-- Columna Derecha - Información y Estado -->
    <div class="col-xl-4">

        <!-- Estado del Sistema -->
        <div class="card">
            <div class="card-body">
                <h6 class="card-title mb-3">
                    <i class="ri-hard-drive-2-line me-1 text-primary"></i>
                    Estado del Sistema
                </h6>

                <div class="mb-3">
                    <div class="d-flex justify-content-between mb-1">
                        <span class="text-muted small">Espacio en disco</span>
                        <span class="fw-semibold small">45 GB / 100 GB</span>
                    </div>
                    <div class="progress" style="height: 8px;">
                        <div class="progress-bar bg-success" role="progressbar" style="width: 45%"></div>
                    </div>
                </div>

                <div class="mb-3">
                    <div class="d-flex justify-content-between mb-1">
                        <span class="text-muted small">Tamaño de la BD</span>
                        <span class="fw-semibold small">12.5 MB</span>
                    </div>
                    <div class="progress" style="height: 8px;">
                        <div class="progress-bar bg-primary" role="progressbar" style="width: 15%"></div>
                    </div>
                </div>

                <div class="mb-0">
                    <div class="d-flex justify-content-between mb-1">
                        <span class="text-muted small">Último respaldo</span>
                        <span class="fw-semibold small">Hace 7 días</span>
                    </div>
                    <div class="progress" style="height: 8px;">
                        <div class="progress-bar bg-warning" role="progressbar" style="width: 70%"></div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Últimos Respaldos -->
        <div class="card">
            <div class="card-body">
                <h6 class="card-title mb-3">
                    <i class="ri-history-line me-1 text-info"></i>
                    Últimos Respaldos
                </h6>

                <div class="list-group list-group-flush">
                    <div class="list-group-item px-0 py-2">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <i class="ri-file-zip-line me-2 text-primary"></i>
                                <span class="fw-medium small">backup_20260420.bak</span>
                            </div>
                            <span class="badge bg-soft-primary text-primary">2.3 MB</span>
                        </div>
                        <div class="mt-1">
                            <small class="text-muted">
                                <i class="ri-time-line me-1"></i>20 Abr 2026 - 02:00 AM
                            </small>
                        </div>
                    </div>

                    <div class="list-group-item px-0 py-2">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <i class="ri-file-zip-line me-2 text-primary"></i>
                                <span class="fw-medium small">backup_20260413.bak</span>
                            </div>
                            <span class="badge bg-soft-primary text-primary">2.1 MB</span>
                        </div>
                        <div class="mt-1">
                            <small class="text-muted">
                                <i class="ri-time-line me-1"></i>13 Abr 2026 - 02:00 AM
                            </small>
                        </div>
                    </div>

                    <div class="list-group-item px-0 py-2">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <i class="ri-file-zip-line me-2 text-primary"></i>
                                <span class="fw-medium small">backup_20260406.bak</span>
                            </div>
                            <span class="badge bg-soft-primary text-primary">2.0 MB</span>
                        </div>
                        <div class="mt-1">
                            <small class="text-muted">
                                <i class="ri-time-line me-1"></i>06 Abr 2026 - 02:00 AM
                            </small>
                        </div>
                    </div>
                </div>

                <div class="mt-3 text-center">
                    <button type="button" class="btn btn-soft-primary btn-sm">
                        <i class="ri-folder-open-line me-1"></i> Ver todos
                    </button>
                </div>
            </div>
        </div>

        <!-- Recomendaciones -->
        <div class="card bg-soft-warning border-0">
            <div class="card-body">
                <h6 class="card-title text-warning fw-semibold mb-3">
                    <i class="ri-lightbulb-line me-1"></i>
                    Recomendaciones
                </h6>
                <ul class="small text-muted mb-0" style="padding-left: 1.2rem;">
                    <li class="mb-2">Cree respaldos antes de realizar actualizaciones del sistema.</li>
                    <li class="mb-2">Almacene copias en servicios en la nube (Google Drive, OneDrive).</li>
                    <li class="mb-2">Mantenga al menos 3 copias de seguridad recientes.</li>
                    <li class="mb-0">Verifique periódicamente que los archivos no estén corruptos.</li>
                </ul>
            </div>
        </div>

        <!-- Soporte -->
        <div class="card bg-soft-success border-0">
            <div class="card-body text-center">
                <i class="ri-customer-service-2-line display-4 text-success mb-2"></i>
                <h6 class="fw-semibold mb-1">¿Necesitas Ayuda?</h6>
                <p class="small text-muted mb-2">
                    Nuestro equipo de soporte está disponible para ayudarte.
                </p>
                <a href="#" class="btn btn-success btn-sm">
                    <i class="ri-message-line me-1"></i> Contactar Soporte
                </a>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    <script>
        // Validar archivo seleccionado
        function validarArchivo(input) {
            const file = input.files[0];
            const archivoInfo = document.getElementById('archivoInfo');
            const archivoNombre = document.getElementById('archivoNombre');
            const btnRestaurar = document.getElementById('btnRestaurar');
            const checkbox = document.getElementById('confirmarRestauracion');

            if (file) {
                if (!file.name.endsWith('.bak')) {
                    mostrarNotificacion('El archivo debe tener extensión .bak', 'danger');
                    input.value = '';
                    archivoInfo.style.display = 'none';
                    return;
                }

                const sizeMB = (file.size / (1024 * 1024)).toFixed(2);
                archivoNombre.textContent = `${file.name} (${sizeMB} MB)`;
                archivoInfo.style.display = 'block';

                // Habilitar botón si el checkbox está marcado
                btnRestaurar.disabled = !checkbox.checked;
            } else {
                archivoInfo.style.display = 'none';
                btnRestaurar.disabled = true;
            }
        }

        // Toggle checkbox de confirmación
        document.getElementById('confirmarRestauracion')?.addEventListener('change', function() {
            const btnRestaurar = document.getElementById('btnRestaurar');
            const archivoInput = document.getElementById('archivoRespaldo');
            btnRestaurar.disabled = !this.checked || !archivoInput.files[0];
        });

        // Toggle frecuencia de respaldos
        function toggleFrecuencia() {
            const checkbox = document.getElementById('respaldosAutomaticos');
            const opciones = document.getElementById('frecuenciaOptions');
            opciones.style.display = checkbox.checked ? 'block' : 'none';
        }

        // Crear respaldo completo
        function crearRespaldoCompleto() {
            if (confirm('¿Está seguro de crear un respaldo completo de la base de datos?\n\nEl proceso puede tardar unos segundos.')) {
                mostrarNotificacion('Iniciando respaldo...', 'info');

                // Simulación - reemplazar con llamada real al backend
                setTimeout(() => {
                    mostrarNotificacion('Respaldo creado exitosamente. La descarga comenzará en breve.', 'success');
                }, 2000);
            }
        }

        // Exportar productos a Excel
        function exportarProductos() {
            mostrarNotificacion('Preparando exportación...', 'info');

            // Redirigir a la acción de exportar productos
            window.location.href = '/Productos/Exportar';
        }

        // Confirmar restauración
        function confirmarRestauracion() {
            const archivo = document.getElementById('archivoRespaldo').files[0];

            if (!archivo) {
                mostrarNotificacion('Seleccione un archivo de respaldo', 'danger');
                return;
            }

            if (confirm('⚠️ ADVERTENCIA ⚠️\n\n¿Está SEGURO que desea restaurar la base de datos?\n\n• Todos los datos actuales se perderán\n• Esta acción es IRREVERSIBLE\n• Se creará un respaldo automático antes de continuar')) {
                mostrarNotificacion('Iniciando proceso de restauración...', 'warning');

                // Simulación - reemplazar con llamada real al backend
                setTimeout(() => {
                    mostrarNotificacion('Restauración completada exitosamente', 'success');
                }, 5000);
            }
        }

        // Utilidad para notificaciones
        function mostrarNotificacion(mensaje, tipo) {
            const alertHtml = `
                <div class="alert alert-${tipo} alert-dismissible fade show position-fixed"
                     style="top: 80px; right: 20px; z-index: 9999; min-width: 300px;"
                     role="alert">
                    <i class="ri-${tipo === 'success' ? 'check-double' : tipo === 'danger' ? 'error-warning' : 'information'}-line me-1"></i>
                    ${mensaje}
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            `;
            document.body.insertAdjacentHTML('beforeend', alertHtml);
            setTimeout(() => {
                const alert = document.querySelector('.alert-dismissible:last-child');
                if (alert) alert.remove();
            }, 4000);
        }

        // Inicializar
        document.addEventListener('DOMContentLoaded', function() {
            toggleFrecuencia();
        });
    </script>
}
