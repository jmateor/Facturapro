@model IEnumerable<Facturapro.Models.ApplicationUser>
@using Microsoft.AspNetCore.Identity
@inject UserManager<Facturapro.Models.ApplicationUser> UserManager
@{
    ViewData["Title"] = "Usuarios y Permisos";
    var usuarios = Model?.ToList() ?? new List<Facturapro.Models.ApplicationUser>();
    var currentUser = await UserManager.GetUserAsync(User);
    var esAdmin = currentUser != null && currentUser.Rol == "Admin";
    var userRole = currentUser?.Rol ?? "No autenticado";
}

<style>
    .avatar-sm { height: 40px; width: 40px; font-size: 16px; }
    .bg-purple { background-color: #727cf5; }
    .badge-soft-primary { background-color: rgba(114, 124, 245, 0.1); color: #727cf5; }
    .badge-soft-warning { background-color: rgba(255, 188, 0, 0.1); color: #ffbc00; }
    .badge-soft-info { background-color: rgba(57, 175, 209, 0.1); color: #39afd1; }
    .badge-soft-success { background-color: rgba(10, 207, 151, 0.1); color: #0acf97; }
    
    /* Switches Premium */
    .form-switch .form-check-input { width: 2.5em; height: 1.25em; cursor: pointer; }
    .permission-card { transition: all 0.2s ease; border: 1px solid #eee; }
    .permission-card:hover { border-color: #727cf5; background-color: rgba(114, 124, 245, 0.02); }
</style>

<!-- Page Header -->
<div class="page-header-title mb-4">
    <div class="d-flex align-items-center justify-content-between">
        <div>
            <h4 class="page-title mb-0">
                <i class="ri-team-line me-2 text-primary"></i>
                Usuarios y Permisos
            </h4>
            <p class="text-muted mb-0">Gestione accesos y capacidades específicas por usuario</p>
        </div>
        @if (esAdmin)
        {
            <button class="btn btn-primary shadow-sm" data-bs-toggle="modal" data-bs-target="#NuevoUsuarioModal">
                <i class="ri-user-add-line me-1"></i> Nuevo Usuario
            </button>
        }
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success border-0 shadow-sm alert-dismissible fade show" role="alert">
        <i class="ri-checkbox-circle-line me-2"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (!esAdmin)
{
    <div class="alert alert-warning border-0 shadow-sm" role="alert">
        <i class="ri-alert-line me-2"></i>
        <strong>Acceso Restringido:</strong> No tienes permisos de administrador.
        <br />
        <small>Usuario actual: @currentUser?.Email | Rol: @userRole</small>
        <br />
        <small class="text-muted">Para crear usuarios necesitas iniciar sesión con una cuenta Admin (josemateo3148@gmail.com)</small>
    </div>
}

<div class="row">
    <!-- Lista de Usuarios -->
    <div class="col-xl-8">
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="bg-light">
                            <tr>
                                <th class="ps-4">Usuario</th>
                                <th>Rol</th>
                                <th>Estado</th>
                                <th>Registro</th>
                                <th class="text-end pe-4">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var usuario in usuarios)
                            {
                                var rol = usuario.Rol ?? "Usuario";
                                var inicial = (usuario.Nombre ?? usuario.Email ?? "U")[0].ToString().ToUpper();
                                
                                <tr>
                                    <td class="ps-4">
                                        <div class="d-flex align-items-center gap-3">
                                            <div class="avatar-sm bg-primary rounded-circle d-flex align-items-center justify-content-center text-white fw-bold">
                                                @inicial
                                            </div>
                                            <div>
                                                <h6 class="mb-0 fw-semibold">@usuario.Nombre @usuario.Apellido</h6>
                                                <small class="text-muted">@usuario.Email</small>
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        <span class="badge badge-soft-primary px-2 py-1">@rol</span>
                                    </td>
                                    <td>
                                        @if (usuario.Activo)
                                        {
                                            <span class="badge bg-success-subtle text-success border border-success-subtle rounded-pill">Activo</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger-subtle text-danger border border-danger-subtle rounded-pill">Inactivo</span>
                                        }
                                    </td>
                                    <td>
                                        <small class="text-muted">@usuario.FechaRegistro.ToString("dd/MM/yyyy")</small>
                                    </td>
                                    <td class="text-end pe-4">
                                        <div class="btn-group">
                                            <button class="btn btn-sm btn-light" onclick="editarUsuario('@usuario.Id')" title="Gestionar Permisos">
                                                <i class="ri-shield-keyhole-line text-primary"></i>
                                            </button>
                                            <button class="btn btn-sm btn-light" onclick="cambiarContrasena('@usuario.Id', '@usuario.Email')" title="Cambiar Contraseña">
                                                <i class="ri-key-2-line text-warning"></i>
                                            </button>
                                            <button class="btn btn-sm btn-light" onclick="eliminarUsuario('@usuario.Id')" title="Eliminar">
                                                <i class="ri-delete-bin-line text-danger"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- Info Lateral -->
    <div class="col-xl-4">
        <div class="card border-0 shadow-sm mb-4 bg-primary text-white">
            <div class="card-body">
                <h5 class="card-title text-white mb-3">Gestión de Seguridad</h5>
                <p class="mb-0 opacity-75">
                    Como administrador, puedes definir qué módulos puede ver cada usuario. 
                    Los cambios de permisos se aplican la próxima vez que el usuario inicie sesión.
                </p>
            </div>
        </div>

        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white">
                <h6 class="card-title mb-0">Auditoría Reciente</h6>
            </div>
            <div class="card-body p-0">
                <div class="list-group list-group-flush">
                    <div class="list-group-item small text-muted text-center py-4">
                        Próximamente: Historial de accesos y cambios
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal Nuevo Usuario -->
<div class="modal fade" id="NuevoUsuarioModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title text-white"><i class="ri-user-add-line me-2"></i>Crear Nuevo Usuario</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <form id="formNuevoUsuario" data-ajax="true">
                    @Html.AntiForgeryToken()
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Nombre</label>
                            <input type="text" name="Nombre" class="form-control" required placeholder="Ej: Juan" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Apellido</label>
                            <input type="text" name="Apellido" class="form-control" placeholder="Ej: Pérez" />
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-bold">Correo Electrónico</label>
                            <input type="email" name="Email" class="form-control" required placeholder="correo@empresa.com" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Contraseña</label>
                            <input type="password" name="Password" class="form-control" required minlength="6" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Rol Principal</label>
                            <select name="Rol" class="form-select">
                                <option value="Vendedor">Vendedor</option>
                                <option value="Cajero">Cajero</option>
                                <option value="Gerente">Gerente</option>
                                <option value="Admin">Administrador</option>
                            </select>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer bg-light border-0">
                <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-primary px-4" onclick="guardarUsuario()">
                    <i class="ri-save-line me-1"></i> Guardar Usuario
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Modal Editar y Permisos (EL "ENCENDIDO/APAGADO") -->
<div class="modal fade" id="EditarUsuarioModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-dark text-white">
                <h5 class="modal-title text-white"><i class="ri-shield-user-line me-2"></i>Gestión de Usuario y Permisos</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-0">
                <form id="formEditarUsuario">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="Id" id="editUsuarioId" />
                    
                    <div class="p-4 bg-light border-bottom">
                        <div class="row g-3">
                            <div class="col-md-4">
                                <label class="form-label fw-bold">Nombre</label>
                                <input type="text" name="Nombre" id="editNombre" class="form-control" required />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label fw-bold">Apellido</label>
                                <input type="text" name="Apellido" id="editApellido" class="form-control" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label fw-bold">Rol</label>
                                <select name="Rol" id="editRol" class="form-select">
                                    <option value="Vendedor">Vendedor</option>
                                    <option value="Cajero">Cajero</option>
                                    <option value="Gerente">Gerente</option>
                                    <option value="Admin">Administrador</option>
                                </select>
                            </div>
                            <div class="col-12 mt-2">
                                <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox" name="Activo" id="editActivo" value="true">
                                    <label class="form-check-label fw-bold" for="editActivo">Usuario Activo (Permitir acceso al sistema)</label>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="p-4">
                        <h6 class="mb-3 text-uppercase fw-bold text-muted small"><i class="ri-lock-unlock-line me-1"></i> Configuración de Permisos</h6>
                        <div class="row g-3">
                            <!-- Permiso Facturar -->
                            <div class="col-md-6">
                                <div class="permission-card p-3 rounded-3 d-flex align-items-center justify-content-between">
                                    <div>
                                        <h6 class="mb-0">Facturación y Ventas</h6>
                                        <small class="text-muted">Permitir crear facturas y cobrar</small>
                                    </div>
                                    <div class="form-check form-switch">
                                        <input class="form-check-input" type="checkbox" name="PuedeFacturar" id="pFacturar" value="true">
                                    </div>
                                </div>
                            </div>
                            <!-- Permiso Reportes -->
                            <div class="col-md-6">
                                <div class="permission-card p-3 rounded-3 d-flex align-items-center justify-content-between">
                                    <div>
                                        <h6 class="mb-0">Reportes Financieros</h6>
                                        <small class="text-muted">Ver estadísticas y ganancias</small>
                                    </div>
                                    <div class="form-check form-switch">
                                        <input class="form-check-input" type="checkbox" name="PuedeVerReportes" id="pReportes" value="true">
                                    </div>
                                </div>
                            </div>
                            <!-- Permiso Inventario -->
                            <div class="col-md-6">
                                <div class="permission-card p-3 rounded-3 d-flex align-items-center justify-content-between">
                                    <div>
                                        <h6 class="mb-0">Inventario / Stock</h6>
                                        <small class="text-muted">Agregar productos y ajustar stock</small>
                                    </div>
                                    <div class="form-check form-switch">
                                        <input class="form-check-input" type="checkbox" name="PuedeGestionarInventario" id="pInventario" value="true">
                                    </div>
                                </div>
                            </div>
                            <!-- Permiso Configuración -->
                            <div class="col-md-6">
                                <div class="permission-card p-3 rounded-3 d-flex align-items-center justify-content-between">
                                    <div>
                                        <h6 class="mb-0">Configuración Sistema</h6>
                                        <small class="text-muted">Cambiar datos de empresa y DGII</small>
                                    </div>
                                    <div class="form-check form-switch">
                                        <input class="form-check-input" type="checkbox" name="PuedeConfigurarSistema" id="pConfig" value="true">
                                    </div>
                                </div>
                            </div>
                            <!-- Permiso Anular -->
                            <div class="col-md-6">
                                <div class="permission-card p-3 rounded-3 d-flex align-items-center justify-content-between">
                                    <div>
                                        <h6 class="mb-0">Anular Facturas</h6>
                                        <small class="text-muted">Permitir cancelar ventas realizadas</small>
                                    </div>
                                    <div class="form-check form-switch">
                                        <input class="form-check-input" type="checkbox" name="PuedeAnularFacturas" id="pAnular" value="true">
                                    </div>
                                </div>
                            </div>
                            <!-- Permiso Ver Costos -->
                            <div class="col-md-6">
                                <div class="permission-card p-3 rounded-3 d-flex align-items-center justify-content-between">
                                    <div>
                                        <h6 class="mb-0">Ver Costos de Compra</h6>
                                        <small class="text-muted">Ver el margen de beneficio</small>
                                    </div>
                                    <div class="form-check form-switch">
                                        <input class="form-check-input" type="checkbox" name="PuedeVerCostos" id="pCostos" value="true">
                                    </div>
                                </div>
                            </div>
                            <!-- Permiso Gestionar Usuarios -->
                            <div class="col-md-6">
                                <div class="permission-card p-3 rounded-3 d-flex align-items-center justify-content-between">
                                    <div>
                                        <h6 class="mb-0">Gestionar Usuarios</h6>
                                        <small class="text-muted">Crear y administrar accesos</small>
                                    </div>
                                    <div class="form-check form-switch">
                                        <input class="form-check-input" type="checkbox" name="PuedeGestionarUsuarios" id="pUsuarios" value="true">
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer bg-light border-0">
                <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cerrar</button>
                <button type="button" class="btn btn-dark px-4" onclick="guardarEdicion()">
                    <i class="ri-save-line me-1"></i> Aplicar Cambios y Permisos
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Modal Cambiar Contraseña -->
<div class="modal fade" id="CambiarContrasenaModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-sm modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header border-0">
                <h5 class="modal-title"><i class="ri-key-2-line me-1 text-warning"></i>Nueva Contraseña</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <form id="formCambiarContrasena">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" id="contrasenaUsuarioId" />
                    <div class="mb-3">
                        <label class="form-label small fw-bold">Contraseña Nueva</label>
                        <input type="password" name="nuevaContrasena" id="nuevaContrasena" class="form-control" required minlength="6" />
                    </div>
                    <div class="mb-0">
                        <label class="form-label small fw-bold">Confirmar</label>
                        <input type="password" id="confirmarContrasena" class="form-control" required />
                    </div>
                </form>
            </div>
            <div class="modal-footer border-0">
                <button type="button" class="btn btn-warning w-100" onclick="guardarContrasena()">Cambiar Contraseña</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function getCsrfToken() {
            return document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
        }

        async function guardarUsuario() {
            const form = document.getElementById('formNuevoUsuario');
            const btn = document.querySelector('#NuevoUsuarioModal .btn-primary');
            const originalText = btn ? btn.innerHTML : 'Guardar';
            
            const formData = new FormData(form);

            try {
                if (btn) {
                    btn.disabled = true;
                    btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span> Guardando...';
                }

                const response = await fetch('/Configuracion/GuardarUsuario', {
                    method: 'POST',
                    body: formData
                });

                const data = await response.json();

                if (response.ok && data.success) {
                    window.location.reload();
                } else {
                    alert("⚠️ Error:\n\n" + (data.message || 'Error desconocido'));
                }
            } catch (error) {
                console.error(error);
                alert('❌ Error de conexión. Verifique su internet.');
            } finally {
                if (btn) {
                    btn.disabled = false;
                    btn.innerHTML = originalText;
                }
            }
        }

        async function editarUsuario(id) {
            try {
                const response = await fetch(`/Configuracion/ObtenerUsuario/${id}`);
                const u = await response.json();

                document.getElementById('editUsuarioId').value = u.id;
                document.getElementById('editNombre').value = u.nombre;
                document.getElementById('editApellido').value = u.apellido;
                document.getElementById('editRol').value = u.rol;
                document.getElementById('editActivo').checked = u.activo;
                
                // Switches de permisos
                document.getElementById('pFacturar').checked = u.puedeFacturar;
                document.getElementById('pReportes').checked = u.puedeVerReportes;
                document.getElementById('pInventario').checked = u.puedeGestionarInventario;
                document.getElementById('pConfig').checked = u.puedeConfigurarSistema;
                document.getElementById('pAnular').checked = u.puedeAnularFacturas;
                document.getElementById('pCostos').checked = u.puedeVerCostos;
                document.getElementById('pUsuarios').checked = u.puedeGestionarUsuarios;

                new bootstrap.Modal(document.getElementById('EditarUsuarioModal')).show();
            } catch (error) {
                alert('No se pudo cargar el usuario');
            }
        }

        async function guardarEdicion() {
            const form = document.getElementById('formEditarUsuario');
            const formData = new FormData(form);
            
            // Asegurar que los checkbox envíen false si no están marcados
            const checkboxes = form.querySelectorAll('input[type="checkbox"]');
            checkboxes.forEach(cb => {
                if (!cb.checked) {
                    formData.append(cb.name, "false");
                }
            });

            try {
                const response = await fetch('/Configuracion/EditarUsuario', {
                    method: 'POST',
                    body: formData
                });

                if (response.ok) {
                    window.location.reload();
                } else {
                    alert('Error al actualizar');
                }
            } catch (error) {
                alert('Error de conexión');
            }
        }

        function cambiarContrasena(id, email) {
            document.getElementById('contrasenaUsuarioId').value = id;
            document.getElementById('nuevaContrasena').value = '';
            document.getElementById('confirmarContrasena').value = '';
            new bootstrap.Modal(document.getElementById('CambiarContrasenaModal')).show();
        }

        async function guardarContrasena() {
            const id = document.getElementById('contrasenaUsuarioId').value;
            const pass = document.getElementById('nuevaContrasena').value;
            const confirm = document.getElementById('confirmarContrasena').value;

            if (pass !== confirm) { alert('Contraseñas no coinciden'); return; }

            const formData = new FormData();
            formData.append('id', id);
            formData.append('nuevaContrasena', pass);
            formData.append('__RequestVerificationToken', getCsrfToken());

            try {
                const response = await fetch('/Configuracion/CambiarContrasena', {
                    method: 'POST',
                    body: formData
                });

                if (response.ok) {
                    alert('Contraseña actualizada');
                    location.reload();
                }
            } catch (error) { alert('Error'); }
        }

        async function eliminarUsuario(id) {
            if (!confirm('¿Seguro que desea eliminar este usuario?')) return;

            const formData = new FormData();
            formData.append('id', id);
            formData.append('__RequestVerificationToken', getCsrfToken());

            try {
                const response = await fetch('/Configuracion/EliminarUsuario', {
                    method: 'POST',
                    body: formData
                });

                if (response.ok) {
                    location.reload();
                } else {
                    const d = await response.json();
                    alert(d.message || 'Error');
                }
            } catch (error) { alert('Error'); }
        }
        function toggleAllPermissions(isAdmin) {
            const checkboxes = document.querySelectorAll('#formEditarUsuario input[type="checkbox"]');
            checkboxes.forEach(cb => {
                cb.checked = isAdmin;
            });
        }

        // Listener para el selector de rol en modal Editar
        document.getElementById('editRol')?.addEventListener('change', function(e) {
            if (e.target.value === 'Admin') {
                toggleAllPermissions(true);
            }
        });
    </script>
}
