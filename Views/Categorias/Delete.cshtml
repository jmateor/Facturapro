@model Facturapro.Models.Entities.Categoria

@{
    ViewData["Title"] = "Eliminar Categoría";
}

<div class="page-header">
    <div class="page-title">
        <h1>Eliminar Categoría</h1>
        <p>¿Estás seguro de que deseas eliminar esta categoría?</p>
    </div>
    <div class="page-actions">
        <a href="@Url.Action("Index")" class="btn btn-secondary">Volver a la lista</a>
    </div>
</div>

@if (Model.Productos.Any())
{
    <div class="alert alert-warning">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z" />
        </svg>
        <strong>No se puede eliminar:</strong> Esta categoría tiene @Model.Productos.Count producto(s) asociado(s). Debes reasignar o eliminar los productos primero.
    </div>
}

<div class="card">
    <div class="card-body">
        <dl class="details-list">
            <dt>Nombre</dt>
            <dd>@Model.Nombre</dd>

            <dt>Descripción</dt>
            <dd>@(Model.Descripcion ?? "-")</dd>

            <dt>Estado</dt>
            <dd>
                @if (Model.Activo)
                {
                    <span class="badge badge-success">Activa</span>
                }
                else
                {
                    <span class="badge badge-secondary">Inactiva</span>
                }
            </dd>

            <dt>Fecha de Creación</dt>
            <dd>@Model.FechaCreacion.ToString("dd/MM/yyyy HH:mm")</dd>

            <dt>Productos Asociados</dt>
            <dd><span class="badge badge-secondary">@Model.Productos.Count</span></dd>
        </dl>

        <form asp-action="Delete" method="post" style="margin-top: var(--space-lg);">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />

            <div class="d-flex gap-1">
                <button type="submit" class="btn btn-danger" @(Model.Productos.Any() ? "disabled" : "") >
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12.562c.34-.06.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
                    </svg>
                    Eliminar Categoría
                </button>
                <a href="@Url.Action("Index")" class="btn btn-secondary">Cancelar</a>
            </div>
        </form>
    </div>
</div>
