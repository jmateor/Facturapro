@model IEnumerable<Facturapro.Models.Entities.Categoria>

@{
    ViewData["Title"] = "Categorías";
}

<!-- Page Header -->
<div class="page-header-title">
    <div class="d-flex align-items-center justify-content-between">
        <div>
            <h4 class="page-title mb-1">
                <i class="ri-price-tag-3-line me-1"></i>
                Categorías
            </h4>
            <p class="text-muted mb-0">Gestiona las categorías de productos</p>
        </div>
        <div>
            <a href="@Url.Action("Create")" class="btn btn-primary">
                <i class="ri-add-line me-1"></i> Nueva Categoría
            </a>
        </div>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="row">
        <div class="col-12">
            <div class="alert alert-success border-0 alert-dismissible fade show" role="alert">
                <i class="ri-checkbox-circle-line me-2"></i>
                @TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        </div>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="row">
        <div class="col-12">
            <div class="alert alert-danger border-0 alert-dismissible fade show" role="alert">
                <i class="ri-error-warning-line me-2"></i>
                @TempData["ErrorMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        </div>
    </div>
}

<!-- Resumen de Categorías -->
<div class="row g-3 mb-3">
    <div class="col-md-4">
        <div class="card">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <p class="text-muted mb-0 small">Total Categorías</p>
                        <h4 class="mb-0 fw-bold">@Model.Count()</h4>
                    </div>
                    <div class="avatar-md bg-primary text-white rounded-circle d-flex align-items-center justify-content-center">
                        <i class="ri-price-tag-3-line fs-4"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <p class="text-muted mb-0 small">Categorías Activas</p>
                        <h4 class="mb-0 fw-bold">@Model.Count(c => c.Activo)</h4>
                    </div>
                    <div class="avatar-md bg-success text-white rounded-circle d-flex align-items-center justify-content-center">
                        <i class="ri-checkbox-circle-line fs-4"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <p class="text-muted mb-0 small">Categorías Inactivas</p>
                        <h4 class="mb-0 fw-bold">@Model.Count(c => !c.Activo)</h4>
                    </div>
                    <div class="avatar-md bg-secondary text-white rounded-circle d-flex align-items-center justify-content-center">
                        <i class="ri-stop-circle-line fs-4"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Filtros y Búsqueda -->
<div class="card mb-3">
    <div class="card-body">
        <form method="get" class="row g-2 align-items-center">
            <div class="col-md-9">
                <div class="position-relative">
                    <input type="text" name="buscar" class="form-control" placeholder="Buscar por nombre o descripción..." value="@Context.Request.Query["buscar"]" />
                    <i class="ri-search-line position-absolute top-50 end-0 translate-middle-y me-3 text-muted"></i>
                </div>
            </div>
            <div class="col-md-3">
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary flex-grow-1">
                        <i class="ri-filter-search-line me-1"></i> Filtrar
                    </button>
                    <a href="@Url.Action("Index")" class="btn btn-soft-secondary" title="Limpiar filtros">
                        <i class="ri-close-line"></i>
                    </a>
                </div>
            </div>
        </form>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover table-centered mb-0" id="tablaCategorias">
                <thead class="table-light">
                    <tr>
                        <th style="width: 25%;">Nombre</th>
                        <th style="width: 35%;">Descripción</th>
                        <th style="width: 12%;" class="text-center">Productos</th>
                        <th style="width: 13%;" class="text-center">Estado</th>
                        <th style="width: 15%;" class="text-end">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr class="categoria-row" data-nombre="@item.Nombre.ToLower()" data-descripcion="@item.Descripcion?.ToLower()">
                            <td>
                                <div class="d-flex align-items-center">
                                    <div class="avatar-sm bg-primary text-white rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 42px; height: 42px;">
                                        <i class="ri-price-tag-3-line"></i>
                                    </div>
                                    <div>
                                        <h6 class="mb-0 fw-semibold">@item.Nombre</h6>
                                        <small class="text-muted">Creada: @item.FechaCreacion.ToString("dd/MM/yyyy")</small>
                                    </div>
                                </div>
                            </td>
                            <td>
                                @if (!string.IsNullOrEmpty(item.Descripcion))
                                {
                                    <span class="text-muted">@item.Descripcion.Substring(0, Math.Min(60, item.Descripcion.Length))@(item.Descripcion.Length > 60 ? "..." : "")</span>
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                            <td class="text-center">
                                @if (item.Productos.Count > 0)
                                {
                                    <a href="@Url.Action("Index", "Productos", new { categoriaId = item.Id })" class="badge bg-info-subtle text-info-emphasis border border-info-subtle text-decoration-none">
                                        <i class="ri-box-3-line me-1"></i>@item.Productos.Count
                                    </a>
                                }
                                else
                                {
                                    <span class="badge bg-secondary-subtle text-secondary-emphasis border border-secondary-subtle">
                                        <i class="ri-close-circle-line me-1"></i>0
                                    </span>
                                }
                            </td>
                            <td class="text-center">
                                @if (item.Activo)
                                {
                                    <span class="badge bg-success-soft text-success">
                                        <i class="ri-checkbox-circle-fill me-1"></i>Activa
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary-soft text-secondary">
                                        <i class="ri-stop-circle-fill me-1"></i>Inactiva
                                    </span>
                                }
                            </td>
                            <td class="text-end">
                                <div class="btn-group" role="group">
                                    <a href="@Url.Action("Details", new { id = item.Id })" class="btn btn-sm btn-soft-info" title="Ver detalles">
                                        <i class="ri-eye-line"></i>
                                    </a>
                                    <a href="@Url.Action("Edit", new { id = item.Id })" class="btn btn-sm btn-soft-primary" title="Editar">
                                        <i class="ri-edit-line"></i>
                                    </a>
                                    <a href="@Url.Action("Delete", new { id = item.Id })" class="btn btn-sm btn-soft-danger" title="Eliminar" onclick="return confirm('¿Está seguro de eliminar esta categoría?@(item.Productos.Any() ? "\n\n¡ADVERTENCIA: Esta categoría tiene " + item.Productos.Count + " producto(s) asociado(s)!" : "")')">
                                        <i class="ri-delete-bin-line"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (!Model.Any())
        {
            <div class="text-center py-5">
                <div class="avatar-lg bg-soft-primary rounded-circle mb-3 mx-auto d-inline-flex" style="width: 100px; height: 100px;">
                    <i class="ri-price-tag-3-line display-4 text-primary"></i>
                </div>
                <h5 class="fw-semibold">No hay categorías registradas</h5>
                <p class="text-muted mb-3">Comienza agregando tu primera categoría para organizar tus productos</p>
                <a href="@Url.Action("Create")" class="btn btn-primary">
                    <i class="ri-add-line me-1"></i> Crear primera categoría
                </a>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        // Búsqueda en tiempo real
        document.querySelector('input[name="buscar"]').addEventListener('input', function() {
            const filtro = this.value.toLowerCase();
            const filas = document.querySelectorAll('.categoria-row');

            filas.forEach(function(fila) {
                const nombre = fila.getAttribute('data-nombre');
                const descripcion = fila.getAttribute('data-descripcion');

                if (nombre?.includes(filtro) || descripcion?.includes(filtro)) {
                    fila.style.display = '';
                } else {
                    fila.style.display = 'none';
                }
            });
        });
    </script>
}
