@model Facturapro.Models.Entities.ReciboPago

@{
    ViewData["Title"] = "Registrar Pago";
    var factura = ViewBag.Factura as Facturapro.Models.Entities.Factura;
    var abonado = (decimal)ViewBag.Abonado;
    var balance = (decimal)ViewBag.Balance;
    var cultura = new System.Globalization.CultureInfo("es-DO");
}

<div class="row">
    <div class="col-12">
        <div class="page-title-box">
            <div class="page-title-right">
                <a href="@Url.Action("Index")" class="btn btn-secondary">Volver</a>
            </div>
            <h4 class="page-title">Registrar Cobro - @factura?.NumeroFactura</h4>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-md-5">
        <div class="card bg-primary text-white">
            <div class="card-body">
                <h5 class="card-title text-white mb-3">Resumen de la Factura</h5>
                
                <div class="d-flex justify-content-between mb-2">
                    <span>Cliente:</span>
                    <span class="fw-bold">@factura?.Cliente?.Nombre</span>
                </div>
                <div class="d-flex justify-content-between mb-2">
                    <span>Total Facturado:</span>
                    <span>@factura?.Total.ToString("C", cultura)</span>
                </div>
                <div class="d-flex justify-content-between mb-2">
                    <span>Monto Abonado:</span>
                    <span class="text-success fw-bold">@abonado.ToString("C", cultura)</span>
                </div>
                <hr class="border-white opacity-50" />
                <div class="d-flex justify-content-between align-items-center">
                    <span class="fs-5">Balance Pendiente:</span>
                    <span class="fs-3 fw-bold text-warning">@balance.ToString("C", cultura)</span>
                </div>
            </div>
        </div>

        <div class="card">
            <div class="card-body">
                <h5 class="card-title mb-3">Historial de Pagos</h5>
                <div id="historial-pagos">
                    <div class="text-center py-3">
                        <div class="spinner-border text-primary" role="status"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-7">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title mb-4">Detalles del Nuevo Pago</h5>

                <form asp-action="Registrar" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    
                    <input type="hidden" asp-for="FacturaId" />
                    <input type="hidden" asp-for="ClienteId" />

                    <div class="row mb-3">
                        <div class="col-md-4">
                            <label asp-for="MontoEfectivo" class="form-label">Efectivo</label>
                            <div class="input-group">
                                <span class="input-group-text">$</span>
                                <input asp-for="MontoEfectivo" class="form-control monto-input" type="number" step="0.01" />
                            </div>
                            <span asp-validation-for="MontoEfectivo" class="text-danger"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="MontoTarjeta" class="form-label">Tarjeta</label>
                            <div class="input-group">
                                <span class="input-group-text">$</span>
                                <input asp-for="MontoTarjeta" class="form-control monto-input" type="number" step="0.01" />
                            </div>
                            <span asp-validation-for="MontoTarjeta" class="text-danger"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="MontoTransferencia" class="form-label">Transferencia/Cheque</label>
                            <div class="input-group">
                                <span class="input-group-text">$</span>
                                <input asp-for="MontoTransferencia" class="form-control monto-input" type="number" step="0.01" />
                            </div>
                            <span asp-validation-for="MontoTransferencia" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <div class="d-flex justify-content-between align-items-center p-3 bg-light rounded">
                            <h5 class="mb-0">Total a Aplicar:</h5>
                            <h4 class="mb-0 text-primary" id="total-aplicar">$0.00</h4>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Referencia" class="form-label">Número de Referencia (Opcional)</label>
                        <input asp-for="Referencia" class="form-control" placeholder="Ej. Aprobación voucher o número transferencia" />
                        <span asp-validation-for="Referencia" class="text-danger"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Notas" class="form-label">Notas Adicionales (Opcional)</label>
                        <textarea asp-for="Notas" class="form-control" rows="2"></textarea>
                        <span asp-validation-for="Notas" class="text-danger"></span>
                    </div>

                    <div class="d-grid">
                        <button type="submit" class="btn btn-primary btn-lg">
                            <i class="ri-save-line me-1"></i> Registrar Pago
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    
    <script>
        $(document).ready(function() {
            // Cargar historial
            $.get('@Url.Action("Historial", new { id = Model.FacturaId })', function(data) {
                $('#historial-pagos').html(data);
            });

            // Calcular total dinámicamente
            $('.monto-input').on('input', function() {
                var efectivo = parseFloat($('#MontoEfectivo').val()) || 0;
                var tarjeta = parseFloat($('#MontoTarjeta').val()) || 0;
                var transferencia = parseFloat($('#MontoTransferencia').val()) || 0;
                
                var total = efectivo + tarjeta + transferencia;
                
                // Formatear como moneda dominicana
                var formatter = new Intl.NumberFormat('es-DO', {
                    style: 'currency',
                    currency: 'DOP'
                });
                
                $('#total-aplicar').text(formatter.format(total));
            });

            // Disparar evento para calcular el total inicial
            $('.monto-input').first().trigger('input');
        });
    </script>
}
