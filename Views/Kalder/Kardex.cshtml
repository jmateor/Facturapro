@model IEnumerable<Facturapro.Models.Entities.MovimientoInventario>
@using Facturapro.Models.Entities
@{
    var producto = ViewData["Producto"] as Facturapro.Models.Entities.Producto;
    ViewData["Title"] = $"Kardex - {producto?.Nombre}";
    var cultura = new System.Globalization.CultureInfo("es-DO");
    
    // Calcular acumulados para el Kardex
}

<div class="row">
    <div class="col-12">
        <div class="page-title-box">
            <div class="page-title-right">
                <form class="d-flex gap-2 align-items-center" method="get">
                    <input type="hidden" name="id" value="@producto?.Id" />
                    <div class="input-group input-group-sm">
                        <span class="input-group-text bg-light border-0"><i class="ri-calendar-event-line"></i></span>
                        <input type="date" name="desde" class="form-control border-0 bg-light" value="@(ViewData["Desde"] as DateTime?)?.ToString("yyyy-MM-dd")" title="Desde" />
                    </div>
                    <div class="input-group input-group-sm">
                        <span class="input-group-text bg-light border-0"><i class="ri-calendar-event-line"></i></span>
                        <input type="date" name="hasta" class="form-control border-0 bg-light" value="@(ViewData["Hasta"] as DateTime?)?.ToString("yyyy-MM-dd")" title="Hasta" />
                    </div>
                    <button type="submit" class="btn btn-primary btn-sm"><i class="ri-filter-3-line"></i></button>
                    <button type="button" class="btn btn-secondary btn-sm" onclick="window.print()">
                        <i class="ri-printer-line"></i>
                    </button>
                    <a href="@Url.Action("Inventario")" class="btn btn-outline-secondary btn-sm">Volver</a>
                </form>
            </div>
            <h4 class="page-title">Kardex de Inventario</h4>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-xl-4 col-md-6">
        <div class="card shadow-sm border-0">
            <div class="card-body">
                <div class="d-flex align-items-center mb-3">
                    <div class="avatar-sm bg-soft-primary rounded d-flex align-items-center justify-content-center me-3">
                        <i class="ri-box-3-line fs-3 text-primary"></i>
                    </div>
                    <div>
                        <h5 class="m-0 fw-semibold">@producto?.Nombre</h5>
                        <p class="text-muted mb-0 small"><i class="ri-barcode-line me-1"></i> @producto?.Codigo</p>
                    </div>
                </div>
                <div class="row text-center border-top pt-3">
                    <div class="col-4 border-end">
                        <h6 class="text-muted small text-uppercase fw-semibold mb-1">Stock Actual</h6>
                        <h4 class="m-0 @(producto?.Stock <= producto?.StockMinimo ? "text-danger" : "text-dark") fw-bold">@producto?.Stock</h4>
                    </div>
                    <div class="col-4 border-end">
                        <h6 class="text-muted small text-uppercase fw-semibold mb-1">Costo Prom.</h6>
                        <h4 class="m-0 fw-bold">@producto?.CostoPromedio.ToString("C", cultura)</h4>
                    </div>
                    <div class="col-4">
                        <h6 class="text-muted small text-uppercase fw-semibold mb-1">Precio Venta</h6>
                        <h4 class="m-0 fw-bold text-success">@producto?.Precio.ToString("C", cultura)</h4>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <div class="col-xl-8 col-md-6">
        <div class="card shadow-sm border-0">
            <div class="card-body">
                <h5 class="card-title mb-3 fw-semibold">Rendimiento Estimado</h5>
                <div class="row align-items-center">
                    <div class="col-6">
                        <p class="text-muted mb-1 fw-medium">Margen de Ganancia Bruta</p>
                        <h3 class="mb-2 fw-bold">@(((producto?.Precio - producto?.CostoPromedio) / (producto?.Precio > 0 ? producto.Precio : 1) * 100)?.ToString("N2"))%</h3>
                        <div class="progress" style="height: 6px;">
                            <div class="progress-bar bg-success" role="progressbar" style="width: @(((producto?.Precio - producto?.CostoPromedio) / (producto?.Precio > 0 ? producto.Precio : 1) * 100)?.ToString("N0"))%"></div>
                        </div>
                    </div>
                    <div class="col-6 text-end">
                        <p class="text-muted mb-1 fw-medium">Valor Total en Almacén</p>
                        <h2 class="text-primary m-0 fw-bold">@((producto?.Stock * producto?.CostoPromedio)?.ToString("C", cultura))</h2>
                        <small class="text-muted">Basado en costo promedio</small>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-12">
        <div class="card shadow-sm border-0">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover table-centered table-bordered mb-0 border-light">
                        <thead class="table-light">
                            <tr>
                                <th rowspan="2" class="text-center align-middle border-end">Fecha / Hora</th>
                                <th rowspan="2" class="align-middle border-end">Detalle / Motivo</th>
                                <th colspan="3" class="text-center bg-soft-success text-success border-end">Entradas</th>
                                <th colspan="3" class="text-center bg-soft-danger text-danger border-end">Salidas</th>
                                <th colspan="2" class="text-center bg-soft-primary text-primary border-end">Saldos</th>
                                <th rowspan="2" class="align-middle text-center">Usuario</th>
                            </tr>
                            <tr>
                                <th class="text-center bg-soft-success text-success">Cant.</th>
                                <th class="text-center bg-soft-success text-success">Costo U.</th>
                                <th class="text-center bg-soft-success text-success border-end">Total</th>
                                <th class="text-center bg-soft-danger text-danger">Cant.</th>
                                <th class="text-center bg-soft-danger text-danger">Costo U.</th>
                                <th class="text-center bg-soft-danger text-danger border-end">Total</th>
                                <th class="text-center bg-soft-primary text-primary">Cant.</th>
                                <th class="text-center bg-soft-primary text-primary border-end">Costo Prom.</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!Model.Any())
                            {
                                <tr>
                                    <td colspan="11" class="text-center py-4 text-muted">No se encontraron movimientos en este rango de fechas.</td>
                                </tr>
                            }
                            @foreach (var mov in Model)
                            {
                                var esEntrada = mov.TipoMovimiento.ToString().StartsWith("Entrada");
                                <tr>
                                    <td class="text-center border-end">
                                        <div class="fw-semibold text-dark">@mov.FechaMovimiento.ToString("dd/MM/yyyy")</div>
                                        <small class="text-muted">@mov.FechaMovimiento.ToString("hh:mm tt")</small>
                                    </td>
                                    <td class="border-end">
                                        @if (mov.Factura != null)
                                        {
                                            <span class="badge badge-outline-info rounded-pill mb-1">Venta #@mov.Factura.NumeroFactura</span>
                                        }
                                        else if (mov.Compra != null)
                                        {
                                            <span class="badge badge-outline-success rounded-pill mb-1">Compra #@mov.Compra.Id</span>
                                        }
                                        <div class="small fw-medium text-muted">@mov.Motivo</div>
                                    </td>
                                    
                                    <!-- Entradas -->
                                    <td class="text-center @(esEntrada ? "fw-bold text-success" : "text-muted")">
                                        @(esEntrada ? mov.Cantidad.ToString() : "-")
                                    </td>
                                    <td class="text-end @(esEntrada ? "" : "text-muted")">
                                        @(esEntrada && mov.CostoUnitario.HasValue ? mov.CostoUnitario.Value.ToString("C", cultura) : "-")
                                    </td>
                                    <td class="text-end border-end @(esEntrada ? "fw-bold text-success" : "text-muted")">
                                        @(esEntrada && mov.CostoUnitario.HasValue ? (mov.Cantidad * mov.CostoUnitario.Value).ToString("C", cultura) : "-")
                                    </td>

                                    <!-- Salidas -->
                                    <td class="text-center @(!esEntrada ? "fw-bold text-danger" : "text-muted")">
                                        @(!esEntrada ? mov.Cantidad.ToString() : "-")
                                    </td>
                                    <td class="text-end @(!esEntrada ? "" : "text-muted")">
                                        @(!esEntrada && mov.CostoUnitario.HasValue ? mov.CostoUnitario.Value.ToString("C", cultura) : "-")
                                    </td>
                                    <td class="text-end border-end @(!esEntrada ? "fw-bold text-danger" : "text-muted")">
                                        @(!esEntrada && mov.CostoUnitario.HasValue ? (mov.Cantidad * mov.CostoUnitario.Value).ToString("C", cultura) : "-")
                                    </td>

                                    <!-- Saldos -->
                                    <td class="text-center fw-bold bg-light">
                                        @mov.StockNuevo
                                    </td>
                                    <td class="text-end fw-bold bg-light border-end">
                                        @(mov.CostoUnitario?.ToString("C", cultura) ?? "-")
                                    </td>

                                    <td class="text-center">
                                        <span class="badge bg-light text-secondary rounded-pill">@mov.UsuarioRegistro</span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
