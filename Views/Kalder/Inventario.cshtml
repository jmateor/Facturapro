@model IEnumerable<Facturapro.Models.Entities.Producto>

@{
    ViewData["Title"] = "Inventario - Kalder";
    var categorias = ViewData["Categorias"] as List<Facturapro.Models.Entities.Categoria> ?? new List<Facturapro.Models.Entities.Categoria>();
    var cultura = new System.Globalization.CultureInfo("es-DO");
}

<div class="row">
    <div class="col-12">
        <div class="page-title-box">
            <div class="page-title-right">
                <a href="@Url.Action("Index")" class="btn btn-secondary">
                    <i class="ri-arrow-go-back-line me-1"></i> Volver a Kalder
                </a>
            </div>
            <h4 class="page-title">Gestión de Inventario</h4>
        </div>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
        <i class="ri-check-line me-2 fs-4 align-middle"></i>
        <strong>¡Éxito!</strong> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
        <i class="ri-error-warning-line me-2 fs-4 align-middle"></i>
        <strong>Error:</strong> @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="row">
    <div class="col-12">
        <div class="card shadow-sm border-0">
            <div class="card-body">
                <form method="get" class="row gy-2 gx-2 align-items-center mb-4">
                    <div class="col-sm-auto flex-grow-1">
                        <label class="visually-hidden" for="buscar">Buscar</label>
                        <div class="input-group">
                            <div class="input-group-text bg-light border-0"><i class="ri-search-line"></i></div>
                            <input type="text" name="buscar" id="buscar" class="form-control bg-light border-0" placeholder="Buscar por nombre, código o código de barras..." value="@Context.Request.Query["buscar"]">
                        </div>
                    </div>
                    <div class="col-sm-auto">
                        <label class="visually-hidden" for="categoriaId">Categoría</label>
                        <select name="categoriaId" id="categoriaId" class="form-select bg-light border-0">
                            <option value="">Todas las categorías</option>
                            @foreach (var cat in categorias)
                            {
                                if (Context.Request.Query["categoriaId"] == cat.Id.ToString())
                                {
                                    <option value="@cat.Id" selected>@cat.Nombre</option>
                                }
                                else
                                {
                                    <option value="@cat.Id">@cat.Nombre</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="col-sm-auto">
                        <button type="submit" class="btn btn-primary w-100">
                            <i class="ri-filter-3-line me-1"></i> Filtrar
                        </button>
                    </div>
                </form>

                <div class="table-responsive">
                    <table class="table table-hover table-centered dt-responsive nowrap w-100" id="inventario-datatable">
                        <thead class="table-light">
                            <tr>
                                <th>Código</th>
                                <th>Producto</th>
                                <th>Categoría</th>
                                <th>Stock</th>
                                <th>Precio Venta</th>
                                <th>Valor Total</th>
                                <th class="text-end">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                var badgeClass = item.Stock == 0 ? "bg-danger" : (item.Stock <= 5 ? "bg-warning" : "bg-success");
                                var stockText = item.Stock == 0 ? "Agotado" : (item.Stock <= 5 ? "Bajo" : "OK");
                                var valorInventario = item.Stock * item.Precio;

                                <tr>
                                    <td>
                                        <span class="badge badge-outline-secondary fs-6">@item.Codigo</span>
                                    </td>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <div class="avatar-sm me-2 bg-light rounded d-flex justify-content-center align-items-center">
                                                <i class="ri-box-3-line fs-3 text-secondary"></i>
                                            </div>
                                            <div>
                                                <h5 class="m-0 fw-semibold text-dark">@item.Nombre</h5>
                                                @if (!string.IsNullOrEmpty(item.CodigoBarras))
                                                {
                                                    <p class="m-0 text-muted small">
                                                        <i class="ri-barcode-line me-1"></i> @item.CodigoBarras
                                                    </p>
                                                }
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        <span class="text-muted fw-medium">@(item.Categoria?.Nombre ?? "-")</span>
                                    </td>
                                    <td>
                                        <h5 class="m-0">
                                            <span class="badge @badgeClass rounded-pill p-2 fs-6">
                                                @item.Stock <small class="fw-normal">(@stockText)</small>
                                            </span>
                                        </h5>
                                    </td>
                                    <td class="fw-semibold">@item.Precio.ToString("C", cultura)</td>
                                    <td class="fw-bold text-primary">@valorInventario.ToString("C", cultura)</td>
                                    <td class="text-end">
                                        <div class="btn-group">
                                            <a href="@Url.Action("Entrada", new { id = item.Id })" class="btn btn-sm btn-soft-success" data-bs-toggle="tooltip" title="Registrar Entrada">
                                                <i class="ri-download-2-line"></i>
                                            </a>
                                            <a href="@Url.Action("Salida", new { id = item.Id })" class="btn btn-sm btn-soft-danger" data-bs-toggle="tooltip" title="Registrar Salida">
                                                <i class="ri-upload-2-line"></i>
                                            </a>
                                            <a href="@Url.Action("Ajuste", new { id = item.Id })" class="btn btn-sm btn-soft-warning" data-bs-toggle="tooltip" title="Ajuste Manual">
                                                <i class="ri-equalizer-line"></i>
                                            </a>
                                            <a href="@Url.Action("Kardex", new { id = item.Id })" class="btn btn-sm btn-primary" data-bs-toggle="tooltip" title="Ver Kardex">
                                                <i class="ri-file-list-3-line"></i> Kardex
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            var table = $('#inventario-datatable').DataTable({
                "language": {
                    "url": "//cdn.datatables.net/plug-ins/1.13.6/i18n/es-ES.json"
                },
                "pageLength": 10,
                "order": [[ 3, "asc" ]] // Ordenar por stock por defecto (menor a mayor para ver agostados)
            });
            $('[data-bs-toggle="tooltip"]').tooltip();
        });
    </script>
}
