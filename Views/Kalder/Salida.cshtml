@model Facturapro.Models.Entities.Producto

@{
    ViewData["Title"] = "Registrar Salida - Kalder";
}

<div class="row">
    <div class="col-12">
        <div class="page-title-box">
            <div class="page-title-right">
                <a href="@Url.Action("Inventario")" class="btn btn-secondary">
                    <i class="ri-arrow-go-back-line me-1"></i> Volver
                </a>
            </div>
            <h4 class="page-title">
                <i class="ri-upload-2-line me-1 text-danger"></i> Registrar Salida
            </h4>
        </div>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-xl-6 col-md-8">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-light">
                <h4 class="card-title m-0 fw-semibold">@Model.Nombre</h4>
            </div>
            <div class="card-body">
                <div class="bg-light p-3 rounded mb-4 d-flex justify-content-between align-items-center border border-light">
                    <div>
                        <span class="text-muted small d-block">Código</span>
                        <span class="fw-semibold text-dark">@Model.Codigo</span>
                    </div>
                    <div class="text-end">
                        <span class="text-muted small d-block">Stock Disponible</span>
                        <h4 class="m-0 @(Model.Stock <= 5 ? "text-danger" : "text-dark") fw-bold">@Model.Stock <small class="text-muted fs-6">unidades</small></h4>
                    </div>
                </div>

                <form asp-action="Salida" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.Id" />

                    <div class="mb-3">
                        <label class="form-label fw-medium text-dark">Cantidad a Retirar <span class="text-danger">*</span></label>
                        <input type="number" name="cantidad" class="form-control form-control-lg form-control-light" min="1" max="@Model.Stock" required autofocus @(Model.Stock == 0 ? "disabled" : "") />
                        @if (Model.Stock == 0)
                        {
                            <div class="form-text text-danger"><i class="ri-error-warning-line me-1"></i> No hay stock disponible para retirar.</div>
                        }
                        else
                        {
                            <div class="form-text text-muted">Máximo disponible: <strong>@Model.Stock</strong> unidades.</div>
                        }
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-medium text-dark">Motivo / Notas</label>
                        <textarea name="motivo" class="form-control form-control-light" rows="3" placeholder="Motivo de la salida (ej. Descarte por daño, consumo interno)..." @(Model.Stock == 0 ? "disabled" : "")></textarea>
                    </div>

                    <div class="d-flex justify-content-end gap-2">
                        <a href="@Url.Action("Inventario")" class="btn btn-light">Cancelar</a>
                        <button type="submit" class="btn btn-danger" @(Model.Stock == 0 ? "disabled" : "")>
                            <i class="ri-upload-2-line me-1"></i> Registrar Salida
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
