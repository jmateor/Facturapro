@model IEnumerable<Facturapro.Models.Entities.MovimientoInventario>

@{
    ViewData["Title"] = "Historial de Movimientos - Kalder";
    var productos = ViewData["Productos"] as List<Facturapro.Models.Entities.Producto> ?? new List<Facturapro.Models.Entities.Producto>();
    var tiposMovimiento = ViewData["TiposMovimiento"] as TipoMovimiento[] ?? Array.Empty<TipoMovimiento>();
    var cultura = new System.Globalization.CultureInfo("es-DO");
}

<!-- Page Header -->
<div class="page-header-title">
    <div class="d-flex align-items-center justify-content-between">
        <div>
            <h4 class="page-title mb-1">
                <i class="ri-history-line me-1"></i>
                Historial de Movimientos
            </h4>
            <p class="text-muted mb-0">Registro de todas las operaciones de inventario</p>
        </div>
        <div>
            <a href="@Url.Action("Index")" class="btn btn-soft-secondary">
                <i class="ri-arrow-left-line me-1"></i> Volver a Kalder
            </a>
        </div>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="row">
        <div class="col-12">
            <div class="alert alert-success border-0 alert-dismissible fade show" role="alert">
                <i class="ri-checkbox-circle-line me-2"></i>
                @TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        </div>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="row">
        <div class="col-12">
            <div class="alert alert-danger border-0 alert-dismissible fade show" role="alert">
                <i class="ri-error-warning-line me-2"></i>
                @TempData["ErrorMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        </div>
    </div>
}

<!-- Resumen de Movimientos -->
<div class="row g-3 mb-3">
    <div class="col-md-3">
        <div class="card">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <p class="text-muted mb-0 small">Total Movimientos</p>
                        <h4 class="mb-0 fw-bold">@Model.Count()</h4>
                    </div>
                    <div class="avatar-md bg-primary text-white rounded-circle d-flex align-items-center justify-content-center">
                        <i class="ri-history-line fs-4"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <p class="text-muted mb-0 small">Entradas</p>
                        <h4 class="mb-0 fw-bold text-success">@Model.Count(m => m.TipoMovimiento.ToString().Contains("Entrada"))</h4>
                    </div>
                    <div class="avatar-md bg-success text-white rounded-circle d-flex align-items-center justify-content-center">
                        <i class="ri-arrow-down-circle-line fs-4"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <p class="text-muted mb-0 small">Salidas</p>
                        <h4 class="mb-0 fw-bold text-danger">@Model.Count(m => m.TipoMovimiento.ToString().Contains("Salida"))</h4>
                    </div>
                    <div class="avatar-md bg-danger text-white rounded-circle d-flex align-items-center justify-content-center">
                        <i class="ri-arrow-up-circle-line fs-4"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <p class="text-muted mb-0 small">Ajustes</p>
                        <h4 class="mb-0 fw-bold text-warning">@Model.Count(m => m.TipoMovimiento.ToString().Contains("Ajuste"))</h4>
                    </div>
                    <div class="avatar-md bg-warning text-white rounded-circle d-flex align-items-center justify-content-center">
                        <i class="ri-equalizer-line fs-4"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Filtros -->
<div class="card mb-3">
    <div class="card-body">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-3">
                <label class="form-label small">Producto</label>
                <select name="productoId" class="form-select">
                    <option value="">Todos los productos</option>
                    @foreach (var prod in productos)
                    {
                        if (Context.Request.Query["productoId"] == prod.Id.ToString())
                        {
                            <option value="@prod.Id" selected>@prod.Nombre</option>
                        }
                        else
                        {
                            <option value="@prod.Id">@prod.Nombre</option>
                        }
                    }
                </select>
            </div>

            <div class="col-md-2">
                <label class="form-label small">Tipo</label>
                <select name="tipoMovimiento" class="form-select">
                    <option value="">Todos</option>
                    @foreach (var tipo in tiposMovimiento)
                    {
                        if (Context.Request.Query["tipoMovimiento"] == tipo.ToString())
                        {
                            <option value="@tipo.ToString()" selected>@tipo.ToString()</option>
                        }
                        else
                        {
                            <option value="@tipo.ToString()">@tipo.ToString()</option>
                        }
                    }
                </select>
            </div>

            <div class="col-md-2">
                <label class="form-label small">Desde</label>
                <input type="date" name="fechaDesde" class="form-control" value="@Context.Request.Query["fechaDesde"]" />
            </div>

            <div class="col-md-2">
                <label class="form-label small">Hasta</label>
                <input type="date" name="fechaHasta" class="form-control" value="@Context.Request.Query["fechaHasta"]" />
            </div>

            <div class="col-md-3">
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary flex-grow-1">
                        <i class="ri-filter-search-line me-1"></i> Filtrar
                    </button>
                    <a href="@Url.Action("Historial")" class="btn btn-soft-secondary" title="Limpiar filtros">
                        <i class="ri-close-line"></i>
                    </a>
                </div>
            </div>
        </form>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover table-centered mb-0">
                <thead class="table-light">
                    <tr>
                        <th style="width: 12%;">Fecha</th>
                        <th style="width: 20%;">Producto</th>
                        <th style="width: 12%;" class="text-center">Tipo</th>
                        <th style="width: 10%;" class="text-center">Cantidad</th>
                        <th style="width: 12%;" class="text-center">Stock Ant.</th>
                        <th style="width: 12%;" class="text-center">Stock Nuevo</th>
                        <th style="width: 12%;">Motivo</th>
                        <th style="width: 10%;">Usuario</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var mov in Model)
                    {
                        var esEntrada = mov.TipoMovimiento == TipoMovimiento.EntradaCompra ||
                                        mov.TipoMovimiento == TipoMovimiento.EntradaAjuste ||
                                        mov.TipoMovimiento == TipoMovimiento.EntradaDevolucion;
                        var tipoClase = esEntrada ? "entrada" : (mov.TipoMovimiento.ToString().Contains("Ajuste") ? "ajuste" : "salida");
                        var signo = esEntrada ? "+" : "-";
                        var colorCantidad = esEntrada ? "text-success" : "text-danger";

                        <tr>
                            <td>
                                <div class="d-flex align-items-center">
                                    <i class="ri-calendar-line me-2 text-muted"></i>
                                    <div>
                                        <div class="fw-semibold">@mov.FechaMovimiento.ToString("dd/MM/yyyy")</div>
                                        <small class="text-muted">@mov.FechaMovimiento.ToString("HH:mm")</small>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <div class="d-flex align-items-center">
                                    <div class="avatar-sm bg-soft-primary text-primary rounded-circle d-flex align-items-center justify-content-center me-2" style="width: 32px; height: 32px;">
                                        <i class="ri-box-3-line"></i>
                                    </div>
                                    <span class="fw-semibold">@(mov.Producto?.Nombre ?? "N/A")</span>
                                </div>
                            </td>
                            <td class="text-center">
                                @if (tipoClase == "entrada")
                                {
                                    <span class="badge bg-success-soft text-success">
                                        <i class="ri-arrow-down-circle-fill me-1"></i>@mov.TipoMovimiento.ToString()
                                    </span>
                                }
                                else if (tipoClase == "ajuste")
                                {
                                    <span class="badge bg-warning-soft text-warning">
                                        <i class="ri-equalizer-fill me-1"></i>@mov.TipoMovimiento.ToString()
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-danger-soft text-danger">
                                        <i class="ri-arrow-up-circle-fill me-1"></i>@mov.TipoMovimiento.ToString()
                                    </span>
                                }
                            </td>
                            <td class="text-center">
                                <span class="fw-bold @colorCantidad">
                                    @signo@mov.Cantidad
                                </span>
                            </td>
                            <td class="text-center">
                                <span class="text-muted">@mov.StockAnterior</span>
                            </td>
                            <td class="text-center">
                                <span class="fw-semibold">@(mov.StockNuevo > mov.StockAnterior ? "text-success" : mov.StockNuevo < mov.StockAnterior ? "text-danger" : "") @mov.StockNuevo</span>
                            </td>
                            <td>
                                <span class="text-muted small">@(string.IsNullOrEmpty(mov.Motivo) ? "-" : mov.Motivo)</span>
                            </td>
                            <td>
                                <div class="d-flex align-items-center">
                                    <div class="avatar-xs bg-secondary text-white rounded-circle d-flex align-items-center justify-content-center me-2" style="width: 24px; height: 24px; font-size: 0.65rem;">
                                        @(mov.UsuarioRegistro?.Substring(0, 1).ToUpper() ?? "U")
                                    </div>
                                    <span class="small">@mov.UsuarioRegistro</span>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (!Model.Any())
        {
            <div class="text-center py-5">
                <div class="avatar-lg bg-soft-primary rounded-circle mb-3 mx-auto d-inline-flex" style="width: 100px; height: 100px;">
                    <i class="ri-history-line display-4 text-primary"></i>
                </div>
                <h5 class="fw-semibold">Sin movimientos registrados</h5>
                <p class="text-muted mb-3">No hay movimientos de inventario con los filtros seleccionados</p>
                <a href="@Url.Action("Historial")" class="btn btn-primary">
                    <i class="ri-refresh-line me-1"></i> Ver todos los movimientos
                </a>
            </div>
        }
    </div>
</div>
