@model Facturapro.Models.Entities.Producto

@{
    ViewData["Title"] = "Ajustar Inventario - Kalder";
}

<div class="page-header">
    <div class="page-title">
        <h1>Ajustar Inventario</h1>
        <p>Corregir cantidades de stock</p>
    </div>
    <div class="page-actions">
        <a href="@Url.Action("Inventario")" class="btn btn-secondary">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
            </svg>
            Volver
        </a>
    </div>
</div>

<div class="card" style="max-width: 600px; margin: 0 auto;">
    <div class="card-header">
        <h3 class="card-title">@Model.Nombre</h3>
    </div>
    <div class="card-body">
        <div style="background: var(--gray-50); padding: var(--space-lg); border-radius: var(--radius); margin-bottom: var(--space-lg);">
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-md);">
                <div>
                    <div style="font-size: 0.75rem; color: var(--text-muted);">Código</div>
                    <div style="font-weight: 600;">@Model.Codigo</div>
                </div>
                <div>
                    <div style="font-size: 0.75rem; color: var(--text-muted);">Stock Actual</div>
                    <div style="font-weight: 600; font-size: 1.25rem;">@Model.Stock unidades</div>
                </div>
            </div>
        </div>

        <div style="background: rgb(245 158 11 / 0.1); border: 1px solid rgb(245 158 11 / 0.3); border-radius: var(--radius); padding: var(--space-md); margin-bottom: var(--space-lg);">
            <div style="display: flex; align-items: center; gap: var(--space-sm); color: var(--warning-color); font-size: 0.875rem;">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z" />
                </svg>
                <strong>¡Atención!</strong> Los ajustes de inventario deben usarse solo para corregir discrepancias.
            </div>
        </div>

        <form asp-action="Ajuste" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@Model.Id" />

            <div class="form-group">
                <label class="form-label required">Nuevo Stock</label>
                <input type="number" name="nuevoStock" class="form-input" min="0" value="@Model.Stock" required autofocus />
                <span class="form-hint">Ingrese la cantidad correcta de stock. El sistema calculará la diferencia.</span>
            </div>

            <div class="form-group">
                <label class="form-label required">Motivo del Ajuste</label>
                <textarea name="motivo" class="form-textarea" rows="3" placeholder="Explique por qué se realiza este ajuste..." required></textarea>
                <span class="form-hint">Este campo es obligatorio para auditoría</span>
            </div>

            <div class="form-actions" style="display: flex; justify-content: flex-end; gap: var(--space-md);">
                <a href="@Url.Action("Inventario")" class="btn btn-secondary">Cancelar</a>
                <button type="submit" class="btn btn-warning">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182m0-4.991v4.99" />
                    </svg>
                    Realizar Ajuste
                </button>
            </div>
        </form>
    </div>
</div>
