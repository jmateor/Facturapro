@model Facturapro.Models.Entities.Producto

@{
    ViewData["Title"] = "Ajustar Inventario - Kalder";
}

<div class="row">
    <div class="col-12">
        <div class="page-title-box">
            <div class="page-title-right">
                <a href="@Url.Action("Inventario")" class="btn btn-secondary">
                    <i class="ri-arrow-go-back-line me-1"></i> Volver
                </a>
            </div>
            <h4 class="page-title">
                <i class="ri-equalizer-line me-1 text-warning"></i> Ajustar Inventario
            </h4>
        </div>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-xl-6 col-md-8">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-light">
                <h4 class="card-title m-0 fw-semibold">@Model.Nombre</h4>
            </div>
            <div class="card-body">
                <div class="bg-light p-3 rounded mb-3 d-flex justify-content-between align-items-center border border-light">
                    <div>
                        <span class="text-muted small d-block">Código</span>
                        <span class="fw-semibold text-dark">@Model.Codigo</span>
                    </div>
                    <div class="text-end">
                        <span class="text-muted small d-block">Stock Actual</span>
                        <h4 class="m-0 text-dark fw-bold">@Model.Stock <small class="text-muted fs-6">unidades</small></h4>
                    </div>
                </div>

                <div class="alert alert-warning border-0 d-flex align-items-center" role="alert">
                    <i class="ri-error-warning-fill fs-4 me-2"></i>
                    <div>
                        <strong>¡Atención!</strong> Los ajustes de inventario deben usarse solo para corregir discrepancias reales tras un conteo físico o auditoría.
                    </div>
                </div>

                <form asp-action="Ajuste" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.Id" />

                    <div class="mb-3">
                        <label class="form-label fw-medium text-dark">Nuevo Stock (Físico real) <span class="text-danger">*</span></label>
                        <input type="number" name="nuevoStock" class="form-control form-control-lg form-control-light text-center" min="0" value="@Model.Stock" required autofocus />
                        <div class="form-text text-muted">Ingrese la cantidad <strong>correcta total</strong> en stock. El sistema calculará la diferencia y registrará el ajuste.</div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-medium text-dark">Motivo del Ajuste <span class="text-danger">*</span></label>
                        <textarea name="motivo" class="form-control form-control-light" rows="3" placeholder="Explique por qué se realiza este ajuste..." required></textarea>
                        <div class="form-text text-danger">Este campo es obligatorio para el registro de auditoría.</div>
                    </div>

                    <div class="d-flex justify-content-end gap-2">
                        <a href="@Url.Action("Inventario")" class="btn btn-light">Cancelar</a>
                        <button type="submit" class="btn btn-warning">
                            <i class="ri-equalizer-line me-1"></i> Realizar Ajuste
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
