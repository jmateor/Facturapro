@model IEnumerable<Facturapro.Models.ViewModels.ClienteViewModel>

@{
    ViewData["Title"] = "Clientes";
    var cultura = new System.Globalization.CultureInfo("es-DO");
}

<!-- Page Header -->
<div class="page-header-title">
    <div class="d-flex align-items-center justify-content-between">
        <div>
            <h4 class="page-title mb-1">
                <i class="ri-user-3-line me-1"></i>
                Clientes
            </h4>
            <p class="text-muted mb-0">Gestiona tu base de datos de clientes</p>
        </div>
        <div>
            <a href="@Url.Action("Create", "Clientes")" class="btn btn-primary">
                <i class="ri-user-add-line me-1"></i>
                Nuevo Cliente
            </a>
        </div>
    </div>
</div>


<div class="card">
    <div class="card-body">
        <!-- Filtros y Búsqueda -->
        <div class="row g-2 mb-3 align-items-center">
            <div class="col-md-6">
                <div class="d-flex gap-2">
                    <div class="position-relative flex-grow-1">
                        <input type="text" id="buscarCliente" class="form-control" placeholder="Buscar por nombre, RNC o email..." />
                        <i class="ri-search-line position-absolute top-50 end-0 translate-middle-y me-3 text-muted"></i>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <select id="filtrarEstado" class="form-select">
                    <option value="">Todos los estados</option>
                    <option value="activo">Activos</option>
                    <option value="inactivo">Inactivos</option>
                </select>
            </div>
            <div class="col-md-3 text-end">
                <span class="text-muted small">
                    <i class="ri-database-2-line me-1"></i>
                    <span id="totalRegistros">@Model.Count()</span> registros
                </span>
            </div>
        </div>

        <div class="table-responsive-sm">
            <table class="table table-hover table-centered mb-0" id="tablaClientes">
                <thead class="table-light">
                    <tr>
                        <th style="width: 30%;">Cliente</th>
                        <th style="width: 25%;">Contacto</th>
                        <th style="width: 15%;">Ubicación</th>
                        <th style="width: 10%;" class="text-center">Facturas</th>
                        <th style="width: 10%;" class="text-end">Total Facturado</th>
                        <th style="width: 5%;" class="text-center">Estado</th>
                        <th style="width: 10%;" class="text-end">Acciones</th>
                    </tr>
                </thead>
                <tbody id="tablaClientesBody">
                    @foreach (var item in Model)
                    {
                        <tr class="cliente-row">
                            <td>
                                <div class="d-flex align-items-center">
                                    <div class="flex-shrink-0">
                                        <div class="avatar-sm rounded-circle bg-primary text-white d-flex align-items-center justify-content-center fw-bold" style="width: 42px; height: 42px;">
                                            @item.Nombre.Substring(0, 1).ToUpper()
                                        </div>
                                    </div>
                                    <div class="flex-grow-1 ms-3">
                                        <h6 class="mb-0 fw-semibold">@item.Nombre</h6>
                                        <small class="text-muted">@item.NIF</small>
                                    </div>
                                </div>
                            </td>
                            <td>
                                @if (!string.IsNullOrEmpty(item.Email))
                                {
                                    <div class="text-muted mb-1">
                                        <i class="ri-mail-line me-1"></i>
                                        <a href="mailto:@item.Email" class="text-decoration-none">@item.Email</a>
                                    </div>
                                }
                                @if (!string.IsNullOrEmpty(item.Telefono))
                                {
                                    <div class="text-muted">
                                        <i class="ri-phone-line me-1"></i>@item.Telefono
                                    </div>
                                }
                            </td>
                            <td>
                                <span class="text-muted">
                                    <i class="ri-map-pin-line me-1"></i>
                                    @(item.Ciudad ?? "-")
                                </span>
                            </td>
                            <td class="text-center">
                                <span class="badge bg-soft-primary text-primary">@item.TotalFacturas</span>
                            </td>
                            <td class="text-end">
                                <span class="fw-bold text-success">@item.TotalFacturado.ToString("C", cultura)</span>
                            </td>
                            <td class="text-center">
                                @if (item.Activo)
                                {
                                    <span class="badge bg-success-soft text-success">
                                        <i class="ri-checkbox-circle-fill me-1"></i>Activo
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary-soft text-secondary">
                                        <i class="ri-stop-circle-fill me-1"></i>Inactivo
                                    </span>
                                }
                            </td>
                            <td class="text-end">
                                <div class="d-flex gap-1 justify-content-end">
                                    <a href="/Clientes/Edit/${item.id}" class="btn btn-sm btn-soft-primary"><i class="ri-edit-line"></i></a>
                                    <a href="/Clientes/Details/${item.id}" class="btn btn-sm btn-soft-info"><i class="ri-eye-line"></i></a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div id="noResults" style="display: none;">
            <div class="text-center py-5">
                <div class="avatar-lg bg-soft-primary rounded-circle mb-3 mx-auto d-inline-flex" style="width: 100px; height: 100px;">
                    <i class="ri-search-line display-4 text-primary"></i>
                </div>
                <h5 class="fw-semibold">No se encontraron clientes</h5>
                <p class="text-muted mb-3">Intenta con otros criterios de búsqueda</p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let debounceTimer;
        
        document.getElementById('buscarCliente').addEventListener('input', function() {
            clearTimeout(debounceTimer);
            debounceTimer = setTimeout(() => cargarClientes(), 300);
        });

        document.getElementById('filtrarEstado').addEventListener('change', () => cargarClientes());

        function cargarClientes() {
            const q = document.getElementById('buscarCliente').value;
            const estado = document.getElementById('filtrarEstado').value;
            const body = document.getElementById('tablaClientesBody');
            const noResults = document.getElementById('noResults');

            window.Skeleton.show('#tablaClientesBody', 'tableRow', 8);

            fetch(`/Clientes/GetClientesJson?q=${encodeURIComponent(q)}&estado=${estado}`)
                .then(r => r.json())
                .then(clientes => {
                    document.getElementById('totalRegistros').textContent = clientes.length;
                    
                    if (clientes.length === 0) {
                        body.innerHTML = '';
                        noResults.style.display = 'block';
                        return;
                    }

                    noResults.style.display = 'none';
                    const html = clientes.map(item => `
                        <tr>
                            <td>
                                <div class="d-flex align-items-center">
                                    <div class="flex-shrink-0">
                                        <div class="avatar-sm rounded-circle bg-primary text-white d-flex align-items-center justify-content-center fw-bold" style="width: 42px; height: 42px;">
                                            ${item.nombre.substring(0, 1).toUpperCase()}
                                        </div>
                                    </div>
                                    <div class="flex-grow-1 ms-3">
                                        <h6 class="mb-0 fw-semibold">${item.nombre}</h6>
                                        <small class="text-muted">${item.nif || ''}</small>
                                    </div>
                                </div>
                            </td>
                            <td>
                                ${item.email ? `<div class="text-muted mb-1"><i class="ri-mail-line me-1"></i>${item.email}</div>` : ''}
                                ${item.telefono ? `<div class="text-muted"><i class="ri-phone-line me-1"></i>${item.telefono}</div>` : ''}
                            </td>
                            <td><span class="text-muted"><i class="ri-map-pin-line me-1"></i>${item.ciudad || '-'}</span></td>
                            <td class="text-center"><span class="badge bg-soft-primary text-primary">${item.totalFacturas}</span></td>
                            <td class="text-end"><span class="fw-bold text-success">${new Intl.NumberFormat('es-DO', { style: 'currency', currency: 'DOP' }).format(item.totalFacturado)}</span></td>
                            <td class="text-center">
                                <span class="badge ${item.activo ? 'bg-success-soft text-success' : 'bg-secondary-soft text-secondary'}">
                                    <i class="${item.activo ? 'ri-checkbox-circle-fill' : 'ri-stop-circle-fill'} me-1"></i>${item.activo ? 'Activo' : 'Inactivo'}
                                </span>
                            </td>
                            <td class="text-end">
                                <div class="d-flex gap-1 justify-content-end">
                                    <a href="/Clientes/Edit/${item.id}" class="btn btn-sm btn-soft-primary"><i class="ri-edit-line"></i></a>
                                    <a href="/Clientes/Details/${item.id}" class="btn btn-sm btn-soft-info"><i class="ri-eye-line"></i></a>
                                </div>
                            </td>
                        </tr>
                    `).join('');

                    window.Skeleton.hide('#tablaClientesBody', html);
                });
        }
    </script>
}
