@model IEnumerable<Facturapro.Models.ViewModels.ClienteViewModel>

@{
    ViewData["Title"] = "Clientes";
    var cultura = new System.Globalization.CultureInfo("es-DO");
}

<!-- Page Header -->
<div class="page-header-title">
    <div class="d-flex align-items-center justify-content-between">
        <div>
            <h4 class="page-title mb-1">
                <i class="ri-user-3-line me-1"></i>
                Clientes
            </h4>
            <p class="text-muted mb-0">Gestiona tu base de datos de clientes</p>
        </div>
        <div>
            <a href="@Url.Action("Create", "Clientes")" class="btn btn-primary">
                <i class="ri-user-add-line me-1"></i>
                Nuevo Cliente
            </a>
        </div>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="row">
        <div class="col-12">
            <div class="alert alert-success border-0 alert-dismissible fade show" role="alert">
                <i class="ri-checkbox-circle-line me-2"></i>
                @TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        </div>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="row">
        <div class="col-12">
            <div class="alert alert-danger border-0 alert-dismissible fade show" role="alert">
                <i class="ri-error-warning-line me-2"></i>
                @TempData["ErrorMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        </div>
    </div>
}

<div class="card">
    <div class="card-body">
        <!-- Filtros y Búsqueda -->
        <div class="row g-2 mb-3 align-items-center">
            <div class="col-md-6">
                <div class="d-flex gap-2">
                    <div class="position-relative flex-grow-1">
                        <input type="text" id="buscarCliente" class="form-control" placeholder="Buscar por nombre, RNC o email..." />
                        <i class="ri-search-line position-absolute top-50 end-0 translate-middle-y me-3 text-muted"></i>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <select id="filtrarEstado" class="form-select">
                    <option value="">Todos los estados</option>
                    <option value="activo">Activos</option>
                    <option value="inactivo">Inactivos</option>
                </select>
            </div>
            <div class="col-md-3 text-end">
                <span class="text-muted small">
                    <i class="ri-database-2-line me-1"></i>
                    <span id="totalRegistros">@Model.Count()</span> registros
                </span>
            </div>
        </div>

        <div class="table-responsive-sm">
            <table class="table table-hover table-centered mb-0" id="tablaClientes">
                <thead class="table-light">
                    <tr>
                        <th style="width: 30%;">Cliente</th>
                        <th style="width: 25%;">Contacto</th>
                        <th style="width: 15%;">Ubicación</th>
                        <th style="width: 10%;" class="text-center">Facturas</th>
                        <th style="width: 10%;" class="text-end">Total Facturado</th>
                        <th style="width: 5%;" class="text-center">Estado</th>
                        <th style="width: 10%;" class="text-end">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr class="cliente-row" data-estado="@(item.Activo ? "activo" : "inactivo")" data-nombre="@item.Nombre.ToLower()" data-nif="@item.NIF?.ToLower()" data-email="@item.Email?.ToLower()">
                            <td>
                                <div class="d-flex align-items-center">
                                    <div class="flex-shrink-0">
                                        <div class="avatar-sm rounded-circle bg-primary text-white d-flex align-items-center justify-content-center fw-bold" style="width: 42px; height: 42px;">
                                            @item.Nombre.Substring(0, 1).ToUpper()
                                        </div>
                                    </div>
                                    <div class="flex-grow-1 ms-3">
                                        <h6 class="mb-0 fw-semibold">@item.Nombre</h6>
                                        <small class="text-muted">@item.NIF</small>
                                    </div>
                                </div>
                            </td>
                            <td>
                                @if (!string.IsNullOrEmpty(item.Email))
                                {
                                    <div class="text-muted mb-1">
                                        <i class="ri-mail-line me-1"></i>
                                        <a href="mailto:@item.Email" class="text-decoration-none">@item.Email</a>
                                    </div>
                                }
                                @if (!string.IsNullOrEmpty(item.Telefono))
                                {
                                    <div class="text-muted">
                                        <i class="ri-phone-line me-1"></i>@item.Telefono
                                    </div>
                                }
                                @if (string.IsNullOrEmpty(item.Email) && string.IsNullOrEmpty(item.Telefono))
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                            <td>
                                <span class="text-muted">
                                    <i class="ri-map-pin-line me-1"></i>
                                    @(item.Ciudad ?? "-")
                                </span>
                            </td>
                            <td class="text-center">
                                <span class="badge bg-soft-primary text-primary">@item.TotalFacturas</span>
                            </td>
                            <td class="text-end">
                                <span class="fw-bold text-success">@item.TotalFacturado.ToString("C", cultura)</span>
                            </td>
                            <td class="text-center">
                                @if (item.Activo)
                                {
                                    <span class="badge bg-success-soft text-success">
                                        <i class="ri-checkbox-circle-fill me-1"></i>Activo
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary-soft text-secondary">
                                        <i class="ri-stop-circle-fill me-1"></i>Inactivo
                                    </span>
                                }
                            </td>
                            <td class="text-end">
                                <div class="d-flex gap-1 justify-content-end">
                                    <a href="@Url.Action("Edit", new { id = item.Id })" class="btn btn-sm btn-soft-primary" title="Editar">
                                        <i class="ri-edit-line"></i>
                                    </a>
                                    <a href="@Url.Action("Details", new { id = item.Id })" class="btn btn-sm btn-soft-info" title="Ver detalles">
                                        <i class="ri-eye-line"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (!Model.Any())
        {
            <div class="text-center py-5">
                <div class="avatar-lg bg-soft-primary rounded-circle mb-3 mx-auto d-inline-flex" style="width: 100px; height: 100px;">
                    <i class="ri-user-3-line display-4 text-primary"></i>
                </div>
                <h5 class="fw-semibold">No hay clientes registrados</h5>
                <p class="text-muted mb-3">Comienza agregando tu primer cliente al sistema</p>
                <a href="@Url.Action("Create")" class="btn btn-primary">
                    <i class="ri-user-add-line me-1"></i>
                    Crear primer cliente
                </a>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        // Búsqueda de clientes
        document.getElementById('buscarCliente').addEventListener('input', function() {
            const filtro = this.value.toLowerCase();
            const filas = document.querySelectorAll('.cliente-row');

            filas.forEach(function(fila) {
                const nombre = fila.getAttribute('data-nombre');
                const nif = fila.getAttribute('data-nif');
                const email = fila.getAttribute('data-email');

                if (nombre?.includes(filtro) || nif?.includes(filtro) || email?.includes(filtro)) {
                    fila.style.display = '';
                } else {
                    fila.style.display = 'none';
                }
            });

            actualizarContador();
        });

        // Filtrar por estado
        document.getElementById('filtrarEstado').addEventListener('change', function() {
            const filtro = this.value;
            const filas = document.querySelectorAll('.cliente-row');

            filas.forEach(function(fila) {
                const estado = fila.getAttribute('data-estado');

                if (filtro === '' || estado === filtro) {
                    fila.style.display = '';
                } else {
                    fila.style.display = 'none';
                }
            });

            actualizarContador();
        });

        // Actualizar contador de registros visibles
        function actualizarContador() {
            const visibles = document.querySelectorAll('.cliente-row[style=""]').length;
            const total = document.querySelectorAll('.cliente-row').length;
            const contador = document.getElementById('totalRegistros');

            if (contador) {
                contador.textContent = visibles === total ? total : `${visibles}/${total}`;
            }
        }

        // Confirmar eliminación
        document.querySelectorAll('.btn-soft-danger').forEach(function(btn) {
            btn.addEventListener('click', function(e) {
                if (!confirm('¿Está seguro de eliminar este cliente?')) {
                    e.preventDefault();
                }
            });
        });
    </script>
}
