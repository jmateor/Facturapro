@model Facturapro.Models.Entities.Cliente

@{
    ViewData["Title"] = "Eliminar Cliente";
}

<div class="page-header">
    <div class="page-title">
        <h1>Eliminar Cliente</h1>
        <p style="color: var(--error-color);">⚠️ Esta acción no se puede deshacer</p>
    </div>
</div>

<div class="card" style="border-color: var(--error-color);">
    <div class="card-body">
        <h3>¿Está seguro de que desea eliminar este cliente?</h3>
        <div style="margin-top: var(--space-lg);">
            <dl style="display: grid; grid-template-columns: 150px 1fr; gap: var(--space);">
                <dt style="color: var(--text-muted);">Nombre:</dt>
                <dd style="font-weight: 600;">@Model.Nombre</dd>

                @if (!string.IsNullOrEmpty(Model.NIF))
                {
                    <dt style="color: var(--text-muted);">NIF/CIF:</dt>
                    <dd>@Model.NIF</dd>
                }

                @if (!string.IsNullOrEmpty(Model.Email))
                {
                    <dt style="color: var(--text-muted);">Email:</dt>
                    <dd>@Model.Email</dd>
                }

                <dt style="color: var(--text-muted);">Fecha de alta:</dt>
                <dd>@Model.FechaAlta.ToString("dd/MM/yyyy")</dd>
            </dl>
        </div>

        <form asp-action="Delete" method="post" style="margin-top: var(--space-xl); display: flex; gap: var(--space);">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />

            <button type="submit" class="btn btn-danger">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
                </svg>
                Sí, Eliminar
            </button>
            <a href="@Url.Action("Index")" class="btn btn-secondary">Cancelar</a>
        </form>
    </div>
</div>
