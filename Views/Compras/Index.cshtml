@model IEnumerable<Facturapro.Models.Entities.Compra>

@{
    ViewData["Title"] = "Compras";
    var estados = ViewData["Estados"] as List<EstadoCompra> ?? new List<EstadoCompra>();
}

<div class="page-header">
    <div class="page-title">
        <h1>Compras y Abastecimiento</h1>
        <p>Gestiona el inventario y las relaciones con tus proveedores</p>
    </div>
    <div class="page-actions">
        <a href="@Url.Action("Create", "Compras")" class="btn btn-primary">
            <i class="ri-add-line"></i>
            Nueva Compra
        </a>
    </div>
</div>

<!-- Dashboard de Resumen -->
<div class="row" style="margin-bottom: var(--space-lg);">
    <div class="col">
        <div class="card bg-primary-soft">
            <div class="card-body">
                <div class="d-flex align-items-center gap-1">
                    <div class="icon-box bg-primary text-white">
                        <i class="ri-shopping-bag-3-line"></i>
                    </div>
                    <div>
                        <p class="text-sm text-secondary" style="margin:0;">Total Mes</p>
                        <h3 style="margin:0;">@(((decimal)ViewBag.TotalComprasMes).ToString("C0"))</h3>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col">
        <div class="card bg-warning-soft">
            <div class="card-body">
                <div class="d-flex align-items-center gap-1">
                    <div class="icon-box bg-warning text-white">
                        <i class="ri-time-line"></i>
                    </div>
                    <div>
                        <p class="text-sm text-secondary" style="margin:0;">Pendientes Recibir</p>
                        <h3 style="margin:0;">@ViewBag.PendientesRecibir</h3>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col">
        <div class="card bg-success-soft">
            <div class="card-body">
                <div class="d-flex align-items-center gap-1">
                    <div class="icon-box bg-success text-white">
                        <i class="ri-truck-line"></i>
                    </div>
                    <div>
                        <p class="text-sm text-secondary" style="margin:0;">Proveedores</p>
                        <h3 style="margin:0;">@ViewBag.ProveedoresCount</h3>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col">
        <div class="card bg-info-soft">
            <div class="card-body">
                <div class="d-flex align-items-center gap-1">
                    <div class="icon-box bg-info text-white">
                        <i class="ri-line-chart-line"></i>
                    </div>
                    <div>
                        <p class="text-sm text-secondary" style="margin:0;">Gasto Anual</p>
                        <h3 style="margin:0;">@(((decimal)ViewBag.TotalGastoAnual).ToString("C0"))</h3>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">
        <i class="ri-checkbox-circle-line"></i>
        @TempData["SuccessMessage"]
    </div>
}

<!-- Filtros Avanzados -->
<div class="card" style="margin-bottom: var(--space-lg);">
    <div class="card-body">
        <form method="get" class="d-flex gap-1" style="flex-wrap: wrap; align-items: flex-end;">
            <div class="form-group" style="flex: 2; min-width: 250px; margin-bottom: 0;">
                <label class="form-label" style="font-size: 11px; text-transform: uppercase; color: var(--text-secondary);">Búsqueda Rápida</label>
                <div style="position: relative;">
                    <i class="ri-search-line" style="position: absolute; left: 12px; top: 50%; transform: translateY(-50%); color: var(--text-secondary);"></i>
                    <input type="text" name="buscar" class="form-input" style="padding-left: 35px;" placeholder="Número de factura o proveedor..." value="@Context.Request.Query["buscar"]" />
                </div>
            </div>
            <div class="form-group" style="flex: 1; min-width: 180px; margin-bottom: 0;">
                <label class="form-label" style="font-size: 11px; text-transform: uppercase; color: var(--text-secondary);">Estado</label>
                <select name="estado" class="form-select">
                    <option value="">Todos los estados</option>
                    @foreach (var est in estados)
                    {
                        <option value="@est" selected="@(Context.Request.Query["estado"] == est.ToString())">@est</option>
                    }
                </select>
            </div>
            <button type="submit" class="btn btn-secondary">
                <i class="ri-filter-3-line"></i>
                Filtrar
            </button>
            <a href="@Url.Action("Index")" class="btn btn-ghost" title="Limpiar filtros">
                <i class="ri-refresh-line"></i>
            </a>
        </form>
    </div>
</div>

<div class="card">
    <div class="card-body" style="padding: 0;">
        <div class="table-container">
            <table class="table">
                <thead>
                    <tr>
                        <th style="padding-left: 20px;">Factura / NCF</th>
                        <th>Proveedor</th>
                        <th>Fecha</th>
                        <th>Estado</th>
                        <th class="text-right">Total</th>
                        <th style="padding-right: 20px;" class="text-right">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="6" style="padding: 60px 0; text-align: center; color: var(--text-secondary);">
                                <div style="font-size: 48px; margin-bottom: 15px; opacity: 0.3;">
                                    <i class="ri-shopping-cart-2-line"></i>
                                </div>
                                <h4>No se encontraron compras</h4>
                                <p>Comienza registrando una nueva factura de proveedor.</p>
                                <a href="@Url.Action("Create")" class="btn btn-primary btn-sm" style="margin-top: 10px;">Registrar Primera Compra</a>
                            </td>
                        </tr>
                    }
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td style="padding-left: 20px;">
                                <div style="font-weight: 600;">@item.NumeroFactura</div>
                                <div class="text-sm text-info font-monospace">@(item.NCF ?? "SIN NCF")</div>
                            </td>
                            <td>
                                <div class="d-flex align-items-center gap-0-5">
                                    <div class="avatar-xs bg-secondary-soft text-secondary">
                                        @(item.Proveedor?.Nombre?.Substring(0, 1).ToUpper() ?? "P")
                                    </div>
                                    @item.Proveedor?.Nombre
                                </div>
                            </td>
                            <td>
                                <div class="text-sm">@item.FechaCompra.ToString("MMM dd, yyyy")</div>
                            </td>
                            <td>
                                @switch (item.Estado)
                                {
                                    case EstadoCompra.Pendiente:
                                        <span class="badge badge-warning-soft text-warning">
                                            <i class="ri-time-line"></i> Pendiente
                                        </span>
                                        break;
                                    case EstadoCompra.Recibida:
                                        <span class="badge badge-success-soft text-success">
                                            <i class="ri-checkbox-circle-line"></i> Recibida
                                        </span>
                                        break;
                                    case EstadoCompra.Cancelada:
                                        <span class="badge badge-secondary-soft text-secondary">
                                            <i class="ri-close-circle-line"></i> Cancelada
                                        </span>
                                        break;
                                }
                            </td>
                            <td class="text-right" style="font-weight: 700; font-size: 15px;">
                                @item.Total.ToString("C", new System.Globalization.CultureInfo("es-DO"))
                            </td>
                            <td style="padding-right: 20px;" class="text-right">
                                <div class="d-flex gap-0-5 justify-content-end">
                                    <a href="@Url.Action("Details", new { id = item.Id })" class="btn btn-ghost btn-sm" title="Ver Detalles">
                                        <i class="ri-eye-line"></i>
                                    </a>
                                    
                                    @if (item.Estado == EstadoCompra.Pendiente)
                                    {
                                        <form asp-action="Recibir" asp-route-id="@item.Id" method="post" style="display: inline;">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-success-soft text-success btn-sm" title="Marcar como Recibida">
                                                <i class="ri-download-2-line"></i>
                                            </button>
                                        </form>
                                    }
                                    
                                    @if (item.Estado != EstadoCompra.Cancelada)
                                    {
                                        <form asp-action="Cancelar" asp-route-id="@item.Id" method="post" style="display: inline;">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-danger-soft text-danger btn-sm" title="Cancelar Compra" onclick="return confirm('¿Está seguro de cancelar esta compra?')">
                                                <i class="ri-delete-bin-line"></i>
                                            </button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    .avatar-xs {
        width: 24px;
        height: 24px;
        border-radius: 6px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 11px;
        font-weight: bold;
    }
    
    .badge-success-soft { background: rgba(16, 183, 89, 0.1); color: #10b759 !important; border: 1px solid rgba(16, 183, 89, 0.2); }
    .badge-warning-soft { background: rgba(255, 159, 67, 0.1); color: #ff9f43 !important; border: 1px solid rgba(255, 159, 67, 0.2); }
    .badge-danger-soft { background: rgba(234, 84, 85, 0.1); color: #ea5455 !important; border: 1px solid rgba(234, 84, 85, 0.2); }
    .badge-secondary-soft { background: rgba(100, 116, 139, 0.1); color: #64748b !important; border: 1px solid rgba(100, 116, 139, 0.2); }
    .badge-info-soft { background: rgba(0, 207, 232, 0.1); color: #00cfe8 !important; border: 1px solid rgba(0, 207, 232, 0.2); }
    
    .btn-success-soft { background: rgba(16, 183, 89, 0.1); }
    .btn-success-soft:hover { background: #10b759; color: white !important; }
    
    .btn-danger-soft { background: rgba(234, 84, 85, 0.1); }
    .btn-danger-soft:hover { background: #ea5455; color: white !important; }

    .text-right { text-align: right; }
    .justify-content-end { justify-content: flex-end; }
</style>
