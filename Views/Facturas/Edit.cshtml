@model Facturapro.Models.Entities.Factura

@{
    ViewData["Title"] = "Editar Factura e-CF";
    var cultura = new System.Globalization.CultureInfo("es-DO");
    var clienteJson = Model.Cliente != null ? System.Text.Json.JsonSerializer.Serialize(new {
        Id = Model.Cliente.Id,
        Nombre = Model.Cliente.Nombre,
        RNC = Model.Cliente.RNC,
        Direccion = Model.Cliente.Direccion,
        Telefono = Model.Cliente.Telefono,
        Email = Model.Cliente.Email
    }) : "null";
}

<style>
    .glass-card {
        background: rgba(255, 255, 255, 0.95);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.2);
        box-shadow: 0 8px 32px 0 rgba(31, 38, 135, 0.07);
    }
    
    .step-indicator {
        width: 35px;
        height: 35px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: bold;
        background: #f8f9fa;
        color: #adb5bd;
        margin-right: 10px;
    }
    
    .step-item.active .step-indicator {
        background: var(--bs-primary);
        color: white;
        box-shadow: 0 0 0 4px rgba(var(--bs-primary-rgb), 0.15);
    }
    
    .step-item.completed .step-indicator {
        background: #198754;
        color: white;
    }
</style>

<!-- Stepper Container -->
<div class="row mb-4 justify-content-center">
    <div class="col-md-11">
        <div class="d-flex justify-content-between align-items-center bg-white p-3 rounded-pill shadow-sm glass-card">
            <div class="step-item completed d-flex align-items-center ms-4">
                <div class="step-indicator"><i class="ri-check-line"></i></div>
                <span class="fw-bold text-success d-none d-md-block">Encabezado</span>
            </div>
            <div class="h-px bg-success flex-grow-1 mx-3" style="height: 2px; opacity: 0.3;"></div>
            <div class="step-item active d-flex align-items-center">
                <div class="step-indicator">2</div>
                <span class="fw-bold text-primary d-none d-md-block">Líneas de Detalle</span>
            </div>
            <div class="h-px bg-light flex-grow-1 mx-3" style="height: 2px;"></div>
            <div class="step-item d-flex align-items-center me-4">
                <div class="step-indicator">3</div>
                <span class="fw-medium text-muted d-none d-md-block">Firma y Envío</span>
            </div>
        </div>
    </div>
</div>

@if (!string.IsNullOrEmpty(TempData["SuccessMessage"] as string))
{
    <div class="row">
        <div class="col-12">
            <div class="alert alert-success border-0 alert-dismissible fade show" role="alert">
                <i class="ri-checkbox-circle-line me-2"></i>
                @TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        </div>
    </div>
}

@if (!string.IsNullOrEmpty(TempData["ErrorMessage"] as string))
{
    <div class="row">
        <div class="col-12">
            <div class="alert alert-danger border-0 alert-dismissible fade show" role="alert">
                <i class="ri-error-warning-line me-2"></i>
                @TempData["ErrorMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        </div>
    </div>
}

<!-- Alertas de estado -->
@if (Model.EstadoDGII == "Firmado" || Model.EstadoDGII == "Enviado" || Model.EstadoDGII == "Aprobado")
{
    <div class="row">
        <div class="col-12">
            <div class="alert alert-warning border-0" role="alert">
                <i class="ri-lock-line me-2"></i>
                <strong>Factura @(Model.EstadoDGII):</strong> Esta factura ya ha sido @(Model.EstadoDGII.ToLower()) y no puede ser modificada. Solo puede consultar su estado o descargar los documentos.
            </div>
        </div>
    </div>
}

@if (string.IsNullOrEmpty(Model.eNCF))
{
    <div class="row">
        <div class="col-12">
            <div class="alert alert-warning border-0" role="alert">
                <i class="ri-alert-line me-2"></i>
                <strong>Sin e-CF asignado:</strong> Esta factura no tiene número e-CF. Asegúrese de que haya rangos disponibles en el módulo de Rangos DGII.
            </div>
        </div>
    </div>
}

<div class="row">
    <!-- Columna Izquierda - Formulario y Líneas -->
    <div class="col-xl-8">

        <!-- Información del Encabezado (Colapsada por defecto para dar prioridad a las líneas) -->
        <div class="card border-0 rounded-4 glass-card shadow-sm mb-4 overflow-hidden">
            <div class="card-header bg-white border-bottom py-3">
                <div class="d-flex align-items-center justify-content-between">
                    <div class="d-flex align-items-center">
                        <i class="ri-information-line me-2 text-primary fs-4"></i>
                        <h5 class="card-title mb-0 fw-bold">Encabezado</h5>
                    </div>
                    <span class="badge bg-primary-subtle text-primary rounded-pill">NCF: @Model.eNCF</span>
                </div>
            </div>
            <div class="card-body p-4">
                <div class="row g-3 small">
                    <div class="col-md-4">
                        <span class="text-muted d-block">Tipo de Comprobante</span>
                        <span class="fw-bold">@Model.TipoECFTexto</span>
                    </div>
                    <div class="col-md-4">
                        <span class="text-muted d-block">Cliente</span>
                        <span class="fw-bold">@(Model.Cliente?.Nombre ?? "Consumidor Final")</span>
                    </div>
                    <div class="col-md-4">
                        <span class="text-muted d-block">Condición Pago</span>
                        <span class="fw-bold text-primary">@(Model.TipoPago == 1 ? "Contado" : "Crédito")</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Líneas de la Factura -->
        <div class="card border-0 rounded-4 glass-card shadow-sm mb-4 overflow-hidden">
            <div class="card-header bg-white border-bottom py-3 d-flex justify-content-between align-items-center">
                <div class="d-flex align-items-center">
                    <div class="bg-success bg-opacity-10 p-2 rounded-3 me-3">
                        <i class="ri-shopping-basket-2-line text-success fs-4"></i>
                    </div>
                    <h5 class="card-title mb-0 fw-bold">Productos y Servicios</h5>
                </div>
                @if (Model.EstadoDGII != "Firmado" && Model.EstadoDGII != "Enviado" && Model.EstadoDGII != "Aprobado")
                {
                    <button type="button" class="btn btn-primary rounded-pill px-4 shadow-sm" data-bs-toggle="modal" data-bs-target="#modalAgregarLinea">
                        <i class="ri-add-line me-1"></i> Agregar Ítem
                    </button>
                }
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="bg-light text-muted small text-uppercase">
                            <tr>
                                <th class="ps-4 py-3">Descripción</th>
                                <th class="text-center py-3">Cant.</th>
                                <th class="text-end py-3">Precio</th>
                                <th class="text-end py-3">ITBIS</th>
                                <th class="text-end pe-4 py-3">Total</th>
                                @if (Model.EstadoDGII != "Firmado" && Model.EstadoDGII != "Enviado" && Model.EstadoDGII != "Aprobado")
                                {
                                    <th style="width: 50px;"></th>
                                }
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.Lineas != null && Model.Lineas.Any())
                            {
                                @foreach (var linea in Model.Lineas.OrderBy(l => l.NumeroLinea))
                                {
                                    <tr>
                                        <td class="ps-4">
                                            <div class="d-flex align-items-center">
                                                <div class="bg-light p-2 rounded-2 me-3 d-none d-sm-block">
                                                    <i class="ri-archive-line text-muted"></i>
                                                </div>
                                                <div>
                                                    <p class="mb-0 fw-bold text-dark">@linea.Descripcion</p>
                                                    <small class="text-muted">@linea.NombreItem</small>
                                                </div>
                                            </div>
                                        </td>
                                        <td class="text-center fw-medium">@linea.Cantidad.ToString("N0")</td>
                                        <td class="text-end fw-medium">@linea.PrecioUnitario.ToString("C", cultura)</td>
                                        <td class="text-end text-success small">@linea.MontoITBIS.ToString("C", cultura)</td>
                                        <td class="text-end pe-4 fw-bold text-primary">@linea.MontoItem.ToString("C", cultura)</td>
                                        @if (Model.EstadoDGII != "Firmado" && Model.EstadoDGII != "Enviado" && Model.EstadoDGII != "Aprobado")
                                        {
                                            <td class="pe-3">
                                                <form asp-action="EliminarLinea" method="post" class="d-inline">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="id" value="@linea.Id" />
                                                    <button type="submit" class="btn btn-link text-danger p-0" onclick="return confirm('¿Eliminar?')">
                                                        <i class="ri-delete-bin-7-line fs-5"></i>
                                                    </button>
                                                </form>
                                            </td>
                                        }
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="6" class="text-center py-5">
                                        <div class="opacity-25 mb-3">
                                            <i class="ri-survey-line display-1"></i>
                                        </div>
                                        <h6 class="text-muted">Aún no hay productos.</h6>
                                        <button type="button" class="btn btn-link text-primary" data-bs-toggle="modal" data-bs-target="#modalAgregarLinea">Agregar el primero</button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

        <!-- Columna Lateral - Totales -->
        <div class="sticky-top" style="top: 2rem;">
            <!-- Totales Card -->
            <div class="card border-0 rounded-4 shadow-sm bg-white mb-4 overflow-hidden border-top border-4 border-primary">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-4 text-dark">Resumen de Venta</h5>
                    
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted small">Subtotal</span>
                        <span class="fw-medium text-dark">@Model.Subtotal.ToString("C", cultura)</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted small">ITBIS (@Model.PorcentajeITBIS%)</span>
                        <span class="fw-medium text-success">+@Model.MontoITBIS.ToString("C", cultura)</span>
                    </div>
                    <hr class="bg-light my-3">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <span class="fw-bold h5 mb-0 text-dark">TOTAL</span>
                        <span class="fw-bold h4 mb-0 text-primary">@Model.Total.ToString("C", cultura)</span>
                    </div>

                    <div class="d-grid gap-2">
                        @if (Model.EstadoDGII == "Pendiente" || Model.EstadoDGII == "Rechazado")
                        {
                            @if (Model.Lineas != null && Model.Lineas.Any())
                            {
                                <a href="@Url.Action("Firmar", new { id = Model.Id })" class="btn btn-primary w-100 py-3 rounded-3 fw-bold shadow-sm">
                                    <i class="ri-quill-pen-line me-2"></i> FIRMAR Y FINALIZAR
                                </a>
                            }
                            else
                            {
                                <button class="btn btn-secondary w-100 py-3 rounded-3 disabled">
                                    <i class="ri-quill-pen-line me-2"></i> FIRMAR (AGREGUE ITEMS)
                                </button>
                            }
                        }
                        else if (Model.EstadoDGII == "Firmado")
                        {
                            <a href="@Url.Action("EnviarDGII", new { id = Model.Id })" class="btn btn-success w-100 py-3 rounded-3 fw-bold">
                                <i class="ri-send-plane-line me-2"></i> ENVIAR A DGII
                            </a>
                        }
                        
                        <a href="@Url.Action("Index")" class="btn btn-link w-100 text-muted text-decoration-none small">
                            <i class="ri-arrow-left-s-line me-1"></i>Regresar a la lista
                        </a>
                    </div>
                </div>
            </div>

            <!-- Datos Cliente -->
            <div class="card border-0 rounded-4 shadow-sm bg-light mb-4">
                <div class="card-body p-4">
                    <h6 class="fw-bold mb-3 small text-uppercase text-muted">Cliente</h6>
                    <div class="d-flex align-items-center">
                        <div class="bg-primary text-white rounded-circle p-2 me-3" style="width: 40px; height: 40px; display: flex; align-items:center; justify-content: center;">
                            @(Model.Cliente?.Nombre?.Substring(0, 1).ToUpper() ?? "C")
                        </div>
                        <div>
                            <p class="mb-0 fw-bold small text-dark">@(Model.Cliente?.Nombre ?? "Consumidor Final")</p>
                            <p class="mb-0 x-small text-muted">NCF: @(Model.eNCF ?? "Pendiente")</p>
                        </div>
                    </div>
                </div>
            </div>

            @if (Model.EstadoDGII == "Aprobado" || Model.EstadoDGII == "Firmado")
            {
                <div class="card border-0 rounded-4 shadow-sm bg-success bg-opacity-10 mb-4">
                    <div class="card-body p-4 text-center">
                        <i class="ri-checkbox-circle-fill text-success display-5 mb-2"></i>
                        <h6 class="fw-bold text-success">Factura @Model.EstadoDGII</h6>
                        <div class="mt-3 d-grid gap-2">
                            <a href="@Url.Action("DescargarXML", new { id = Model.Id })" class="btn btn-sm btn-outline-success rounded-pill" target="_blank">Descargar XML</a>
                            <a href="@Url.Action("DescargarPDF", new { id = Model.Id })" class="btn btn-sm btn-success rounded-pill" target="_blank">Imprimir PDF</a>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<!-- Modal Cliente Rápido -->
<div class="modal fade" id="modalClienteRapido" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title"><i class="ri-user-add-line me-2"></i>Nuevo Cliente Rápido</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="formClienteRapido">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label class="form-label">Nombre *</label>
                        <input type="text" id="clienteNombre" name="Nombre" class="form-control" required placeholder="Nombre del cliente" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">RNC / Cédula</label>
                        <input type="text" id="clienteNIF" name="NIF" class="form-control" placeholder="RNC o cédula" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Email</label>
                        <input type="email" id="clienteEmail" name="Email" class="form-control" placeholder="correo@ejemplo.com" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Teléfono</label>
                        <input type="tel" id="clienteTelefono" name="Telefono" class="form-control" placeholder="809-000-0000" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Dirección</label>
                        <input type="text" id="clienteDireccion" name="Direccion" class="form-control" placeholder="Calle #, Ciudad" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Ciudad</label>
                        <input type="text" id="clienteCiudad" name="Ciudad" class="form-control" placeholder="Ej: Santo Domingo" />
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-soft-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-primary" onclick="guardarClienteRapido()">
                    <i class="ri-save-line me-1"></i> Guardar y Seleccionar
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Modal Agregar Línea -->
@if (Model.EstadoDGII != "Firmado" && Model.EstadoDGII != "Enviado" && Model.EstadoDGII != "Aprobado")
{
    <div class="modal fade" id="modalAgregarLinea" tabindex="-1" aria-labelledby="modalAgregarLineaLabel" aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <form asp-action="AgregarLinea" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="facturaId" value="@Model.Id" />

                    <div class="modal-header">
                        <h5 class="modal-title" id="modalAgregarLineaLabel">
                            <i class="ri-add-line me-1"></i> Agregar Línea a la Factura
                        </h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label">Descripción del Producto/Servicio *</label>
                                <input type="text" name="descripcion" class="form-control" required
                                       placeholder="Ej: Servicio de consultoría, Producto XYZ..." />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Nombre del Ítem (opcional)</label>
                                <input type="text" name="nombreItem" class="form-control"
                                       placeholder="Nombre específico del producto" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Cantidad *</label>
                                <input type="number" name="cantidad" class="form-control" step="0.01" min="0.01" required value="1" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Precio Unitario *</label>
                                <input type="number" name="precioUnitario" class="form-control" step="0.01" min="0.01" required value="0.00" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">ITBIS *</label>
                                <select name="indicadorFacturacion" class="form-select">
                                    <option value="1">Gravado (18%)</option>
                                    <option value="2">Exento</option>
                                    <option value="3">Sin Derecho a Crédito</option>
                                </select>
                            </div>
                        </div>

                        <div class="alert alert-info mt-3 mb-0">
                            <i class="ri-information-line me-1"></i>
                            <strong>Nota:</strong> El ITBIS se calculará automáticamente según el indicador seleccionado.
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-soft-secondary" data-bs-dismiss="modal">Cancelar</button>
                        <button type="submit" class="btn btn-primary">
                            <i class="ri-add-line me-1"></i> Agregar Línea
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}

@section Scripts {
    <script>
        // Auto-recalcular totales cuando cambie el ITBIS
        document.getElementById('porcentajeItbis')?.addEventListener('change', function() {
            // Aquí podrías agregar lógica para recalcular en tiempo real
            // Por ahora, el cálculo se hace en el servidor al guardar
        });

        // Confirmar antes de salir si hay cambios sin guardar
        let formChanged = false;
        document.querySelectorAll('#editForm input, #editForm select').forEach(input => {
            input.addEventListener('change', () => formChanged = true);
        });

        window.addEventListener('beforeunload', (e) => {
            if (formChanged) {
                e.preventDefault();
                e.returnValue = '';
            }
        });

        // ========================================
        // CLIENTE RÁPIDO DESDE FACTURACIÓN
        // ========================================
        function abrirModalClienteRapido() {
            // Limpiar formulario
            document.getElementById('formClienteRapido').reset();
            document.getElementById('clienteNombre').value = '';
            document.getElementById('clienteNIF').value = '';
            document.getElementById('clienteEmail').value = '';
            document.getElementById('clienteTelefono').value = '';
            document.getElementById('clienteDireccion').value = '';
            document.getElementById('clienteCiudad').value = '';

            const modal = new bootstrap.Modal(document.getElementById('modalClienteRapido'));
            modal.show();
        }

        function guardarClienteRapido() {
            const nombre = document.getElementById('clienteNombre').value.trim();
            const nif = document.getElementById('clienteNIF').value.trim();
            const email = document.getElementById('clienteEmail').value.trim();
            const telefono = document.getElementById('clienteTelefono').value.trim();
            const direccion = document.getElementById('clienteDireccion').value.trim();
            const ciudad = document.getElementById('clienteCiudad').value.trim();

            if (!nombre) {
                mostrarNotificacion('El nombre es obligatorio', 'danger');
                return;
            }

            const formData = new URLSearchParams();
            formData.append('__RequestVerificationToken', document.querySelector('input[name="__RequestVerificationToken"]').value);
            formData.append('Nombre', nombre);
            formData.append('NIF', nif);
            formData.append('Email', email);
            formData.append('Telefono', telefono);
            formData.append('Direccion', direccion);
            formData.append('Ciudad', ciudad);

            fetch('/Clientes/CrearRapido', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded'
                },
                body: formData.toString()
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    // Cerrar modal
                    bootstrap.Modal.getInstance(document.getElementById('modalClienteRapido')).hide();

                    // Agregar nuevo cliente al select y seleccionarlo
                    const clienteSelect = document.getElementById('clienteSelect');
                    const option = document.createElement('option');
                    option.value = data.cliente.Id;
                    option.textContent = data.cliente.Nombre;
                    option.selected = true;
                    clienteSelect.appendChild(option);

                    mostrarNotificacion('Cliente creado correctamente', 'success');
                } else {
                    mostrarNotificacion(data.message || 'Error al crear cliente', 'danger');
                }
            })
            .catch(error => {
                console.error('Error:', error);
                mostrarNotificacion('Error de conexión al crear cliente', 'danger');
            });
        }

        function mostrarNotificacion(mensaje, tipo) {
            const alertHtml = `
                <div class="alert alert-${tipo} alert-dismissible fade show position-fixed"
                     style="top: 80px; right: 20px; z-index: 9999; min-width: 300px;"
                     role="alert">
                    <i class="ri-${tipo === 'success' ? 'check-double' : 'error-warning'}-line me-1"></i>
                    ${mensaje}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            `;
            document.body.insertAdjacentHTML('beforeend', alertHtml);
            setTimeout(() => {
                const alert = document.querySelector('.alert-dismissible:last-child');
                if (alert) alert.remove();
            }, 3000);
        }
    </script>
}
