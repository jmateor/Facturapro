@model Facturapro.Models.Entities.Factura

@{
    ViewData["Title"] = "Editar Factura e-CF";
    var cultura = new System.Globalization.CultureInfo("es-DO");
    var clienteJson = Model.Cliente != null ? System.Text.Json.JsonSerializer.Serialize(new {
        Id = Model.Cliente.Id,
        Nombre = Model.Cliente.Nombre,
        RNC = Model.Cliente.RNC,
        Direccion = Model.Cliente.Direccion,
        Telefono = Model.Cliente.Telefono,
        Email = Model.Cliente.Email
    }) : "null";
}

<!-- Page Header -->
<div class="page-header-title">
    <div class="d-flex align-items-center justify-content-between">
        <div>
            <h4 class="page-title mb-1">
                <i class="ri-file-edit-line me-1"></i>
                Editar Factura @Model.NumeroFactura
            </h4>
            <p class="text-muted mb-0">Gestione las líneas y detalles del comprobante electrónico</p>
        </div>
        <div class="d-flex gap-2">
            <a href="@Url.Action("Index")" class="btn btn-soft-secondary">
                <i class="ri-arrow-left-line me-1"></i> Volver
            </a>
        </div>
    </div>
</div>

@if (!string.IsNullOrEmpty(TempData["SuccessMessage"] as string))
{
    <div class="row">
        <div class="col-12">
            <div class="alert alert-success border-0 alert-dismissible fade show" role="alert">
                <i class="ri-checkbox-circle-line me-2"></i>
                @TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        </div>
    </div>
}

@if (!string.IsNullOrEmpty(TempData["ErrorMessage"] as string))
{
    <div class="row">
        <div class="col-12">
            <div class="alert alert-danger border-0 alert-dismissible fade show" role="alert">
                <i class="ri-error-warning-line me-2"></i>
                @TempData["ErrorMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        </div>
    </div>
}

<!-- Alertas de estado -->
@if (Model.EstadoDGII == "Firmado" || Model.EstadoDGII == "Enviado" || Model.EstadoDGII == "Aprobado")
{
    <div class="row">
        <div class="col-12">
            <div class="alert alert-warning border-0" role="alert">
                <i class="ri-lock-line me-2"></i>
                <strong>Factura @(Model.EstadoDGII):</strong> Esta factura ya ha sido @(Model.EstadoDGII.ToLower()) y no puede ser modificada. Solo puede consultar su estado o descargar los documentos.
            </div>
        </div>
    </div>
}

@if (string.IsNullOrEmpty(Model.eNCF))
{
    <div class="row">
        <div class="col-12">
            <div class="alert alert-warning border-0" role="alert">
                <i class="ri-alert-line me-2"></i>
                <strong>Sin e-CF asignado:</strong> Esta factura no tiene número e-CF. Asegúrese de que haya rangos disponibles en el módulo de Rangos DGII.
            </div>
        </div>
    </div>
}

<div class="row">
    <!-- Columna Izquierda - Formulario y Líneas -->
    <div class="col-xl-8">

        <!-- Información del Encabezado -->
        <div class="card">
            <div class="card-body">
                <div class="d-flex align-items-center mb-4">
                    <div class="avatar-sm bg-primary rounded-3 me-3">
                        <span class="avatar-title text-white fw-bold">1</span>
                    </div>
                    <div>
                        <h5 class="card-title mb-0">Información del Comprobante</h5>
                        <p class="text-muted mb-0 small">Datos principales de la factura</p>
                    </div>
                </div>

                <form asp-action="Edit" method="post" id="editForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="eNCF" />
                    <input type="hidden" asp-for="NumeroFactura" />

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="TipoECF" class="form-label">Tipo de Comprobante</label>
                            <select asp-for="TipoECF" class="form-select" disabled>
                                <option value="31">E31 - Factura de Crédito Fiscal</option>
                                <option value="32">E32 - Factura de Consumo</option>
                                <option value="33">E33 - Nota de Débito</option>
                                <option value="34">E34 - Nota de Crédito</option>
                            </select>
                            <small class="text-muted">No editable después de creada</small>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="eNCF" class="form-label">e-CF Asignado</label>
                            <input asp-for="eNCF" class="form-control" readonly
                                   placeholder="Sin asignar"
                                   value="@(string.IsNullOrEmpty(Model.eNCF) ? "Pendiente" : Model.eNCF)" />
                        </div>

                        <div class="col-md-6">
                            <label asp-for="ClienteId" class="form-label">Cliente</label>
                            <div class="input-group">
                                <select asp-for="ClienteId" asp-items="ViewBag.Clientes" class="form-select" id="clienteSelect">
                                    <option value="">Seleccione un cliente...</option>
                                </select>
                                <a href="@Url.Action("Create", "Clientes")" class="btn btn-outline-primary" target="_blank" title="Nuevo Cliente">
                                    <i class="ri-add-line"></i>
                                </a>
                            </div>
                        </div>

                        <div class="col-md-3">
                            <label asp-for="FechaEmision" class="form-label">Fecha Emisión</label>
                            <input asp-for="FechaEmision" type="date" class="form-control" />
                        </div>

                        <div class="col-md-3">
                            <label asp-for="FechaVencimiento" class="form-label">Fecha Vencimiento</label>
                            <input asp-for="FechaVencimiento" type="date" class="form-control" />
                        </div>

                        <div class="col-md-6">
                            <label asp-for="TipoPago" class="form-label">Tipo de Pago</label>
                            <select asp-for="TipoPago" class="form-select">
                                <option value="1">Contado</option>
                                <option value="2">Crédito</option>
                                <option value="3">Mixto</option>
                            </select>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="PorcentajeITBIS" class="form-label">ITBIS (%)</label>
                            <input asp-for="PorcentajeITBIS" type="number" step="0.01" class="form-control" id="porcentajeItbis" />
                        </div>

                        <div class="col-md-8">
                            <label asp-for="Notas" class="form-label">Notas</label>
                            <input asp-for="Notas" class="form-control" placeholder="Notas adicionales..." />
                        </div>
                    </div>

                    <div class="mt-4 text-end">
                        <button type="submit" class="btn btn-primary">
                            <i class="ri-save-line me-1"></i> Guardar Cambios
                        </button>
                    </div>
                </form>
            </div>
        </div>

        <!-- Líneas de la Factura -->
        <div class="card">
            <div class="card-body">
                <div class="d-flex align-items-center mb-4">
                    <div class="avatar-sm bg-success rounded-3 me-3">
                        <span class="avatar-title text-white fw-bold">2</span>
                    </div>
                    <div class="flex-grow-1">
                        <h5 class="card-title mb-0">Líneas de Detalle</h5>
                        <p class="text-muted mb-0 small">Productos o servicios facturados</p>
                    </div>
                    @if (Model.EstadoDGII != "Firmado" && Model.EstadoDGII != "Enviado" && Model.EstadoDGII != "Aprobado")
                    {
                        <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#modalAgregarLinea">
                            <i class="ri-add-line me-1"></i> Agregar Línea
                        </button>
                    }
                </div>

                @if (Model.Lineas != null && Model.Lineas.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th style="width: 5%;">#</th>
                                    <th style="width: 35%;">Descripción</th>
                                    <th style="width: 12%;" class="text-center">Cant.</th>
                                    <th style="width: 15%;" class="text-end">Precio Unit.</th>
                                    <th style="width: 13%;" class="text-end">ITBIS</th>
                                    <th style="width: 15%;" class="text-end">Total</th>
                                    @if (Model.EstadoDGII != "Firmado" && Model.EstadoDGII != "Enviado" && Model.EstadoDGII != "Aprobado")
                                    {
                                        <th style="width: 5%;"></th>
                                    }
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var linea in Model.Lineas.OrderBy(l => l.NumeroLinea))
                                {
                                    <tr>
                                        <td>
                                            <span class="badge bg-light text-dark fw-normal">@linea.NumeroLinea</span>
                                        </td>
                                        <td>
                                            <span class="fw-semibold">@linea.Descripcion</span>
                                            @if (!string.IsNullOrEmpty(linea.NombreItem) && linea.NombreItem != linea.Descripcion)
                                            {
                                                <small class="text-muted d-block">@linea.NombreItem</small>
                                            }
                                        </td>
                                        <td class="text-center">@linea.Cantidad.ToString("N2")</td>
                                        <td class="text-end">@linea.PrecioUnitario.ToString("C", cultura)</td>
                                        <td class="text-end">
                                            @if (linea.MontoITBIS > 0)
                                            {
                                                <span class="text-success">+@linea.MontoITBIS.ToString("C", cultura)</span>
                                            }
                                            else
                                            {
                                                <span class="text-muted">Exento</span>
                                            }
                                        </td>
                                        <td class="text-end">
                                            <span class="fw-bold">@linea.MontoItem.ToString("C", cultura)</span>
                                        </td>
                                        @if (Model.EstadoDGII != "Firmado" && Model.EstadoDGII != "Enviado" && Model.EstadoDGII != "Aprobado")
                                        {
                                            <td class="text-end">
                                                <form asp-action="EliminarLinea" method="post" class="d-inline">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="id" value="@linea.Id" />
                                                    <button type="submit" class="btn btn-sm btn-soft-danger"
                                                            onclick="return confirm('¿Eliminar esta línea?')">
                                                        <i class="ri-delete-bin-line"></i>
                                                    </button>
                                                </form>
                                            </td>
                                        }
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-center py-5">
                        <div class="avatar-lg bg-soft-success rounded-circle mb-3 mx-auto d-inline-flex" style="width: 80px; height: 80px;">
                            <i class="ri-file-list-3-line display-4 text-success"></i>
                        </div>
                        <h6 class="fw-semibold">Sin líneas de detalle</h6>
                        <p class="text-muted mb-3 small">Agregue productos o servicios para continuar</p>
                        @if (Model.EstadoDGII != "Firmado" && Model.EstadoDGII != "Enviado" && Model.EstadoDGII != "Aprobado")
                        {
                            <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#modalAgregarLinea">
                                <i class="ri-add-line me-1"></i> Agregar Primera Línea
                            </button>
                        }
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Columna Derecha - Resumen y Acciones -->
    <div class="col-xl-4">

        <!-- Tarjeta de Resumen -->
        <div class="card bg-primary text-white">
            <div class="card-body text-center">
                <div class="avatar-lg bg-white text-primary rounded-circle mb-3 mx-auto d-flex align-items-center justify-content-center" style="width: 100px; height: 100px;">
                    <i class="ri-file-list-3-line display-4"></i>
                </div>
                <h5 class="mb-1">@Model.NumeroFactura</h5>
                <p class="text-white-50 small mb-2">@Model.TipoECFTexto</p>
                <span class="badge bg-white text-primary">
                    @(Model.Estado ?? "Pendiente")
                </span>
            </div>
        </div>

        <!-- Totales -->
        <div class="card">
            <div class="card-body">
                <h6 class="card-title mb-3">
                    <i class="ri-calculator-line me-1 text-primary"></i>
                    Resumen de Totales
                </h6>

                <div class="d-flex justify-content-between mb-2 pb-2 border-bottom">
                    <span class="text-muted">Subtotal:</span>
                    <span class="fw-semibold">@Model.Subtotal.ToString("C", cultura)</span>
                </div>
                <div class="d-flex justify-content-between mb-2 pb-2">
                    <span class="text-muted">ITBIS (@Model.PorcentajeITBIS%):</span>
                    <span class="fw-semibold text-success">@Model.MontoITBIS.ToString("C", cultura)</span>
                </div>
                <div class="d-flex justify-content-between mb-2 pb-2">
                    <span class="text-muted">Total ITBIS:</span>
                    <span class="fw-semibold">@Model.TotalITBIS.ToString("C", cultura)</span>
                </div>
                <div class="d-flex justify-content-between align-items-center p-3 bg-soft-primary rounded-3">
                    <span class="fw-bold">Total:</span>
                    <span class="fw-bold fs-4 text-primary">@Model.Total.ToString("C", cultura)</span>
                </div>

                <hr />

                <div class="small text-muted">
                    <div class="d-flex justify-content-between mb-2">
                        <span><i class="ri-calendar-line me-2"></i>Emisión:</span>
                        <span class="fw-medium">@Model.FechaEmision.ToString("dd/MM/yyyy")</span>
                    </div>
                    <div class="d-flex justify-content-between">
                        <span><i class="ri-time-line me-2"></i>Vencimiento:</span>
                        <span class="fw-medium">@Model.FechaVencimiento.ToString("dd/MM/yyyy")</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Acciones DGII -->
        <div class="card">
            <div class="card-body">
                <h6 class="card-title mb-3">
                    <i class="ri-shield-keyhole-line me-1 text-warning"></i>
                    Acciones de Facturación Electrónica
                </h6>

                <div class="d-grid gap-2">
                    @if (Model.EstadoDGII == "Pendiente" || Model.EstadoDGII == "Rechazado")
                    {
                        @if (Model.Lineas != null && Model.Lineas.Any())
                        {
                            <a href="@Url.Action("Firmar", new { id = Model.Id })" class="btn btn-success">
                                <i class="ri-signature-line me-1"></i> Firmar Digitalmente
                            </a>
                            <small class="text-muted text-center">
                                <i class="ri-information-line me-1"></i>Firma con certificado digital
                            </small>
                        }
                        else
                        {
                            <button class="btn btn-secondary" disabled>
                                <i class="ri-signature-line me-1"></i> Firmar Digitalmente
                            </button>
                            <small class="text-danger text-center">
                                <i class="ri-alert-line me-1"></i>Agregue al menos una línea
                            </small>
                        }
                    }
                    else if (Model.EstadoDGII == "Firmado")
                    {
                        <a href="@Url.Action("EnviarDGII", new { id = Model.Id })" class="btn btn-primary">
                            <i class="ri-send-plane-line me-1"></i> Enviar a la DGII
                        </a>
                        <small class="text-muted text-center">
                            <i class="ri-information-line me-1"></i>Envía el comprobante firmado
                        </small>
                    }
                    else if (Model.EstadoDGII == "Enviado" || Model.EstadoDGII == "EnProceso")
                    {
                        <a href="@Url.Action("ConsultarEstado", new { id = Model.Id })" class="btn btn-warning">
                            <i class="ri-refresh-line me-1"></i> Consultar Estado
                        </a>
                        <small class="text-muted text-center">
                            <i class="ri-time-line me-1"></i>Estado: @Model.EstadoDGII
                        </small>
                    }
                    else if (Model.EstadoDGII == "Aprobado" || Model.EstadoDGII == "Firmado")
                    {
                        <span class="badge bg-success-soft text-success p-2 text-center">
                            <i class="ri-checkbox-circle-fill me-1"></i>@Model.EstadoDGII por la DGII
                        </span>
                    }

                    <hr class="my-2" />

                    <!-- Descargar Documentos -->
                    @if (!string.IsNullOrEmpty(Model.XMLFirmado))
                    {
                        <a href="@Url.Action("DescargarXML", new { id = Model.Id })" class="btn btn-soft-info" target="_blank">
                            <i class="ri-file-code-line me-1"></i> Descargar XML
                        </a>
                    }

                    @if (Model.EstadoDGII == "Firmado" || Model.EstadoDGII == "Aprobado")
                    {
                        <a href="@Url.Action("DescargarPDF", new { id = Model.Id })" class="btn btn-soft-danger" target="_blank">
                            <i class="ri-file-pdf-line me-1"></i> Descargar PDF
                        </a>
                    }
                </div>
            </div>
        </div>

        <!-- Estado DGII -->
        <div class="card border-1 @if (Model.EstadoDGII == "Aprobado" || Model.EstadoDGII == "Firmado") { @("border-success") } else if (Model.EstadoDGII == "Rechazado") { @("border-danger") }">
            <div class="card-body">
                <h6 class="card-title mb-3">
                    <i class="ri-global-line me-1 text-primary"></i>
                    Estado ante la DGII
                </h6>

                <div class="text-center mb-3">
                    @if (Model.EstadoDGII == "Aprobado" || Model.EstadoDGII == "Firmado")
                    {
                        <div class="avatar-lg bg-success-soft rounded-circle mb-2 mx-auto d-flex align-items-center justify-content-center" style="width: 80px; height: 80px;">
                            <i class="ri-checkbox-circle-fill display-4 text-success"></i>
                        </div>
                        <span class="badge bg-success p-2">@Model.EstadoDGII</span>
                    }
                    else if (Model.EstadoDGII == "Rechazado")
                    {
                        <div class="avatar-lg bg-danger-soft rounded-circle mb-2 mx-auto d-flex align-items-center justify-content-center" style="width: 80px; height: 80px;">
                            <i class="ri-close-circle-fill display-4 text-danger"></i>
                        </div>
                        <span class="badge bg-danger p-2">@Model.EstadoDGII</span>
                    }
                    else if (Model.EstadoDGII == "Enviado" || Model.EstadoDGII == "EnProceso")
                    {
                        <div class="avatar-lg bg-warning-soft rounded-circle mb-2 mx-auto d-flex align-items-center justify-content-center" style="width: 80px; height: 80px;">
                            <i class="ri-time-line display-4 text-warning"></i>
                        </div>
                        <span class="badge bg-warning p-2">@Model.EstadoDGII</span>
                    }
                    else
                    {
                        <div class="avatar-lg bg-secondary-soft rounded-circle mb-2 mx-auto d-flex align-items-center justify-content-center" style="width: 80px; height: 80px;">
                            <i class="ri-file-line display-4 text-secondary"></i>
                        </div>
                        <span class="badge bg-secondary p-2">@Model.EstadoDGII</span>
                    }
                </div>

                @if (!string.IsNullOrEmpty(Model.MensajeDGII))
                {
                    <div class="alert @(Model.EstadoDGII == "Rechazado" ? "alert-danger" : "alert-info") small mb-0">
                        <i class="ri-message-line me-1"></i>
                        @Model.MensajeDGII
                    </div>
                }
            </div>
        </div>

        <!-- Información Rápida -->
        <div class="card">
            <div class="card-body">
                <h6 class="card-title mb-3">
                    <i class="ri-file-info-line me-1 text-primary"></i>
                    Información Rápida
                </h6>

                <div class="small">
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted"><i class="ri-calendar-line me-2"></i>Creada:</span>
                        <span class="fw-medium">@Model.FechaCreacion.ToString("dd/MM/yyyy")</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted"><i class="ri-hashtag me-2"></i>eNCF:</span>
                        <span class="fw-medium">@(Model.eNCF ?? "Pendiente")</span>
                    </div>
                    @if (!string.IsNullOrEmpty(Model.RNCEmisor))
                    {
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted"><i class="ri-store-2-line me-2"></i>RNC Emisor:</span>
                            <span class="fw-medium">@Model.RNCEmisor</span>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(Model.FirmaDigital))
                    {
                        <div class="d-flex justify-content-between">
                            <span class="text-muted"><i class="ri-signature-line me-2"></i>Firmada:</span>
                            <span class="fw-medium">@Model.FechaHoraFirma?.ToString("dd/MM/yyyy HH:mm")</span>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal Agregar Línea -->
@if (Model.EstadoDGII != "Firmado" && Model.EstadoDGII != "Enviado" && Model.EstadoDGII != "Aprobado")
{
    <div class="modal fade" id="modalAgregarLinea" tabindex="-1" aria-labelledby="modalAgregarLineaLabel" aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <form asp-action="AgregarLinea" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="facturaId" value="@Model.Id" />

                    <div class="modal-header">
                        <h5 class="modal-title" id="modalAgregarLineaLabel">
                            <i class="ri-add-line me-1"></i> Agregar Línea a la Factura
                        </h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label">Descripción del Producto/Servicio *</label>
                                <input type="text" name="descripcion" class="form-control" required
                                       placeholder="Ej: Servicio de consultoría, Producto XYZ..." />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Nombre del Ítem (opcional)</label>
                                <input type="text" name="nombreItem" class="form-control"
                                       placeholder="Nombre específico del producto" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Cantidad *</label>
                                <input type="number" name="cantidad" class="form-control" step="0.01" min="0.01" required value="1" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Precio Unitario *</label>
                                <input type="number" name="precioUnitario" class="form-control" step="0.01" min="0.01" required value="0.00" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">ITBIS *</label>
                                <select name="indicadorFacturacion" class="form-select">
                                    <option value="1">Gravado (18%)</option>
                                    <option value="2">Exento</option>
                                    <option value="3">Sin Derecho a Crédito</option>
                                </select>
                            </div>
                        </div>

                        <div class="alert alert-info mt-3 mb-0">
                            <i class="ri-information-line me-1"></i>
                            <strong>Nota:</strong> El ITBIS se calculará automáticamente según el indicador seleccionado.
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-soft-secondary" data-bs-dismiss="modal">Cancelar</button>
                        <button type="submit" class="btn btn-primary">
                            <i class="ri-add-line me-1"></i> Agregar Línea
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}

@section Scripts {
    <script>
        // Auto-recalcular totales cuando cambie el ITBIS
        document.getElementById('porcentajeItbis')?.addEventListener('change', function() {
            // Aquí podrías agregar lógica para recalcular en tiempo real
            // Por ahora, el cálculo se hace en el servidor al guardar
        });

        // Confirmar antes de salir si hay cambios sin guardar
        let formChanged = false;
        document.querySelectorAll('#editForm input, #editForm select').forEach(input => {
            input.addEventListener('change', () => formChanged = true);
        });

        window.addEventListener('beforeunload', (e) => {
            if (formChanged) {
                e.preventDefault();
                e.returnValue = '';
            }
        });
    </script>
}
