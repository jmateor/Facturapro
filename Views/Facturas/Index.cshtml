@model IEnumerable<Facturapro.Models.Entities.Factura>

@{
    ViewData["Title"] = "Facturas";
    var cultura = new System.Globalization.CultureInfo("es-DO");
}

<!-- start page title -->
<div class="row">
    <div class="col-12">
        <div class="page-title-box">
            <div class="page-title-right">
                <a href="@Url.Action("Create", "Facturas")" class="btn btn-primary">
                    <i class="ri-file-add-line me-1"></i>
                    Nueva Factura e-CF
                </a>
            </div>
            <h4 class="page-title">
                <i class="@(Context.Request.Query["tipoECF"] == "34" ? "ri-file-history-line" : "ri-file-list-3-line") me-2"></i>
                @(Context.Request.Query["tipoECF"] == "34" ? "Notas de Crédito" : "Facturas")
            </h4>
            <p class="text-muted mb-0">
                @(Context.Request.Query["tipoECF"] == "34" ? "Gestiona tus notas de crédito electrónicas (e-NCF) y devoluciones" : "Gestiona todas tus facturas electrónicas (e-CF)")
            </p>
        </div>
    </div>
</div>
<!-- end page title -->

<div class="row mb-3">
    <div class="col-md-3">
        <div class="card mb-0 shadow-sm border-0">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div class="avatar-sm bg-soft-primary rounded-3 me-3">
                        <i class="ri-file-list-3-line font-24 text-primary"></i>
                    </div>
                    <div class="flex-grow-1">
                        <h5 class="text-muted fw-normal mt-0" title="Total Facturas">Total Emitidas</h5>
                        <h3 class="my-0">@Model.Count()</h3>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card mb-0 shadow-sm border-0">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div class="avatar-sm bg-soft-success rounded-3 me-3">
                        <i class="ri-checkbox-circle-line font-24 text-success"></i>
                    </div>
                    <div class="flex-grow-1">
                        <h5 class="text-muted fw-normal mt-0" title="Aprobadas">Aprobadas DGII</h5>
                        <h3 class="my-0">@Model.Count(f => f.EstadoDGII == "Aprobado" || f.EstadoDGII == "Firmado")</h3>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card mb-0 shadow-sm border-0">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div class="avatar-sm bg-soft-warning rounded-3 me-3">
                        <i class="ri-calendar-todo-line font-24 text-warning"></i>
                    </div>
                    <div class="flex-grow-1">
                        <h5 class="text-muted fw-normal mt-0" title="Pendientes">A Crédito</h5>
                        <h3 class="my-0">@Model.Count(f => f.TipoPago == 2)</h3>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card mb-0 shadow-sm border-0">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div class="avatar-sm bg-soft-info rounded-3 me-3">
                        <i class="ri-money-dollar-circle-line font-24 text-info"></i>
                    </div>
                    <div class="flex-grow-1">
                        <h5 class="text-muted fw-normal mt-0" title="Total">Total Facturado</h5>
                        <h3 class="my-0">@Model.Sum(f => f.Total).ToString("C", cultura)</h3>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>


<!-- Filtros -->
<div class="card mb-3">
    <div class="card-body">
        <form method="get" class="row g-2 align-items-center">
            <div class="col-md-3">
                <select name="tipoECF" class="form-select">
                    <option value="">Todos los tipos e-CF</option>
                    <option value="31" selected='@(Context.Request.Query["tipoECF"] == "31" ? "selected" : null)'>E31 - Factura Crédito Fiscal</option>
                    <option value="32" selected='@(Context.Request.Query["tipoECF"] == "32" ? "selected" : null)'>E32 - Factura Consumo</option>
                    <option value="33" selected='@(Context.Request.Query["tipoECF"] == "33" ? "selected" : null)'>E33 - Nota Débito</option>
                    <option value="34" selected='@(Context.Request.Query["tipoECF"] == "34" ? "selected" : null)'>E34 - Nota Crédito</option>
                </select>
            </div>
            <div class="col-md-3">
                <select name="estadoDGII" class="form-select">
                    <option value="">Estado DGII</option>
                    <option value="Pendiente" selected='@(Context.Request.Query["estadoDGII"] == "Pendiente" ? "selected" : null)'>Pendiente</option>
                    <option value="Firmado" selected='@(Context.Request.Query["estadoDGII"] == "Firmado" ? "selected" : null)'>Firmado</option>
                    <option value="Enviado" selected='@(Context.Request.Query["estadoDGII"] == "Enviado" ? "selected" : null)'>Enviado</option>
                    <option value="EnProceso" selected='@(Context.Request.Query["estadoDGII"] == "EnProceso" ? "selected" : null)'>En Proceso</option>
                    <option value="Aprobado" selected='@(Context.Request.Query["estadoDGII"] == "Aprobado" ? "selected" : null)'>Aprobado</option>
                    <option value="Rechazado" selected='@(Context.Request.Query["estadoDGII"] == "Rechazado" ? "selected" : null)'>Rechazado</option>
                </select>
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-secondary w-100">
                    <i class="ri-filter-search-line me-1"></i>
                    Filtrar
                </button>
            </div>
            <div class="col-md-4 text-end">
                <a href="@Url.Action("ConsultarEstadoPendientes")" class="btn btn-soft-info">
                    <i class="ri-refresh-line me-1"></i>
                    Actualizar Estados
                </a>
            </div>
        </form>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <div class="table-responsive-sm">
            <table class="table table-centered mb-0" id="tablaFacturas">
                <thead class="table-light">
                    <tr>
                        <th>e-CF</th>
                        <th>Tipo</th>
                        <th>Cliente</th>
                        <th>Fecha Emisión</th>
                        <th>Condición</th>
                        <th>Total</th>
                        <th>Estado DGII</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody id="tablaFacturasBody">
                    @foreach (var item in Model)
                    {
                        var estadoDGIIClass = item.EstadoDGII switch
                        {
                            "Aprobado" => "bg-success",
                            "Firmado" => "bg-primary",
                            "Enviado" => "bg-warning",
                            "Rechazado" => "bg-danger",
                            _ => "bg-secondary"
                        };

                        <tr>
                            <td>
                                <strong>@(item.eNCF ?? "-")</strong>
                                <br />
                                <small class="text-muted">@item.NumeroFactura</small>
                            </td>
                            <td>
                                <span class="badge bg-info">E@(item.TipoECF ?? "31")</span>
                            </td>
                            <td>
                                <div class="d-flex align-items-center">
                                    <div class="avatar-sm rounded-circle bg-soft-primary text-primary d-flex align-items-center justify-content-center me-2" style="width: 32px; height: 32px; font-size: 0.8rem; font-weight: 600;">
                                        @(item.Cliente?.Nombre?.Substring(0, 1).ToUpper() ?? "?")
                                    </div>
                                    <span>@(item.Cliente?.Nombre ?? "-")</span>
                                </div>
                            </td>
                            <td>@item.FechaEmision.ToString("dd/MM/yyyy")</td>
                            <td>
                                <span class="badge @(item.TipoPago == 2 ? "bg-warning-soft text-warning" : "bg-success-soft text-success")">
                                    @(item.TipoPago == 2 ? "Crédito" : "Contado")
                                </span>
                            </td>
                            <td>
                                <span class="fw-bold text-primary">@item.Total.ToString("C", cultura)</span>
                            </td>
                            <td>
                                <span class="badge @estadoDGIIClass">@(item.EstadoDGII ?? "Pendiente")</span>
                            </td>
                            <td>
                                <div class="d-flex gap-1 flex-wrap">
                                    <a href="@Url.Action("Details", new { id = item.Id })" class="btn btn-sm btn-soft-info"><i class="ri-eye-line"></i></a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div id="noResults" style="display: none;">
            <div class="text-center py-5">
                <i class="ri-file-search-line display-4 text-muted"></i>
                <h5 class="fw-semibold mt-3">No se encontraron facturas</h5>
                <p class="text-muted">Prueba cambiando los filtros</p>
            </div>
        </div>

        <!-- Pagination Controls -->
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-center mt-3 gap-3">
            <div class="text-muted small">
                Mostrando <span id="spanStart">0</span> a <span id="spanEnd">0</span> de <span id="spanTotal">0</span> facturas
            </div>
            <nav aria-label="Navegación de facturas">
                <ul class="pagination pagination-rounded mb-0" id="paginationContainer">
                    <!-- Dinámico -->
                </ul>
            </nav>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let currentPage = 1;
        const pageSize = 10;

        document.addEventListener('DOMContentLoaded', function() {
             cargarFacturas();
        });

        // Manejo de filtros AJAX
        document.querySelector('form').addEventListener('submit', function(e) {
            e.preventDefault();
            currentPage = 1;
            cargarFacturas();
        });

        function cargarFacturas(page = 1) {
            currentPage = page;
            const tipoECF = document.querySelector('select[name="tipoECF"]').value;
            const estadoDGII = document.querySelector('select[name="estadoDGII"]').value;
            const body = document.getElementById('tablaFacturasBody');
            const noResults = document.getElementById('noResults');

            body.innerHTML = '<tr><td colspan="8" class="text-center"><i class="ri-loader-4-line ri-spin me-2"></i>Cargando facturas...</td></tr>';

            const url = `/Facturas/GetFacturasJson?tipoECF=${tipoECF}&estadoDGII=${estadoDGII}&page=${currentPage}&pageSize=${pageSize}`;
            console.log("Cargando facturas desde:", url);

            fetch(url)
                .then(r => {
                    if (!r.ok) throw new Error("Error en servidor: " + r.status);
                    return r.json();
                })
                .then(data => {
                    console.log("Datos recibidos:", data);
                    const facturas = data.items;
                    if (facturas.length === 0) {
                        body.innerHTML = '';
                        noResults.style.display = 'block';
                        updatePaginationInfo(0, 0, 0);
                        renderPagination(0);
                        return;
                    }

                    noResults.style.display = 'none';
                    const html = facturas.map(item => {
                        const estadoClass = getEstadoDGIIClass(item.estadoDGII);
                        const fecha = item.fechaEmisionRaw ? new Date(item.fechaEmisionRaw).toLocaleDateString('es-DO') : '-';
                        
                        return `
                            <tr>
                                <td>
                                    <strong>${item.eNCF || '-'}</strong>
                                    <br />
                                    <small class="text-muted">${item.numeroFactura}</small>
                                </td>
                                <td><span class="badge bg-info">E${item.tipoECF || '31'}</span></td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="avatar-sm rounded-circle bg-soft-primary text-primary d-flex align-items-center justify-content-center me-2" style="width: 32px; height: 32px; font-size: 0.8rem; font-weight: 600;">
                                            ${(item.clienteNombre || "C").substring(0, 1).toUpperCase()}
                                        </div>
                                        <span>${item.clienteNombre}</span>
                                    </div>
                                </td>
                                <td>${fecha}</td>
                                <td>
                                    <span class="badge ${item.tipoPago == 2 ? 'bg-warning-soft text-warning' : 'bg-success-soft text-success'}">
                                        ${item.tipoPago == 2 ? 'Crédito' : 'Contado'}
                                    </span>
                                </td>
                                <td><span class="fw-bold text-primary">${new Intl.NumberFormat('es-DO', { style: 'currency', currency: 'DOP' }).format(item.total)}</span></td>
                                <td><span class="badge ${estadoClass}">${item.estadoDGII || 'Pendiente'}</span></td>
                                <td>
                                    <div class="d-flex gap-1 flex-wrap">
                                        ${getAccionesHtml(item)}
                                    </div>
                                </td>
                            </tr>
                        `;
                    }).join('');

                    body.innerHTML = html;
                    
                    const start = ((currentPage - 1) * pageSize) + 1;
                    const end = Math.min(currentPage * pageSize, data.totalItems);
                    updatePaginationInfo(start, end, data.totalItems);
                    renderPagination(data.totalPages);
                });
        }

        function updatePaginationInfo(start, end, total) {
            document.getElementById('spanStart').textContent = start;
            document.getElementById('spanEnd').textContent = end;
            document.getElementById('spanTotal').textContent = total;
        }

        function renderPagination(totalPages) {
            const container = document.getElementById('paginationContainer');
            container.innerHTML = '';

            if (totalPages <= 1) return;

            // Botón Anterior
            container.innerHTML += `
                <li class="page-item ${currentPage === 1 ? 'disabled' : ''}">
                    <a class="page-link" href="javascript:void(0)" onclick="cargarFacturas(${currentPage - 1})">
                        <i class="ri-arrow-left-s-line"></i>
                    </a>
                </li>
            `;

            // Páginas (Lógica simplificada para mostrar hasta 5 páginas)
            for (let i = 1; i <= totalPages; i++) {
                if (i === 1 || i === totalPages || (i >= currentPage - 2 && i <= currentPage + 2)) {
                    container.innerHTML += `
                        <li class="page-item ${i === currentPage ? 'active' : ''}">
                            <a class="page-link" href="javascript:void(0)" onclick="cargarFacturas(${i})">${i}</a>
                        </li>
                    `;
                } else if (i === currentPage - 3 || i === currentPage + 3) {
                    container.innerHTML += `<li class="page-item disabled"><span class="page-link">...</span></li>`;
                }
            }

            // Botón Siguiente
            container.innerHTML += `
                <li class="page-item ${currentPage === totalPages ? 'disabled' : ''}">
                    <a class="page-link" href="javascript:void(0)" onclick="cargarFacturas(${currentPage + 1})">
                        <i class="ri-arrow-right-s-line"></i>
                    </a>
                </li>
            `;
        }

        function getEstadoDGIIClass(estado) {
            switch (estado) {
                case "Aprobado": return "bg-success";
                case "Firmado": return "bg-primary";
                case "Enviado": return "bg-warning";
                case "Rechazado": return "bg-danger";
                default: return "bg-secondary";
            }
        }

        function getAccionesHtml(item) {
            let html = '';
            
            // Botón WhatsApp si tiene teléfono
            if (item.clienteTelefono) {
                html += `<a href="/Facturas/EnviarWhatsApp/${item.id}" class="btn btn-sm btn-success" target="_blank" title="Enviar por WhatsApp">
                            <i class="ri-whatsapp-line"></i>
                         </a>`;
            }

            if (item.estadoDGII === "Pendiente" || item.estadoDGII === "Rechazado") {
                html += `<a href="/Facturas/Firmar/${item.id}" class="btn btn-sm btn-soft-primary" title="Firmar"><i class="ri-signature-line"></i></a>`;
            }
            
            // Botón Nota de Crédito si está aprobada/firmada
            if (item.estadoDGII === "Aprobado" || item.estadoDGII === "Firmado") {
                html += `
                <form action="/Facturas/EmitirNotaCredito/${item.id}" method="post" style="display:inline;" onsubmit="return confirm('¿Desea crear una Nota de Crédito para esta factura?');">
                    <input type="hidden" name="__RequestVerificationToken" value="${document.querySelector('input[name=\"__RequestVerificationToken\"]').value}">
                    <button type="submit" class="btn btn-sm btn-soft-warning" title="Emitir Nota de Crédito">
                        <i class="ri-arrow-go-back-line"></i>
                    </button>
                </form>`;
            }

            html += `<a href="/Facturas/Details/${item.id}" class="btn btn-sm btn-soft-info" title="Ver detalles"><i class="ri-eye-line"></i></a>`;
            
            // Link a PDF si existe
            html += `<a href="/Facturas/DescargarPDF/${item.id}" class="btn btn-sm btn-soft-secondary" target="_blank" title="PDF"><i class="ri-file-pdf-line"></i></a>`;
            
            return html;
        }
    </script>
}
