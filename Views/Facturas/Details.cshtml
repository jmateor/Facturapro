@model Facturapro.Models.Entities.Factura

@{
    ViewData["Title"] = "Detalles de Factura";
    var cultura = new System.Globalization.CultureInfo("es-DO");
}

<!-- Page Header -->
<div class="page-header-title">
    <div class="d-flex align-items-center justify-content-between">
        <div>
            <h4 class="page-title mb-1">
                <i class="ri-file-list-3-line me-1"></i>
                @Model.NumeroFactura
            </h4>
            <p class="text-muted mb-0">Información completa de la factura electrónica</p>
        </div>
        <div class="d-flex gap-2">
            <a href="@Url.Action("DescargarPDF", new { id = Model.Id })" class="btn btn-primary" target="_blank">
                <i class="ri-download-line me-1"></i> Descargar PDF
            </a>
            <a href="@Url.Action("Index")" class="btn btn-soft-secondary">
                <i class="ri-arrow-left-line me-1"></i> Volver
            </a>
        </div>
    </div>
</div>

@if (!string.IsNullOrEmpty(TempData["ErrorMessage"] as string))
{
    <div class="row">
        <div class="col-12">
            <div class="alert alert-danger border-0 alert-dismissible fade show" role="alert">
                <i class="ri-error-warning-line me-2"></i>
                @TempData["ErrorMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        </div>
    </div>
}

<div class="row">
    <!-- Columna Izquierda - Información -->
    <div class="col-xl-8">
        <!-- Información de la Factura -->
        <div class="card">
            <div class="card-body">
                <div class="d-flex align-items-center mb-4">
                    <div class="avatar-sm bg-primary rounded-3 me-3">
                        <span class="avatar-title text-white fw-bold">1</span>
                    </div>
                    <div>
                        <h5 class="card-title mb-0">Información del Comprobante</h5>
                        <p class="text-muted mb-0 small">Datos principales de la factura electrónica</p>
                    </div>
                </div>

                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label text-muted small">Número de Factura Interno</label>
                        <div class="fw-semibold">
                            <i class="ri-file-text-line me-1 text-primary"></i>
                            @Model.NumeroFactura
                        </div>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label text-muted small">Tipo de Comprobante</label>
                        <div class="fw-semibold">
                            <i class="ri-price-tag-3-line me-1 text-primary"></i>
                            @Model.TipoECFTexto
                        </div>
                    </div>
                    @if (!string.IsNullOrEmpty(Model.eNCF))
                    {
                        <div class="col-md-6">
                            <label class="form-label text-muted small">e-CF (Número Electrónico)</label>
                            <div class="fw-semibold text-success">
                                <i class="ri-checkbox-circle-line me-1"></i>
                                @Model.eNCF
                            </div>
                        </div>
                    }
                    <div class="col-md-6">
                        <label class="form-label text-muted small">Estado DGII</label>
                        <div>
                            @if (Model.EstadoDGII == "Aprobado" || Model.EstadoDGII == "Firmado")
                            {
                                <span class="badge bg-success-soft text-success">
                                    <i class="ri-checkbox-circle-fill me-1"></i>@Model.EstadoDGII
                                </span>
                            }
                            else if (Model.EstadoDGII == "Rechazado")
                            {
                                <span class="badge bg-danger-soft text-danger">
                                    <i class="ri-close-circle-fill me-1"></i>@Model.EstadoDGII
                                </span>
                            }
                            else if (Model.EstadoDGII == "EnProceso" || Model.EstadoDGII == "Enviado")
                            {
                                <span class="badge bg-warning-soft text-warning">
                                    <i class="ri-time-line me-1"></i>@Model.EstadoDGII
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-secondary-soft text-secondary">
                                    <i class="ri-information-line me-1"></i>@(Model.EstadoDGII ?? "Pendiente")
                                </span>
                            }
                        </div>
                    <div class="col-md-6">
                        <label class="form-label text-muted small">Condición de Pago</label>
                        <div class="fw-semibold">
                            <i class="ri-calendar-check-line me-1 text-primary"></i>
                            @(Model.TipoPago == 2 ? "A Crédito" : "Al Contado")
                        </div>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label text-muted small">Estado de Factura</label>
                        <div>
                            <span class="badge @(Model.Estado == "Pagada" ? "bg-success-soft text-success" : (Model.Estado == "Cancelada" ? "bg-danger-soft text-danger" : "bg-warning-soft text-warning"))">
                                <i class="@(Model.Estado == "Pagada" ? "ri-checkbox-circle-fill" : (Model.Estado == "Cancelada" ? "ri-close-circle-fill" : "ri-time-fill")) me-1"></i>
                                @Model.Estado
                            </span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label text-muted small">Fecha de Emisión</label>
                        <div class="fw-semibold">
                            <i class="ri-calendar-line me-1 text-primary"></i>
                            @Model.FechaEmision.ToString("dd/MM/yyyy HH:mm")
                        </div>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label text-muted small">Fecha de Vencimiento</label>
                        <div class="fw-semibold">
                            <i class="ri-calendar-event-line me-1 text-primary"></i>
                            @Model.FechaVencimiento.ToString("dd/MM/yyyy")
                        </div>
                    </div>
                    @if (!string.IsNullOrEmpty(Model.Notas))
                    {
                        <div class="col-12">
                            <label class="form-label text-muted small">Notas</label>
                            <div class="fw-semibold">
                                @Model.Notas
                            </div>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(Model.MensajeDGII))
                    {
                        <div class="col-12">
                            <label class="form-label text-muted small">Mensaje DGII</label>
                            <div class="fw-semibold @(Model.EstadoDGII == "Rechazado" ? "text-danger" : "")">
                                @Model.MensajeDGII
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Datos del Cliente -->
        <div class="card">
            <div class="card-body">
                <div class="d-flex align-items-center mb-4">
                    <div class="avatar-sm bg-success rounded-3 me-3">
                        <span class="avatar-title text-white fw-bold">2</span>
                    </div>
                    <div>
                        <h5 class="card-title mb-0">Datos del Cliente</h5>
                        <p class="text-muted mb-0 small">Información del cliente</p>
                    </div>
                </div>

                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label text-muted small">Nombre / Razón Social</label>
                        <div class="fw-semibold">
                            <i class="ri-user-3-line me-1 text-success"></i>
                            @(Model.Cliente?.Nombre ?? "Consumidor Final")
                        </div>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label text-muted small">RNC / Cédula</label>
                        <div class="fw-semibold">
                            <i class="ri-id-card-line me-1 text-success"></i>
                            @(Model.Cliente?.RNC ?? "Sin RNC")
                        </div>
                    </div>
                    @if (!string.IsNullOrEmpty(Model.Cliente?.Direccion))
                    {
                        <div class="col-12">
                            <label class="form-label text-muted small">Dirección</label>
                            <div class="fw-semibold">
                                <i class="ri-map-pin-line me-1 text-success"></i>
                                @Model.Cliente.Direccion
                            </div>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(Model.Cliente?.Telefono))
                    {
                        <div class="col-md-6">
                            <label class="form-label text-muted small">Teléfono</label>
                            <div class="fw-semibold">
                                <i class="ri-phone-line me-1 text-success"></i>
                                @Model.Cliente.Telefono
                            </div>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(Model.Cliente?.Email))
                    {
                        <div class="col-md-6">
                            <label class="form-label text-muted small">Email</label>
                            <div class="fw-semibold">
                                <i class="ri-mail-line me-1 text-success"></i>
                                @Model.Cliente.Email
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Líneas de la Factura -->
        <div class="card">
            <div class="card-body">
                <div class="d-flex align-items-center mb-4">
                    <div class="avatar-sm bg-info rounded-3 me-3">
                        <span class="avatar-title text-white fw-bold">3</span>
                    </div>
                    <div>
                        <h5 class="card-title mb-0">Líneas de Detalle</h5>
                        <p class="text-muted mb-0 small">Productos o servicios facturados</p>
                    </div>
                </div>

                @if (Model.Lineas != null && Model.Lineas.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th style="width: 8%;">#</th>
                                    <th style="width: 40%;">Descripción</th>
                                    <th style="width: 12%;" class="text-center">Cantidad</th>
                                    <th style="width: 15%;" class="text-end">Precio Unit.</th>
                                    <th style="width: 12%;" class="text-end">Descuento</th>
                                    <th style="width: 13%;" class="text-end">Total</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var linea in Model.Lineas.OrderBy(l => l.Orden))
                                {
                                    <tr>
                                        <td>
                                            <span class="badge bg-light text-dark fw-normal">@linea.Orden</span>
                                        </td>
                                        <td>
                                            <span class="fw-semibold">@linea.Descripcion</span>
                                        </td>
                                        <td class="text-center">
                                            @linea.Cantidad.ToString("N2")
                                        </td>
                                        <td class="text-end">
                                            <span class="text-muted">@linea.PrecioUnitario.ToString("C", cultura)</span>
                                        </td>
                                        <td class="text-end">
                                            @if (linea.MontoDescuento > 0)
                                            {
                                                <span class="text-danger">-@linea.MontoDescuento.ToString("C", cultura)</span>
                                            }
                                            else
                                            {
                                                <span class="text-muted">$0.00</span>
                                            }
                                        </td>
                                        <td class="text-end">
                                            <span class="fw-bold text-success">@linea.MontoItem.ToString("C", cultura)</span>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-center py-4">
                        <div class="avatar-lg bg-soft-info rounded-circle mb-3 mx-auto d-inline-flex" style="width: 80px; height: 80px;">
                            <i class="ri-file-list-3-line display-4 text-info"></i>
                        </div>
                        <h6 class="fw-semibold">Sin líneas de detalle</h6>
                        <p class="text-muted mb-0 small">Esta factura no tiene productos o servicios registrados</p>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Columna Derecha - Resumen y Acciones -->
    <div class="col-xl-4">
        <!-- Tarjeta de Factura -->
        <div class="card bg-primary text-white">
            <div class="card-body text-center">
                <div class="avatar-lg bg-white text-primary rounded-circle mb-3 mx-auto d-flex align-items-center justify-content-center" style="width: 100px; height: 100px;">
                    <i class="ri-file-list-3-line display-4"></i>
                </div>
                <h5 class="mb-1">@Model.NumeroFactura</h5>
                <p class="text-white-50 small mb-2">
                    Emitida el @Model.FechaEmision.ToString("dd/MM/yyyy")
                </p>
                <span class="badge bg-white text-primary">
                    @(Model.Estado ?? "Pendiente")
                </span>
            </div>
        </div>

        <!-- Totales -->
        <div class="card">
            <div class="card-body">
                <h6 class="card-title mb-3">
                    <i class="ri-calculator-line me-1 text-primary"></i>
                    Resumen de Totales
                </h6>

                <div class="d-flex justify-content-between mb-2 pb-2 border-bottom">
                    <span class="text-muted">Subtotal:</span>
                    <span class="fw-semibold">@Model.Subtotal.ToString("C", cultura)</span>
                </div>
                <div class="d-flex justify-content-between mb-2 pb-2">
                    <span class="text-muted">ITBIS (@Model.PorcentajeITBIS%):</span>
                    <span class="fw-semibold text-success">@Model.MontoITBIS.ToString("C", cultura)</span>
                </div>
                <div class="d-flex justify-content-between mb-2 pb-2">
                    <span class="text-muted">Total ITBIS:</span>
                    <span class="fw-semibold">@Model.TotalITBIS.ToString("C", cultura)</span>
                </div>
                <div class="d-flex justify-content-between align-items-center p-3 bg-soft-primary rounded-3">
                    <span class="fw-bold">Total:</span>
                    <span class="fw-bold fs-4 text-primary">@Model.Total.ToString("C", cultura)</span>
                </div>
            </div>
        </div>

        <!-- Acciones de Envío -->
        <div class="card">
            <div class="card-body">
                <h6 class="card-title mb-3">
                    <i class="ri-share-line me-1 text-warning"></i>
                    Compartir Factura
                </h6>

                <div class="d-grid gap-2">
                    @if (!string.IsNullOrEmpty(Model.Cliente?.Email))
                    {
                        <a href="mailto:@Model.Cliente.Email?subject=Factura @Model.NumeroFactura&body=Estimado cliente,%0D%0A%0D%0AAdjunto enviamos su factura electrónica No. @Model.NumeroFactura con fecha @Model.FechaEmision.ToString("dd/MM/yyyy").%0D%0A%0D%0AMonto total: @Model.Total.ToString("C", cultura)%0D%0A%0D%0AGracias por su preferencia." class="btn btn-soft-primary">
                            <i class="ri-mail-send-line me-1"></i> Enviar por Email
                        </a>
                        <small class="text-muted text-center">
                            <i class="ri-mail-line me-1"></i>@Model.Cliente.Email
                        </small>
                    }
                    else
                    {
                        <div class="alert alert-warning-soft mb-2 small">
                            <i class="ri-alert-line me-1"></i>
                            El cliente no tiene email registrado
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(Model.Cliente?.Telefono))
                    {
                        var mensajeWhatsApp = $"Hola! Te envío tu factura electrónica No. {Model.NumeroFactura} con fecha {Model.FechaEmision:dd/MM/yyyy}. Monto total: {Model.Total.ToString("C", cultura)}. Gracias por tu compra!";
                        var telefonoLimpio = Model.Cliente.Telefono.Replace("-", "").Replace(" ", "").Replace("(", "").Replace(")", "");

                        <a href="@Url.Action("EnviarWhatsApp", new { id = Model.Id })" class="btn btn-soft-success" target="_blank">
                            <i class="ri-whatsapp-line me-1"></i> Enviar por WhatsApp
                        </a>
                        <small class="text-muted text-center">
                            <i class="ri-phone-line me-1"></i>@Model.Cliente.Telefono
                        </small>
                    }
                    else
                    {
                        <div class="alert alert-warning-soft mb-2 small">
                            <i class="ri-alert-line me-1"></i>
                            El cliente no tiene teléfono registrado
                        </div>
                    }

                    <hr class="my-2" />

                    <a href="@Url.Action("DescargarPDF", new { id = Model.Id })" class="btn btn-soft-info" target="_blank">
                        <i class="ri-printer-line me-1"></i> Imprimir / Descargar PDF
                    </a>
                </div>
            </div>
        </div>

        <!-- Información Rápida -->
        <div class="card">
            <div class="card-body">
                <h6 class="card-title mb-3">
                    <i class="ri-file-info-line me-1 text-primary"></i>
                    Información Rápida
                </h6>

                <div class="small">
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted"><i class="ri-calendar-line me-2"></i>Creada:</span>
                        <span class="fw-medium">@Model.FechaCreacion.ToString("dd/MM/yyyy")</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted"><i class="ri-file-text-line me-2"></i>Tipo:</span>
                        <span class="fw-medium">@Model.TipoECF</span>
                    </div>
                    @if (!string.IsNullOrEmpty(Model.RNCEmisor))
                    {
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted"><i class="ri-store-2-line me-2"></i>RNC Emisor:</span>
                            <span class="fw-medium">@Model.RNCEmisor</span>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Opciones Fiscales -->
        @if (Model.EstadoDGII == "Aprobado" || Model.EstadoDGII == "Firmado" || Model.EstadoDGII == "Enviado")
        {
            <div class="card border-warning border-1">
                <div class="card-body">
                    <h6 class="card-title text-warning mb-2">
                        <i class="ri-file-damage-line me-1"></i>
                        Opciones Fiscales
                    </h6>
                    <p class="small text-muted mb-3">
                        Utilice esta opción para realizar una devolución o ajuste que disminuya el valor de esta factura.
                    </p>
                    <form asp-action="EmitirNotaCredito" asp-route-id="@Model.Id" method="post" class="mb-2">
                        <button type="submit" class="btn btn-outline-warning w-100"
                                onclick="return confirm('¿Desea crear una Nota de Crédito (E34) para esta factura? (Disminuye el monto original)');">
                            <i class="ri-arrow-go-back-line me-1"></i> Emitir Nota de Crédito
                        </button>
                    </form>
                    <form asp-action="EmitirNotaDebito" asp-route-id="@Model.Id" method="post">
                        <button type="submit" class="btn btn-outline-info w-100"
                                onclick="return confirm('¿Desea crear una Nota de Débito (E33) para esta factura? (Aumenta el monto original por cargos o penalidades)');">
                            <i class="ri-add-box-line me-1"></i> Emitir Nota de Débito
                        </button>
                    </form>
                </div>
            </div>
        }

        <!-- Zona de Peligro -->
        <div class="card border-danger border-1">
            <div class="card-body">
                <h6 class="card-title text-danger mb-2">
                    <i class="ri-delete-bin-2-line me-1"></i>
                    Zona de Peligro
                </h6>
                <p class="small text-muted mb-3">
                    Eliminar una factura electrónica es una acción irreversible y puede tener implicaciones fiscales.
                </p>
                <a href="@Url.Action("Delete", new { id = Model.Id })" class="btn btn-outline-danger w-100"
                   onclick="return confirm('¿Está completamente seguro de eliminar esta factura? Esta acción es irreversible y puede afectar sus reportes fiscales.')">
                    <i class="ri-delete-bin-line me-1"></i> Eliminar Factura
                </a>
            </div>
        </div>
    </div>
</div>
