@model Facturapro.Models.Entities.Factura

@{
    ViewData["Title"] = "Nueva Factura e-CF";
}

<div class="page-header">
    <div class="page-title">
        <h1>Nueva Factura e-CF</h1>
        <p>Crear un nuevo comprobante fiscal electrónico</p>
    </div>
    <div class="page-actions">
        <a href="@Url.Action("Index")" class="btn btn-secondary">Volver a la lista</a>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()

            <div class="row" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: var(--space-md); margin-bottom: var(--space-lg);">
                <div class="form-group">
                    <label asp-for="TipoECF" class="form-label required">Tipo de Comprobante</label>
                    <select asp-for="TipoECF" class="form-select" required>
                        <option value="31">E31 - Factura de Crédito Fiscal</option>
                        <option value="32">E32 - Factura de Consumo</option>
                        <option value="33">E33 - Nota de Débito</option>
                        <option value="34">E34 - Nota de Crédito</option>
                    </select>
                    <div class="form-hint">E31 para empresas, E32 para consumidores finales</div>
                </div>

                <div class="form-group">
                    <label asp-for="ClienteId" class="form-label required">Cliente</label>
                    <select asp-for="ClienteId" asp-items="ViewBag.Clientes" class="form-select" required>
                        <option value="">Seleccione un cliente...</option>
                    </select>
                </div>

                <div class="form-group">
                    <label asp-for="FechaEmision" class="form-label required">Fecha de Emisión</label>
                    <input asp-for="FechaEmision" type="date" class="form-input" required />
                </div>

                <div class="form-group">
                    <label asp-for="FechaVencimiento" class="form-label required">Fecha de Vencimiento</label>
                    <input asp-for="FechaVencimiento" type="date" class="form-input" required />
                </div>

                <div class="form-group">
                    <label asp-for="TipoPago" class="form-label required">Tipo de Pago</label>
                    <select asp-for="TipoPago" class="form-select">
                        <option value="1">Contado</option>
                        <option value="2">Crédito</option>
                        <option value="3">Gratuito</option>
                    </select>
                </div>

                <div class="form-group">
                    <label asp-for="PorcentajeITBIS" class="form-label">ITBIS (%)</label>
                    <input asp-for="PorcentajeITBIS" type="number" step="0.01" class="form-input" value="18" />
                </div>
            </div>

            <div class="form-group">
                <label asp-for="Notas" class="form-label">Notas</label>
                <textarea asp-for="Notas" class="form-textarea" rows="3" placeholder="Notas adicionales..."></textarea>
            </div>

            <div class="alert alert-info">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m11.25 11.25.041-.02a.75.75 0 0 1 1.063.852l-.708 2.836a.75.75 0 0 0 1.063.853l.041-.021M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9-3.75h.008v.008H12V8.25Z" />
                </svg>
                Al crear la factura, se asignará automáticamente un número e-CF del rango disponible. Luego podrá agregar líneas y firmar el documento.
            </div>

            <div class="form-group" style="margin-top: var(--space-lg);">
                <button type="submit" class="btn btn-primary btn-lg">Crear Factura e-CF</button>
                <a href="@Url.Action("Index")" class="btn btn-secondary">Cancelar</a>
            </div>
        </form>
    </div>
</div>
