@model Facturapro.Models.Entities.Factura

@{
    ViewData["Title"] = "Nueva Factura e-CF";
}

<style>
    .glass-card {
        background: rgba(255, 255, 255, 0.95);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.2);
        box-shadow: 0 8px 32px 0 rgba(31, 38, 135, 0.07);
    }
    
    .ecf-type-card {
        cursor: pointer;
        transition: all 0.3s ease;
        border: 2px solid transparent;
    }
    
    .ecf-type-card:hover {
        transform: translateY(-5px);
        border-color: var(--bs-primary-border-subtle);
        background-color: var(--bs-primary-bg-subtle);
    }
    
    .ecf-type-card.active {
        border-color: var(--bs-primary);
        background-color: var(--bs-primary-bg-subtle);
        box-shadow: 0 4px 15px rgba(var(--bs-primary-rgb), 0.15);
    }
    
    .step-indicator {
        width: 35px;
        height: 35px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: bold;
        background: #f8f9fa;
        color: #adb5bd;
        margin-right: 10px;
    }
    
    .step-item.active .step-indicator {
        background: var(--bs-primary);
        color: white;
        box-shadow: 0 0 0 4px rgba(var(--bs-primary-rgb), 0.15);
    }
    
    .floating-label-group {
        position: relative;
    }
    
    .gradient-header {
        background: linear-gradient(135deg, #4e73df 0%, #224abe 100%);
    }
</style>

<!-- Stepper Container -->
<div class="row mb-4 justify-content-center">
    <div class="col-md-10">
        <div class="d-flex justify-content-between align-items-center bg-white p-3 rounded-pill shadow-sm glass-card">
            <div class="step-item active d-flex align-items-center ms-4">
                <div class="step-indicator">1</div>
                <span class="fw-bold text-primary d-none d-md-block">Encabezado</span>
            </div>
            <div class="h-px bg-light flex-grow-1 mx-3" style="height: 2px;"></div>
            <div class="step-item d-flex align-items-center">
                <div class="step-indicator">2</div>
                <span class="fw-medium text-muted d-none d-md-block">Líneas de Detalle</span>
            </div>
            <div class="h-px bg-light flex-grow-1 mx-3" style="height: 2px;"></div>
            <div class="step-item d-flex align-items-center me-4">
                <div class="step-indicator">3</div>
                <span class="fw-medium text-muted d-none d-md-block">Firma y Envío</span>
            </div>
        </div>
    </div>
</div>

<form asp-action="Create" method="post" id="formCreateFactura">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="TipoECF" id="inputTipoECF" value="31" />
    
    <div asp-validation-summary="All" class="alert alert-danger mx-auto" style="max-width: 800px; display: @(ViewData.ModelState.IsValid ? "none" : "block")"></div>

    <div class="row g-4 justify-content-center">
        <div class="col-md-10 col-lg-7">
            <!-- Selector de Tipo de Comprobante (Interactivo) -->
            <div class="mb-4">
                <h5 class="fw-bold mb-3 text-dark d-flex align-items-center">
                    <i class="ri-settings-3-line me-2 text-primary"></i>
                    ¿Qué tipo de comprobante vas a emitir?
                </h5>
                <div class="row g-3">
                    <div class="col-sm-6">
                        <div class="card ecf-type-card active rounded-4 p-3 h-100" data-value="31" onclick="selectECFType(this, '31')">
                            <div class="d-flex align-items-center mb-2">
                                <div class="bg-primary bg-opacity-10 p-2 rounded-3 me-2">
                                    <i class="ri-building-line text-primary fs-4"></i>
                                </div>
                                <h6 class="mb-0 fw-bold">E31 - Crédito Fiscal</h6>
                            </div>
                            <p class="small text-muted mb-0">Para empresas y personas que necesitan sustentar gastos/costos.</p>
                        </div>
                    </div>
                    <div class="col-sm-6">
                        <div class="card ecf-type-card rounded-4 p-3 h-100" data-value="32" onclick="selectECFType(this, '32')">
                            <div class="d-flex align-items-center mb-2">
                                <div class="bg-success bg-opacity-10 p-2 rounded-3 me-2">
                                    <i class="ri-user-heart-line text-success fs-4"></i>
                                </div>
                                <h6 class="mb-0 fw-bold">E32 - Consumo</h6>
                            </div>
                            <p class="small text-muted mb-0">Para ventas a consumidores finales sin valor fiscal.</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Formulario Principal -->
            <div class="card border-0 rounded-4 glass-card shadow-sm mb-4">
                <div class="card-body p-4 p-md-5">
                    <div class="row g-4">
                        <div class="col-12">
                            <label class="form-label fw-bold">Seleccionar Cliente</label>
                            <div class="input-group input-group-lg">
                                <span class="input-group-text bg-white border-end-0"><i class="ri-search-2-line text-muted"></i></span>
                                <select asp-for="ClienteId" asp-items="ViewBag.Clientes" class="form-select border-start-0" required id="selectCliente">
                                    <option value="">Buscar en tu base de datos de clientes...</option>
                                </select>
                            </div>
                            <div id="clienteInfoContainer" class="mt-3 p-3 rounded-4 bg-light border-0 d-none animate__animated animate__fadeIn">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div class="d-flex align-items-center">
                                        <div class="avatar-sm bg-primary text-white rounded-circle d-flex align-items-center justify-content-center me-3" id="clienteAvatar">?</div>
                                        <div>
                                            <h6 class="mb-0 fw-bold" id="clienteNombreText">-</h6>
                                            <small class="text-muted" id="clienteRNCText">RNC: -</small>
                                        </div>
                                    </div>
                                    <button type="button" class="btn btn-sm btn-outline-primary rounded-pill px-3">Ver Perfil</button>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="FechaEmision" class="form-label fw-bold">Fecha de Factura</label>
                            <input asp-for="FechaEmision" type="date" class="form-control form-control-lg rounded-3 border-0 bg-light" required value="@DateTime.Now.ToString("yyyy-MM-dd")" />
                        </div>

                        <div class="col-md-6">
                            <label asp-for="FechaVencimiento" class="form-label fw-bold">Fecha de Vencimiento</label>
                            <input asp-for="FechaVencimiento" type="date" class="form-control form-control-lg rounded-3 border-0 bg-light" required value="@DateTime.Now.AddDays(30).ToString("yyyy-MM-dd")" />
                        </div>

                        <div class="col-md-12">
                            <label class="form-label fw-bold">Condición de Pago</label>
                            <div class="d-flex gap-2">
                                <input type="radio" asp-for="TipoPago" class="btn-check" id="pagoContado" value="1" checked>
                                <label class="btn btn-outline-light text-dark border-0 bg-light flex-grow-1 py-3 rounded-3" for="pagoContado">
                                    <i class="ri-money-dollar-circle-line d-block fs-4 mb-1"></i> Contado
                                </label>

                                <input type="radio" asp-for="TipoPago" class="btn-check" id="pagoCredito" value="2">
                                <label class="btn btn-outline-light text-dark border-0 bg-light flex-grow-1 py-3 rounded-3" for="pagoCredito">
                                    <i class="ri-time-line d-block fs-4 mb-1"></i> Crédito
                                </label>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Columna Lateral de Resumen -->
        <div class="col-md-10 col-lg-3">
            <div class="sticky-top" style="top: 2rem;">
                <div class="card border-0 rounded-4 shadow-sm bg-white mb-4 overflow-hidden shadow-lg border-top border-4 border-primary">
                    <div class="card-body p-4">
                        <div class="d-flex align-items-center mb-4">
                            <div class="bg-primary bg-opacity-10 p-2 rounded-3 me-2">
                                <i class="ri-rocket-2-line text-primary fs-4"></i>
                            </div>
                            <h5 class="mb-0 fw-bold text-dark">Resumen</h5>
                        </div>
                        
                        <div class="mb-3 d-flex justify-content-between align-items-center">
                            <span class="text-muted small">Tipo:</span>
                            <span class="badge bg-primary-subtle text-primary rounded-pill" id="badgeTipoECF">E31 - Crédito Fiscal</span>
                        </div>
                        <div class="mb-3 d-flex justify-content-between align-items-center">
                            <span class="text-muted small">ITBIS:</span>
                            <span class="fw-bold text-dark">18.00% (DOP)</span>
                        </div>
                        <hr class="bg-light">
                        <p class="small text-muted mb-4">Se asignará un NCF automáticamente al guardar el encabezado.</p>
                        
                        <button type="submit" class="btn btn-primary w-100 py-3 rounded-3 fw-bold mb-3 shadow-sm">
                            CREAR Y CONTINUAR
                            <i class="ri-arrow-right-line ms-2"></i>
                        </button>
                        
                        <a href="@Url.Action("Index")" class="btn btn-link text-muted w-100 py-2 small text-decoration-none">
                            Cancelar operación
                        </a>
                    </div>
                </div>

                <div class="card border-0 rounded-4 shadow-sm bg-info bg-opacity-10 border border-info border-opacity-10">
                    <div class="card-body p-3">
                        <div class="d-flex">
                            <i class="ri-shield-user-line text-info fs-3 me-2"></i>
                            <div>
                                <h6 class="fw-bold text-info mb-1">Factura Segura</h6>
                                <p class="small text-muted mb-0">Toda la información se valida con los estándares de la DGII.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    <script>
        function selectECFType(element, value) {
            document.querySelectorAll('.ecf-type-card').forEach(c => c.classList.remove('active'));
            element.classList.add('active');
            document.getElementById('inputTipoECF').value = value;
            document.getElementById('badgeTipoECF').innerText = (value === '31' ? 'E31 - Crédito Fiscal' : 'E32 - Consumo');
        }

        // Simulación de búsqueda de cliente (Mejorar con AJAX real después)
        document.getElementById('selectCliente').addEventListener('change', function() {
            const container = document.getElementById('clienteInfoContainer');
            if (this.value) {
                const nombre = this.options[this.selectedIndex].text;
                document.getElementById('clienteNombreText').innerText = nombre;
                document.getElementById('clienteAvatar').innerText = nombre.substring(0, 1).toUpperCase();
                container.classList.remove('d-none');
            } else {
                container.classList.add('d-none');
            }
        });
    </script>
}
