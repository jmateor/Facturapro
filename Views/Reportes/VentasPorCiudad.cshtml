@model List<Facturapro.Models.ViewModels.Reportes.VentasPorCiudadViewModel>

@{
    ViewData["Title"] = "Ventas por Ciudad";
    var cultura = new System.Globalization.CultureInfo("es-DO");
}

<!-- Page Header -->
<div class="page-header-title">
    <div class="d-flex align-items-center justify-content-between">
        <div>
            <h4 class="page-title mb-1">
                <i class="ri-map-pin-2-line me-1"></i>
                Ventas por Ciudad
            </h4>
            <p class="text-muted mb-0">Distribución geográfica de las ventas</p>
        </div>
        <div>
            <a href="@Url.Action("General")" class="btn btn-soft-secondary">
                <i class="ri-arrow-left-line me-1"></i> Volver
            </a>
        </div>
    </div>
</div>

<!-- Filtros -->
<div class="card mb-3">
    <div class="card-body">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-4">
                <label class="form-label small">Desde</label>
                <input type="date" name="desde" class="form-control" value="@Context.Request.Query["desde"]" />
            </div>
            <div class="col-md-4">
                <label class="form-label small">Hasta</label>
                <input type="date" name="hasta" class="form-control" value="@Context.Request.Query["hasta"]" />
            </div>
            <div class="col-md-4">
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary flex-grow-1">
                        <i class="ri-filter-search-line me-1"></i> Filtrar
                    </button>
                    <a href="@Url.Action("VentasPorCiudad")" class="btn btn-soft-secondary">
                        <i class="ri-close-line"></i>
                    </a>
                </div>
            </div>
        </form>
    </div>
</div>

<!-- Tabla -->
<div class="card">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover table-centered mb-0">
                <thead class="table-light">
                    <tr>
                        <th style="width: 8%;">#</th>
                        <th style="width: 25%;">Ciudad</th>
                        <th style="width: 15%;" class="text-center">Clientes</th>
                        <th style="width: 15%;" class="text-center">Facturas</th>
                        <th style="width: 17%;" class="text-end">Total Ventas</th>
                        <th style="width: 10%;" class="text-end">%</th>
                        <th style="width: 10%;"></th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        var posicion = 1;
                    }
                    @foreach (var ciudad in Model)
                    {
                        <tr>
                            <td>
                                <span class="badge @(posicion <= 3 ? "bg-warning text-dark" : "bg-light text-dark") fw-bold">#@posicion</span>
                            </td>
                            <td>
                                <div class="d-flex align-items-center">
                                    <div class="avatar-sm bg-soft-info text-info rounded-circle d-flex align-items-center justify-content-center me-2" style="width: 32px; height: 32px;">
                                        <i class="ri-map-pin-line"></i>
                                    </div>
                                    <span class="fw-semibold">@ciudad.Ciudad</span>
                                </div>
                            </td>
                            <td class="text-center">
                                <span class="badge bg-light text-dark">@ciudad.CantidadClientes</span>
                            </td>
                            <td class="text-center">
                                <span class="text-muted">@ciudad.CantidadFacturas</span>
                            </td>
                            <td class="text-end">
                                <span class="fw-bold text-success">@ciudad.TotalVentas.ToString("C", cultura)</span>
                            </td>
                            <td class="text-end">
                                <div class="d-flex align-items-center justify-content-end gap-2">
                                    <div class="progress" style="width: 80px; height: 8px;">
                                        <div class="progress-bar bg-info" role="progressbar" style="width: @ciudad.Porcentaje%"></div>
                                    </div>
                                    <span class="fw-bold">@ciudad.Porcentaje.ToString("F1")%</span>
                                </div>
                            </td>
                            <td>
                                <a href="@Url.Action("General", new { ciudad = ciudad.Ciudad })" class="btn btn-sm btn-soft-info">
                                    <i class="ri-eye-line"></i>
                                </a>
                            </td>
                        </tr>
                        posicion++;
                    }
                </tbody>
            </table>
        </div>

        @if (!Model.Any())
        {
            <div class="text-center py-5">
                <div class="avatar-lg bg-soft-info rounded-circle mb-3 mx-auto d-inline-flex" style="width: 100px; height: 100px;">
                    <i class="ri-map-pin-2-line display-4 text-info"></i>
                </div>
                <h5 class="fw-semibold">Sin datos de ubicación</h5>
                <p class="text-muted mb-3">Los clientes no tienen ciudad registrada</p>
            </div>
        }
    </div>
</div>
