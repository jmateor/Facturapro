@model Facturapro.Models.ViewModels.Reportes.ReporteGeneralViewModel

@{
    ViewData["Title"] = "Reporte General de Ventas";
    var cultura = new System.Globalization.CultureInfo("es-DO");
}

<!-- Page Header -->
<div class="page-header-title">
    <div class="d-flex align-items-center justify-content-between">
        <div>
            <h4 class="page-title mb-1">
                <i class="ri-file-chart-line me-1"></i>
                Reporte General de Ventas
            </h4>
            <p class="text-muted mb-0">Consulta y exporta reportes detallados de ventas</p>
        </div>
        <div class="d-flex gap-2">
            <a href="@Url.Action("ExportarPDF", new { desde = Model.FechaDesde, hasta = Model.FechaHasta, clienteId = Model.ClienteId, tipoReporte = Model.TipoReporte })" class="btn btn-primary" target="_blank">
                <i class="ri-file-pdf-line me-1"></i> Exportar PDF
            </a>
            <a href="@Url.Action("Dashboard")" class="btn btn-soft-secondary">
                <i class="ri-arrow-left-line me-1"></i> Volver
            </a>
        </div>
    </div>
</div>

<!-- Filtros -->
<div class="card mb-3">
    <div class="card-body">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-2">
                <label class="form-label small">Tipo de Reporte</label>
                <select name="tipoReporte" class="form-select" onchange="this.form.submit()">
                    <option value="">Ventas Normales</option>
                    <option value="anuladas" selected="@(Model.TipoReporte == "anuladas" ? "selected" : "")">Facturas Anuladas</option>
                    <option value="devoluciones" selected="@(Model.TipoReporte == "devoluciones" ? "selected" : "")">Devoluciones</option>
                </select>
            </div>

            <div class="col-md-2">
                <label class="form-label small">Año</label>
                <select name="anio" class="form-select" onchange="this.form.submit()">
                    <option value="">Todos</option>
                    @if (ViewBag.Anios != null)
                    {
                        foreach (var anio in ViewBag.Anios)
                        {
                            if (Model.Anio == anio)
                            {
                                <option value="@anio" selected>@anio</option>
                            }
                            else
                            {
                                <option value="@anio">@anio</option>
                            }
                        }
                    }
                </select>
            </div>

            <div class="col-md-2">
                <label class="form-label small">Desde</label>
                <input type="date" name="desde" class="form-control" value="@Model.FechaDesde.ToString("yyyy-MM-dd")" />
            </div>

            <div class="col-md-2">
                <label class="form-label small">Hasta</label>
                <input type="date" name="hasta" class="form-control" value="@Model.FechaHasta.ToString("yyyy-MM-dd")" />
            </div>

            <div class="col-md-2">
                <label class="form-label small">Cliente</label>
                <select name="clienteId" class="form-select">
                    <option value="">Todos</option>
                    @if (ViewBag.Clientes != null)
                    {
                        foreach (var cliente in ViewBag.Clientes)
                        {
                            if (Model.ClienteId == cliente.Value)
                            {
                                <option value="@cliente.Value" selected>@cliente.Text</option>
                            }
                            else
                            {
                                <option value="@cliente.Value">@cliente.Text</option>
                            }
                        }
                    }
                </select>
            </div>

            <div class="col-md-2">
                <label class="form-label small">Categoría</label>
                <select name="categoriaId" class="form-select">
                    <option value="">Todas</option>
                    @if (ViewBag.Categorias != null)
                    {
                        foreach (var categoria in ViewBag.Categorias)
                        {
                            if (Model.CategoriaId == categoria.Value)
                            {
                                <option value="@categoria.Value" selected>@categoria.Text</option>
                            }
                            else
                            {
                                <option value="@categoria.Value">@categoria.Text</option>
                            }
                        }
                    }
                </select>
            </div>

            <div class="col-md-2">
                <label class="form-label small">Producto</label>
                <select name="productoId" class="form-select">
                    <option value="">Todos</option>
                    @if (ViewBag.Productos != null)
                    {
                        foreach (var producto in ViewBag.Productos)
                        {
                            if (Model.ProductoId == producto.Value)
                            {
                                <option value="@producto.Value" selected>@producto.Text</option>
                            }
                            else
                            {
                                <option value="@producto.Value">@producto.Text</option>
                            }
                        }
                    }
                </select>
            </div>

            <div class="col-md-2">
                <label class="form-label small">Ciudad</label>
                <select name="ciudad" class="form-select">
                    <option value="">Todas</option>
                    @if (ViewBag.Ciudades != null)
                    {
                        foreach (var ciudad in ViewBag.Ciudades)
                        {
                            if (Model.Ciudad == ciudad.Value)
                            {
                                <option value="@ciudad.Value" selected>@ciudad.Text</option>
                            }
                            else
                            {
                                <option value="@ciudad.Value">@ciudad.Text</option>
                            }
                        }
                    }
                </select>
            </div>

            <div class="col-md-4">
                <div class="d-flex gap-2 align-items-end h-100">
                    <button type="submit" class="btn btn-primary flex-grow-1">
                        <i class="ri-filter-search-line me-1"></i> Filtrar
                    </button>
                    <a href="@Url.Action("General")" class="btn btn-soft-secondary" title="Limpiar filtros">
                        <i class="ri-close-line"></i>
                    </a>
                </div>
            </div>
        </form>
    </div>
</div>

<!-- Tarjetas de Resumen -->
<div class="row g-3 mb-3">
    <div class="col-md-3">
        <div class="card">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <p class="text-muted mb-0 small">Total Facturas</p>
                        <h4 class="mb-0 fw-bold">@Model.TotalFacturas</h4>
                    </div>
                    <div class="avatar-md bg-primary text-white rounded-circle d-flex align-items-center justify-content-center">
                        <i class="ri-file-list-3-line fs-4"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <p class="text-muted mb-0 small">Total Ventas</p>
                        <h4 class="mb-0 fw-bold text-success">@Model.TotalVentas.ToString("C", cultura)</h4>
                    </div>
                    <div class="avatar-md bg-success text-white rounded-circle d-flex align-items-center justify-content-center">
                        <i class="ri-money-dollar-circle-line fs-4"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <p class="text-muted mb-0 small">Total ITBIS</p>
                        <h4 class="mb-0 fw-bold text-info">@Model.TotalITBIS.ToString("C", cultura)</h4>
                    </div>
                    <div class="avatar-md bg-info text-white rounded-circle d-flex align-items-center justify-content-center">
                        <i class="ri-percent-line fs-4"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <p class="text-muted mb-0 small">Promedio por Factura</p>
                        <h4 class="mb-0 fw-bold">@(Model.TotalFacturas > 0 ? (Model.TotalVentas / Model.TotalFacturas).ToString("C", cultura) : "$0.00")</h4>
                    </div>
                    <div class="avatar-md bg-warning text-white rounded-circle d-flex align-items-center justify-content-center">
                        <i class="ri-calculator-line fs-4"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Tabla de Facturas -->
<div class="card">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover table-centered mb-0">
                <thead class="table-light">
                    <tr>
                        <th style="width: 10%;">Fecha</th>
                        <th style="width: 12%;">Factura</th>
                        <th style="width: 20%;">Cliente</th>
                        <th style="width: 10%;">Tipo</th>
                        <th style="width: 10%;" class="text-center">Estado</th>
                        <th style="width: 12%;" class="text-end">Subtotal</th>
                        <th style="width: 10%;" class="text-end">ITBIS</th>
                        <th style="width: 16%;" class="text-end">Total</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var factura in Model.Facturas.OrderBy(f => f.FechaEmision))
                    {
                        var estadoClass = factura.EstadoDGII.ToLower() switch
                        {
                            "aprobado" or "firmado" => "bg-success-soft text-success",
                            "rechazado" or "cancelada" => "bg-danger-soft text-danger",
                            "enviado" or "enproceso" => "bg-warning-soft text-warning",
                            _ => "bg-secondary-soft text-secondary"
                        };

                        <tr>
                            <td>
                                <div class="d-flex align-items-center">
                                    <i class="ri-calendar-line me-2 text-muted"></i>
                                    <div>
                                        <div class="fw-semibold">@factura.FechaEmision.ToString("dd/MM/yyyy")</div>
                                        <small class="text-muted">@factura.FechaEmision.ToString("HH:mm")</small>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <div>
                                    <span class="fw-semibold">@factura.NumeroFactura</span>
                                    @if (!string.IsNullOrEmpty(factura.ENCF))
                                    {
                                        <br /><small class="text-success"><i class="ri-checkbox-circle-line me-1"></i>@factura.ENCF</small>
                                    }
                                </div>
                            </td>
                            <td>
                                <div class="d-flex align-items-center">
                                    <div class="avatar-sm bg-soft-primary text-primary rounded-circle d-flex align-items-center justify-content-center me-2" style="width: 32px; height: 32px;">
                                        <i class="ri-user-3-line"></i>
                                    </div>
                                    <div>
                                        <div class="fw-semibold">@factura.ClienteNombre</div>
                                        @if (!string.IsNullOrEmpty(factura.ClienteRNC))
                                        {
                                            <small class="text-muted">RNC: @factura.ClienteRNC</small>
                                        }
                                    </div>
                                </div>
                            </td>
                            <td>
                                <span class="badge bg-info-soft text-info">
                                    @factura.TipoECFTexto
                                </span>
                            </td>
                            <td class="text-center">
                                <span class="badge @estadoClass">
                                    @factura.EstadoDGII
                                </span>
                            </td>
                            <td class="text-end">
                                <span class="text-muted">@factura.Subtotal.ToString("C", cultura)</span>
                            </td>
                            <td class="text-end">
                                <span class="text-success">@factura.ITBIS.ToString("C", cultura)</span>
                            </td>
                            <td class="text-end">
                                <span class="fw-bold text-primary">@factura.Total.ToString("C", cultura)</span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (!Model.Facturas.Any())
        {
            <div class="text-center py-5">
                <div class="avatar-lg bg-soft-primary rounded-circle mb-3 mx-auto d-inline-flex" style="width: 100px; height: 100px;">
                    <i class="ri-file-chart-line display-4 text-primary"></i>
                </div>
                <h5 class="fw-semibold">Sin resultados</h5>
                <p class="text-muted mb-3">No hay facturas con los filtros seleccionados</p>
                <a href="@Url.Action("General")" class="btn btn-primary">
                    <i class="ri-refresh-line me-1"></i> Ver todas las ventas
                </a>
            </div>
        }
    </div>
</div>

<!-- Enlaces rápidos a otros reportes -->
<div class="row g-3 mt-3">
    <div class="col-12">
        <h6 class="card-title mb-3">
            <i class="ri-folder-chart-line me-1 text-primary"></i>
            Otros Reportes Disponibles
        </h6>
    </div>
    <div class="col-md-4">
        <a href="@Url.Action("ProductosMasVendidos")" class="card card-link">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div class="avatar-md bg-success text-white rounded-circle d-flex align-items-center justify-content-center me-3">
                        <i class="ri-trophy-line fs-4"></i>
                    </div>
                    <div>
                        <h6 class="mb-0">Productos Más Vendidos</h6>
                        <small class="text-muted">Ranking de productos por ventas</small>
                    </div>
                </div>
            </div>
        </a>
    </div>
    <div class="col-md-4">
        <a href="@Url.Action("VentasPorCategoria")" class="card card-link">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div class="avatar-md bg-info text-white rounded-circle d-flex align-items-center justify-content-center me-3">
                        <i class="ri-pie-chart-2-line fs-4"></i>
                    </div>
                    <div>
                        <h6 class="mb-0">Ventas por Categoría</h6>
                        <small class="text-muted">Distribución de ventas por categoría</small>
                    </div>
                </div>
            </div>
        </a>
    </div>
    <div class="col-md-4">
        <a href="@Url.Action("VentasPorCiudad")" class="card card-link">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div class="avatar-md bg-warning text-white rounded-circle d-flex align-items-center justify-content-center me-3">
                        <i class="ri-map-pin-2-line fs-4"></i>
                    </div>
                    <div>
                        <h6 class="mb-0">Ventas por Ciudad</h6>
                        <small class="text-muted">Ventas segmentadas por ubicación</small>
                    </div>
                </div>
            </div>
        </a>
    </div>
    <div class="col-md-4">
        <a href="@Url.Action("VentasPorAnio")" class="card card-link">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div class="avatar-md bg-purple text-white rounded-circle d-flex align-items-center justify-content-center me-3">
                        <i class="ri-calendar-2-line fs-4"></i>
                    </div>
                    <div>
                        <h6 class="mb-0">Ventas por Año</h6>
                        <small class="text-muted">Histórico anual de ventas</small>
                    </div>
                </div>
            </div>
        </a>
    </div>
    <div class="col-md-4">
        <a href="@Url.Action("Devoluciones")" class="card card-link">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div class="avatar-md bg-danger text-white rounded-circle d-flex align-items-center justify-content-center me-3">
                        <i class="ri-return-line fs-4"></i>
                    </div>
                    <div>
                        <h6 class="mb-0">Listado de Devoluciones</h6>
                        <small class="text-muted">Notas de crédito y devoluciones</small>
                    </div>
                </div>
            </div>
        </a>
    </div>
    <div class="col-md-4">
        <a href="@Url.Action("Inventario")" class="card card-link">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div class="avatar-md bg-secondary text-white rounded-circle d-flex align-items-center justify-content-center me-3">
                        <i class="ri-archive-line fs-4"></i>
                    </div>
                    <div>
                        <h6 class="mb-0">Inventario</h6>
                        <small class="text-muted">Reporte de stock y valoración</small>
                    </div>
                </div>
            </div>
        </a>
    </div>
</div>

@section Scripts {
    <script>
        // Auto-submit cuando cambian ciertos filtros
        document.querySelectorAll('select[name="anio"], select[name="tipoReporte"]').forEach(function(select) {
            select.addEventListener('change', function() {
                // Pequeño delay para mejor UX
                setTimeout(() => this.form.submit(), 100);
            });
        });
    </script>
}
