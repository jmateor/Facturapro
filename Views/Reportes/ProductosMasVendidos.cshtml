@model List<Facturapro.Models.ViewModels.Reportes.ProductosMasVendidosViewModel>

@{
    ViewData["Title"] = "Productos Más Vendidos";
    var cultura = new System.Globalization.CultureInfo("es-DO");
}

<!-- Page Header -->
<div class="page-header-title">
    <div class="d-flex align-items-center justify-content-between">
        <div>
            <h4 class="page-title mb-1">
                <i class="ri-trophy-line me-1"></i>
                Productos Más Vendidos
            </h4>
            <p class="text-muted mb-0">Ranking de productos por cantidad vendida</p>
        </div>
        <div>
            <a href="@Url.Action("General")" class="btn btn-soft-secondary">
                <i class="ri-arrow-left-line me-1"></i> Volver
            </a>
        </div>
    </div>
</div>

<!-- Filtros -->
<div class="card mb-3">
    <div class="card-body">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-3">
                <label class="form-label small">Desde</label>
                <input type="date" name="desde" class="form-control" value="@Context.Request.Query["desde"]" />
            </div>
            <div class="col-md-3">
                <label class="form-label small">Hasta</label>
                <input type="date" name="hasta" class="form-control" value="@Context.Request.Query["hasta"]" />
            </div>
            <div class="col-md-3">
                <label class="form-label small">Categoría</label>
                <select name="categoriaId" class="form-select">
                    <option value="">Todas</option>
                    @if (ViewBag.Categorias != null)
                    {
                        foreach (var cat in ViewBag.Categorias)
                        {
                            <option value="@cat.Value" selected="@(Context.Request.Query["categoriaId"] == cat.Value ? "selected" : "")">@cat.Text</option>
                        }
                    }
                </select>
            </div>
            <div class="col-md-3">
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary flex-grow-1">
                        <i class="ri-filter-search-line me-1"></i> Filtrar
                    </button>
                    <a href="@Url.Action("ProductosMasVendidos")" class="btn btn-soft-secondary">
                        <i class="ri-close-line"></i>
                    </a>
                </div>
            </div>
        </form>
    </div>
</div>

<!-- Tabla -->
<div class="card">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover table-centered mb-0">
                <thead class="table-light">
                    <tr>
                        <th style="width: 8%;">#</th>
                        <th style="width: 35%;">Producto</th>
                        <th style="width: 15%;" class="text-center">Cantidad Vendida</th>
                        <th style="width: 15%;" class="text-center">Facturas</th>
                        <th style="width: 17%;" class="text-end">Total Ventas</th>
                        <th style="width: 10%;"></th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        var posicion = 1;
                    }
                    @foreach (var producto in Model)
                    {
                        var badgeClass = posicion <= 3 ? "bg-warning text-dark" : "bg-light text-dark";
                        var icono = posicion switch
                        {
                            1 => "<i class=\'ri-medal-line me-1\'></i>",
                            2 => "<i class=\'ri-medal-2-line me-1\'></i>",
                            3 => "<i class=\'ri-medal-fill me-1\'></i>",
                            _ => ""
                        };
                        <tr>
                            <td>
                                <span class="badge @badgeClass fw-bold">
                                    @Html.Raw(icono)#@posicion
                                </span>
                            </td>
                            <td>
                                <div class="d-flex align-items-center">
                                    <div class="avatar-sm bg-soft-primary text-primary rounded-circle d-flex align-items-center justify-content-center me-2" style="width: 32px; height: 32px;">
                                        <i class="ri-box-3-line"></i>
                                    </div>
                                    <div>
                                        <div class="fw-semibold">@producto.Nombre</div>
                                        @if (!string.IsNullOrEmpty(producto.Categoria))
                                        {
                                            <small class="text-muted">@producto.Categoria</small>
                                        }
                                    </div>
                                </div>
                            </td>
                            <td class="text-center">
                                <span class="fw-bold text-success">@producto.CantidadVendida.ToString("N2")</span>
                            </td>
                            <td class="text-center">
                                <span class="text-muted">@producto.NumeroFacturas</span>
                            </td>
                            <td class="text-end">
                                <span class="fw-bold text-primary">@producto.TotalVentas.ToString("C", cultura)</span>
                            </td>
                            <td>
                                <a href="@Url.Action("General", new { productoId = producto.ProductoId })" class="btn btn-sm btn-soft-info">
                                    <i class="ri-eye-line"></i>
                                </a>
                            </td>
                        </tr>
                        posicion++;
                    }
                </tbody>
            </table>
        </div>

        @if (!Model.Any())
        {
            <div class="text-center py-5">
                <div class="avatar-lg bg-soft-success rounded-circle mb-3 mx-auto d-inline-flex" style="width: 100px; height: 100px;">
                    <i class="ri-trophy-line display-4 text-success"></i>
                </div>
                <h5 class="fw-semibold">Sin datos de ventas</h5>
                <p class="text-muted mb-3">No hay productos vendidos en el período seleccionado</p>
            </div>
        }
    </div>
</div>
