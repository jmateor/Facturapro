@model List<Facturapro.Models.ViewModels.Reportes.DevolucionReporteViewModel>

@{
    ViewData["Title"] = "Listado de Devoluciones";
    var cultura = new System.Globalization.CultureInfo("es-DO");
}

<!-- Page Header -->
<div class="page-header-title">
    <div class="d-flex align-items-center justify-content-between">
        <div>
            <h4 class="page-title mb-1">
                <i class="ri-return-line me-1"></i>
                Listado de Devoluciones
            </h4>
            <p class="text-muted mb-0">Notas de crédito y devoluciones de clientes</p>
        </div>
        <div class="d-flex gap-2">
            <a href="@Url.Action("ExportarPDF", new { desde = Context.Request.Query["desde"], hasta = Context.Request.Query["hasta"], clienteId = Context.Request.Query["clienteId"], tipoReporte = "devoluciones" })" class="btn btn-primary" target="_blank">
                <i class="ri-file-pdf-line me-1"></i> Exportar PDF
            </a>
            <a href="@Url.Action("General")" class="btn btn-soft-secondary">
                <i class="ri-arrow-left-line me-1"></i> Volver
            </a>
        </div>
    </div>
</div>

<!-- Filtros -->
<div class="card mb-3">
    <div class="card-body">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-3">
                <label class="form-label small">Desde</label>
                <input type="date" name="desde" class="form-control" value="@Context.Request.Query["desde"]" />
            </div>
            <div class="col-md-3">
                <label class="form-label small">Hasta</label>
                <input type="date" name="hasta" class="form-control" value="@Context.Request.Query["hasta"]" />
            </div>
            <div class="col-md-3">
                <label class="form-label small">Cliente</label>
                <select name="clienteId" class="form-select">
                    <option value="">Todos</option>
                    @if (ViewBag.Clientes != null)
                    {
                        foreach (var cliente in ViewBag.Clientes)
                        {
                            <option value="@cliente.Value" selected="@(Context.Request.Query["clienteId"] == cliente.Value ? "selected" : "")">@cliente.Text</option>
                        }
                    }
                </select>
            </div>
            <div class="col-md-3">
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary flex-grow-1">
                        <i class="ri-filter-search-line me-1"></i> Filtrar
                    </button>
                    <a href="@Url.Action("Devoluciones")" class="btn btn-soft-secondary">
                        <i class="ri-close-line"></i>
                    </a>
                </div>
            </div>
        </form>
    </div>
</div>

<!-- Resumen -->
<div class="row g-3 mb-3">
    <div class="col-md-4">
        <div class="card">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <p class="text-muted mb-0 small">Total Devoluciones</p>
                        <h4 class="mb-0 fw-bold">@Model.Count</h4>
                    </div>
                    <div class="avatar-md bg-danger text-white rounded-circle d-flex align-items-center justify-content-center">
                        <i class="ri-return-line fs-4"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <p class="text-muted mb-0 small">Monto Total Devuelto</p>
                        <h4 class="mb-0 fw-bold text-danger">@Model.Sum(d => d.TotalDevolucion).ToString("C", cultura)</h4>
                    </div>
                    <div class="avatar-md bg-danger text-white rounded-circle d-flex align-items-center justify-content-center">
                        <i class="ri-money-dollar-circle-line fs-4"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <p class="text-muted mb-0 small">Clientes con Devoluciones</p>
                        <h4 class="mb-0 fw-bold">@Model.Select(d => d.ClienteNombre).Distinct().Count()</h4>
                    </div>
                    <div class="avatar-md bg-warning text-white rounded-circle d-flex align-items-center justify-content-center">
                        <i class="ri-user-3-line fs-4"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Tabla -->
<div class="card">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover table-centered mb-0">
                <thead class="table-light">
                    <tr>
                        <th style="width: 10%;">Fecha</th>
                        <th style="width: 15%;">Factura</th>
                        <th style="width: 25%;">Cliente</th>
                        <th style="width: 15%;">RNC</th>
                        <th style="width: 15%;" class="text-center">Tipo</th>
                        <th style="width: 20%;" class="text-end">Monto Devolución</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var devolucion in Model)
                    {
                        <tr>
                            <td>
                                <div class="d-flex align-items-center">
                                    <i class="ri-calendar-line me-2 text-muted"></i>
                                    <span class="fw-semibold">@devolucion.FechaEmision.ToString("dd/MM/yyyy")</span>
                                </div>
                            </td>
                            <td>
                                <div>
                                    <span class="fw-semibold">@devolucion.NumeroFactura</span>
                                    @if (!string.IsNullOrEmpty(devolucion.ENCF))
                                    {
                                        <br /><small class="text-success"><i class="ri-checkbox-circle-line me-1"></i>@devolucion.ENCF</small>
                                    }
                                </div>
                            </td>
                            <td>
                                <div class="d-flex align-items-center">
                                    <div class="avatar-sm bg-soft-danger text-danger rounded-circle d-flex align-items-center justify-content-center me-2" style="width: 32px; height: 32px;">
                                        <i class="ri-user-3-line"></i>
                                    </div>
                                    <span class="fw-semibold">@devolucion.ClienteNombre</span>
                                </div>
                            </td>
                            <td>
                                <span class="text-muted">@(devolucion.ClienteRNC ?? "-")</span>
                            </td>
                            <td class="text-center">
                                <span class="badge bg-danger-soft text-danger">
                                    <i class="ri-return-line me-1"></i>Devolución
                                </span>
                            </td>
                            <td class="text-end">
                                <span class="fw-bold text-danger">@devolucion.TotalDevolucion.ToString("C", cultura)</span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (!Model.Any())
        {
            <div class="text-center py-5">
                <div class="avatar-lg bg-soft-danger rounded-circle mb-3 mx-auto d-inline-flex" style="width: 100px; height: 100px;">
                    <i class="ri-return-line display-4 text-danger"></i>
                </div>
                <h5 class="fw-semibold">Sin devoluciones registradas</h5>
                <p class="text-muted mb-3">No hay notas de crédito o devoluciones en el período seleccionado</p>
            </div>
        }
    </div>
</div>
