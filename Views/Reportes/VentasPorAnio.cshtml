@model List<Facturapro.Models.ViewModels.Reportes.VentasPorAnioViewModel>

@{
    ViewData["Title"] = "Ventas por Año";
    var cultura = new System.Globalization.CultureInfo("es-DO");
}

<!-- Page Header -->
<div class="page-header-title">
    <div class="d-flex align-items-center justify-content-between">
        <div>
            <h4 class="page-title mb-1">
                <i class="ri-calendar-2-line me-1"></i>
                Ventas por Año
            </h4>
            <p class="text-muted mb-0">Histórico anual de ventas</p>
        </div>
        <div>
            <a href="@Url.Action("General")" class="btn btn-soft-secondary">
                <i class="ri-arrow-left-line me-1"></i> Volver
            </a>
        </div>
    </div>
</div>

<!-- Resumen -->
<div class="row g-3 mb-3">
    <div class="col-md-4">
        <div class="card">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <p class="text-muted mb-0 small">Años Registrados</p>
                        <h4 class="mb-0 fw-bold">@Model.Count</h4>
                    </div>
                    <div class="avatar-md bg-primary text-white rounded-circle d-flex align-items-center justify-content-center">
                        <i class="ri-calendar-line fs-4"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <p class="text-muted mb-0 small">Mejor Año</p>
                        <h4 class="mb-0 fw-bold text-success">@Model.OrderByDescending(a => a.TotalVentas).FirstOrDefault()?.Anio</h4>
                    </div>
                    <div class="avatar-md bg-success text-white rounded-circle d-flex align-items-center justify-content-center">
                        <i class="ri-trophy-line fs-4"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <p class="text-muted mb-0 small">Ventas Totales Históricas</p>
                        <h4 class="mb-0 fw-bold">@Model.Sum(a => a.TotalVentas).ToString("C", cultura)</h4>
                    </div>
                    <div class="avatar-md bg-info text-white rounded-circle d-flex align-items-center justify-content-center">
                        <i class="ri-money-dollar-circle-line fs-4"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Gráfico y Tabla -->
<div class="row">
    <div class="col-lg-7">
        <div class="card">
            <div class="card-body">
                <h6 class="card-title mb-3">
                    <i class="ri-bar-chart-box-line me-1"></i>
                    Evolución de Ventas por Año
                </h6>
                <div style="height: 300px;">
                    <canvas id="anioCanvas"></canvas>
                </div>
            </div>
        </div>
    </div>
    <div class="col-lg-5">
        <div class="card">
            <div class="card-body">
                <h6 class="card-title mb-3">
                    <i class="ri-list-check me-1"></i>
                    Detalle por Año
                </h6>
                <div class="table-responsive">
                    <table class="table table-hover table-centered mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Año</th>
                                <th class="text-center">Facturas</th>
                                <th class="text-end">Total Ventas</th>
                                <th class="text-end">Prom. Mensual</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var anio in Model.OrderByDescending(a => a.Anio))
                            {
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <div class="avatar-sm bg-soft-primary text-primary rounded-circle d-flex align-items-center justify-content-center me-2" style="width: 32px; height: 32px;">
                                                <span class="fw-bold" style="font-size: 0.7rem;">@anio.Anio.ToString().Substring(2, 2)</span>
                                            </div>
                                            <span class="fw-semibold">@anio.Anio</span>
                                        </div>
                                    </td>
                                    <td class="text-center">
                                        <span class="badge bg-light text-dark">@anio.CantidadFacturas</span>
                                    </td>
                                    <td class="text-end">
                                        <span class="fw-bold text-success">@anio.TotalVentas.ToString("C", cultura)</span>
                                    </td>
                                    <td class="text-end">
                                        <span class="text-muted">@anio.PromedioMensual.ToString("C", cultura)</span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        const ctx = document.getElementById('anioCanvas').getContext('2d');
        new Chart(ctx, {
            type: 'bar',
            data: {
                labels: @Html.Raw(Json.Serialize(Model.Select(a => a.Anio.ToString()))),
                datasets: [{
                    label: 'Ventas Anuales (RD$)',
                    data: @Html.Raw(Json.Serialize(Model.Select(a => a.TotalVentas))),
                    backgroundColor: '#3b82f6',
                    borderRadius: 6,
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: false }
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        ticks: {
                            callback: function(value) {
                                return 'RD$' + (value / 1000).toFixed(0) + 'K';
                            }
                        }
                    }
                }
            }
        });
    </script>
}
